{
  "id": "australia-skilled-independent-189",
  "country_id": "australia",
  "category_ids": ["skilled_worker"],
  "official_names": {
    "en": "Skilled Independent visa (subclass 189) — Points-tested stream",
    "zh-Hans": "独立技术移民签证（189 子类）- 积分测试类别"
  },
  "aliases": ["subclass 189", "Skilled Independent 189", "189 points-tested"],
  "status": "active",
  "status_note_md": {
    "en": "The points-tested stream is invitation-based through SkillSelect. Meeting the points threshold and other eligibility signals does not guarantee an invitation or visa grant.",
    "zh-Hans": "积分测试流是通过 SkillSelect 基于邀请进行的。满足积分门槛和其他资格信号并不能保证获得邀请或签证。"
  },
  "summary_md": {
    "en": "A permanent skilled visa for invited workers who do not need an employer or state sponsor. Applicants must nominate an eligible occupation, hold a suitable skills assessment, satisfy the points test, and be invited to apply.",
    "zh-Hans": "为不需要雇主或国家担保的受邀工人提供永久技术签证。申请人必须提名一个合格的职业，进行适当的技能评估，满足分数测试，并被邀请申请。"
  },
  "good_for_md": {
    "en": "Skilled workers under 45 at invitation with an occupation on the relevant skilled list, a positive skills assessment, at least Competent English, and a competitive SkillSelect points score.",
    "zh-Hans": "受邀请的 45 岁以下技术工人，其职业在相关技术清单上，具有积极的技能评估，至少具有良好的英语能力，并且具有有竞争力的 SkillSelect 分数。"
  },
  "not_good_for_md": {
    "en": "People without an eligible occupation, skills assessment, English evidence, or a competitive points score. Invitation rounds are competitive and not a personal entitlement.",
    "zh-Hans": "没有合格职业、技能评估、英语证明或竞争分数的人。邀请轮次是竞争性的，不是个人权利。"
  },
  "pathway_mechanism": "points_invitation",
  "eligibility": {
    "age": {
      "max": 44,
      "points_sensitive": true,
      "note_md": {
        "en": "You must be under 45 to be invited for the points-tested stream. Points also vary by age band.",
        "zh-Hans": "您必须年满 45 岁才能受邀参加积分测试流。分数也因年龄段而异。"
      }
    },
    "education": {
      "required_level": "unknown",
      "credential_assessment_required": true,
      "note_md": {
        "en": "There is no single universal degree minimum for all occupations. Applicants need a suitable skills assessment for the nominated occupation, and education can contribute points under the points table.",
        "zh-Hans": "对于所有职业来说，没有单一的通用最低学位。申请人需要对提名职业进行合适的技能评估，教育程度可以在积分表下贡献积分。"
      }
    },
    "work_experience": {
      "min_years": 0,
      "occupation_list_required": true,
      "note_md": {
        "en": "The nominated occupation must appear on the relevant skilled occupation list. Skilled employment contributes points, and a suitable skills assessment is required.",
        "zh-Hans": "提名职业必须出现在相关技术职业列表中。技能就业会加分，并且需要进行适当的技能评估。"
      }
    },
    "language": [
      {
        "language": "en",
        "test": "Department-approved English test",
        "minimum_level": "Competent English",
        "minimum_benchmark": 6,
        "note_md": {
          "en": "Competent English is the baseline for points-tested skilled visas. Proficient and Superior English attract additional points.",
          "zh-Hans": "合格的英语是通过打分测试的技术签证的基线。熟练和优秀的英语会吸引额外的加分。"
        }
      }
    ],
    "health_check_required": true,
    "police_certificate_required": true,
    "points_based": true,
    "points_threshold": 65,
    "invitation_competition_level": "high",
    "job_offer_required": false,
    "sponsor_required": false
  },
  "funds": {
    "proof_of_funds": [],
    "application_fees": [
      {
        "label": {
          "en": "Main applicant charge, from official materials",
          "zh-Hans": "主申请人费用，来自官方材料"
        },
        "amount": 6135,
        "currency": "AUD",
        "applies_to": "primary"
      }
    ]
  },
  "income": {
    "required": false,
    "accepted_sources": [],
    "income_location": "not_applicable",
    "stability_requirement_md": {
      "en": "No fixed income floor is stated as a universal subclass 189 points-tested minimum.",
      "zh-Hans": "没有固定收入下限被规定为通用子类 189 点测试的最低标准。"
    }
  },
  "timeline": {
    "application_processing_time_md": {
      "en": "Use the official visa processing times tool for current indications. Invitation timing is separate from post-application processing.",
      "zh-Hans": "使用官方签证处理时间工具了解当前情况。邀请时间与申请后处理是分开的。"
    },
    "processing_time_months_min": "unknown",
    "processing_time_months_max": "unknown",
    "renewable": false
  },
  "rights": {
    "work_allowed": true,
    "local_employment_allowed": true,
    "remote_work_allowed": "unknown",
    "study_allowed": true,
    "business_allowed": "unknown",
    "healthcare_access_md": {
      "en": "Permanent residents may access Medicare if eligible.",
      "zh-Hans": "如果符合条件，永久居民可以享受医疗保险。"
    },
    "tax_residency_note_md": {
      "en": "Tax residence depends on Australian tax rules and personal circumstances.",
      "zh-Hans": "税务居住地取决于澳大利亚税务规则和个人情况。"
    }
  },
  "family": {
    "spouse_or_partner_allowed": true,
    "unmarried_partner_allowed": "unknown",
    "children_allowed": true,
    "spouse_work_allowed": true,
    "dependent_parents_allowed": "not_applicable",
    "note_md": {
      "en": "Members of the family unit can be included in the application and must meet health and character requirements.",
      "zh-Hans": "家庭成员可以包含在申请中，并且必须满足健康和品格要求。"
    }
  },
  "pr_pathway": {
    "available": true,
    "summary_md": {
      "en": "A successful application grants Australian permanent residence directly.",
      "zh-Hans": "成功申请可直接授予澳大利亚永久居留权。"
    }
  },
  "citizenship_pathway": {
    "available": "indirect",
    "min_residence_years": "unknown",
    "summary_md": {
      "en": "Permanent residents may later apply for Australian citizenship if they meet the separate citizenship requirements.",
      "zh-Hans": "如果永久居民满足单独的公民身份要求，则可以稍后申请澳大利亚公民身份。"
    }
  },

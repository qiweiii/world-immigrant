{
  "id": "singapore-entrepass",
  "country_id": "singapore",
  "category_ids": ["startup_entrepreneur"],
  "official_names": {
    "en": "EntrePass",
    "zh-Hans": "创业通行证"
  },
  "aliases": ["Singapore EntrePass"],
  "status": "active",
  "status_note_md": {
    "en": "MOM describes EntrePass as a route for eligible foreign entrepreneurs operating venture-backed or innovative-technology businesses. Qualification and renewal criteria are business-specific and remain flagged for human review.",
    "zh-Hans": "MOM 将创业通行证描述为符合条件的外国企业家经营风险投资或创新技术企业的途径。资格和续订标准是针对特定业务的，并且仍标记为供人工审核。"
  },
  "summary_md": {
    "en": "A Singapore own-company work pass for foreign entrepreneurs who start or operate an ACRA-registered private limited company, hold at least 30% of it, and meet at least one qualifying funding, accelerator, technology, IP, or research criterion.",
    "zh-Hans": "新加坡自有公司工作准证，适用于创办或经营 ACRA 注册私人有限公司、持有至少 30% 股份，并满足至少一项合格资金、加速器、技术、知识产权或研究标准的外国企业家。"
  },
  "good_for_md": {
    "en": "Founders of venture-backed or innovative-technology companies who can meet the 30% ownership requirement and document at least one of MOM's qualifying entrepreneur, innovator, investor, or research criteria.",
    "zh-Hans": "风险投资支持或创新技术公司的创始人，可以满足 30% 的所有权要求，并至少记录 MOM 的一项合格企业家、创新者、投资者或研究标准。"
  },
  "not_good_for_md": {
    "en": "Ordinary small businesses such as coffee shops, bars, employment agencies, and similar excluded businesses, or founders without the qualifying business profile. This is distinct from the standard employer-sponsored EP.",
    "zh-Hans": "普通小型企业，例如咖啡店、酒吧、职业介绍所和类似的排除企业，或不具备合格企业简介的创始人。这与标准的雇主赞助的 EP 不同。"
  },
  "pathway_mechanism": "own_company",

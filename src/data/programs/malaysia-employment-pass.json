  "category_ids": ["skilled_worker"],
  "official_names": {
    "en": "Employment Pass (Category I–III)",
    "zh-Hans": "就业准证（第一至第三类别）"
  },
  "aliases": ["Malaysia Employment Pass", "Malaysia EP"],
  "status": "active",
  "status_note_md": {
    "en": "The Malaysian Expatriate Services Division maintains the Employment Pass route for eligible expatriate employees. ESD states that revised salary thresholds and a structured employment-duration framework take effect from June 1, 2026.",
    "zh-Hans": "马来西亚外籍人士服务部门继续提供面向合格外籍员工的就业准证途径。ESD 说明，修订后的薪资门槛和结构化雇佣期限框架自 2026 年 6 月 1 日起实施。"
  },
  "summary_md": {
    "en": "An employer-sponsored Malaysian work-pass route for expatriates hired by an ESD-registered company. The ESD guidebook describes company registration and activation, expatriate application, Employment Pass categories, supporting-agency processes, and pass endorsement.",
    "zh-Hans": "面向由 ESD 注册公司聘用的外籍人士的马来西亚雇主担保工作准证途径。ESD 指南说明了公司注册和激活、外籍人士申请、就业准证类别、支持机构流程以及准证签注。"
  },
  "good_for_md": {
    "en": "Professionals with a Malaysian employer that can complete ESD registration and activation, obtain any required agency support, and submit the employment-pass documents.",
    "zh-Hans": "适合拥有马来西亚雇主，且雇主能够完成 ESD 注册和激活、取得所需机构支持并提交就业准证材料的专业人士。"
  },
  "not_good_for_md": {
    "en": "Applicants seeking a self-sponsored or remote-work route, applicants without a Malaysian hiring company, or cases that do not meet the current category-specific salary and employment-duration rules.",
    "zh-Hans": "不适合寻求自我担保或远程工作的申请人、没有马来西亚聘用公司的申请人，或不符合当前类别薪资和雇佣期限规则的案件。"
  },

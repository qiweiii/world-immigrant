  "status": "active",
  "status_note_md": {
    "en": "This fixture uses the Dubai GDRFA Talented Geniuses service for culture and arts, innovators and inventors, athletes, and digital-technology talent."
  },
  "summary_md": {
    "en": "A ten-year renewable Golden Residence route for exceptional talent in culture and arts, innovation and invention, athletics, or digital technology, with nomination and category-specific evidence."
  },
  "good_for_md": {
    "en": "Recognised creatives, inventors, innovators, athletes, and digital-technology talents who can obtain a nomination letter from the relevant UAE authority and document the applicable achievements."
  },
  "not_good_for_md": {
    "en": "Applicants without a nominating authority, category-specific achievements, or a clear record matching one of the listed exceptional-talent categories."
  },
  "pathway_mechanism": "talent_pass",

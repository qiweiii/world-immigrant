  "status_note_md": {
    "en": "This fixture uses the ICP entrepreneur visa service, which describes a service to complete Golden Residency procedures for an innovative or future-oriented project."
  },
  "summary_md": {
    "en": "An entrepreneur route to complete UAE Golden Residency procedures for an innovative or future-oriented project valued at least AED 500,000 and supported by an accredited-auditor letter and competent-authority or incubator confirmation."
  },
  "good_for_md": {
    "en": "Project owners who can document an innovative or future-oriented project, obtain the competent-authority or incubator letter, and prove a project value of at least AED 500,000."
  },
  "not_good_for_md": {
    "en": "Ordinary businesses without an innovation/future-oriented classification or without the required auditor and authority documentation."
  },
  "pathway_mechanism": "own_company",

  "status": "active",
  "status_note_md": {
    "en": "The Malaysian Immigration Department and Education Malaysia Global Services describe the Student Pass as the immigration pass for non-citizen students studying at approved institutions in Malaysia.",
    "zh-Hans": "马来西亚移民局和马来西亚教育全球服务说明，学生准证是面向在马来西亚获批机构学习的非公民学生的移民准证。"
  },
  "summary_md": {
    "en": "A study residence route for international students admitted to approved Malaysian institutions. The documented process includes an offer letter, EMGS or institutional application, academic screening, eVAL, possible Single-Entry Visa, arrival medical screening, and Student Pass endorsement.",
    "zh-Hans": "面向获准进入马来西亚认可机构学习的国际学生的学习居留途径。已记录流程包括录取通知书、EMGS 或学校申请、学术审查、电子签证批准信、可能需要的单次入境签证、抵达后的体检以及学生准证签注。"
  },
  "good_for_md": {
    "en": "International students with an offer from an approved Malaysian institution who can complete the EMGS and Immigration process and maintain the required insurance and pass conditions.",
    "zh-Hans": "适合获得马来西亚认可机构录取，能够完成 EMGS 和移民局流程，并维持所需保险及准证条件的国际学生。"
  },
  "not_good_for_md": {
    "en": "Applicants seeking unrestricted work, a self-sponsored work route, or a direct permanent-residence pathway. Part-time work and dependant eligibility are conditional.",
    "zh-Hans": "不适合寻求不受限制工作、自我担保工作途径或直接永久居留途径的申请人。兼职工作和家属资格均有条件限制。"
  },
  "pathway_mechanism": "other",

  "status": "active",
  "status_note_md": {
    "en": "GOV.UK describes the Skilled Worker visa as an active route for an eligible job with an approved employer, a certificate of sponsorship, and the applicable salary requirement.",
    "zh-Hans": "GOV.UK 将技术工人签证描述为面向合格职业的有效途径，要求有获批雇主、担保证书以及适用的薪资条件。"
  },
  "summary_md": {
    "en": "A UK work and residence route for an eligible job with an approved employer, a certificate of sponsorship, the required salary, and English-language ability. GOV.UK says the visa can last up to five years and may support settlement after five years when the other conditions are met.",
    "zh-Hans": "面向英国合格职业的工作和居留途径，要求有获批雇主、担保证书、规定薪资和英语能力。GOV.UK 说明签证最长可达五年，满足其他条件时五年后可能支持定居。"
  },
  "good_for_md": {
    "en": "Applicants with a confirmed offer from an approved UK employer, an eligible occupation, the required salary, and the required English-language evidence.",
    "zh-Hans": "适合拥有获批英国雇主的确认工作机会、合格职业、规定薪资以及所需英语证明的申请人。"
  },
  "not_good_for_md": {
    "en": "Applicants without an approved sponsor, eligible occupation, confirmed job offer, or the applicable salary and English-language evidence.",
    "zh-Hans": "不适合没有获批担保雇主、合格职业、确认工作机会，或不满足适用薪资和英语证明要求的申请人。"
  },

  "official_names": {
    "en": "Student's Pass",
    "zh-Hans": "学生准证（Student’s Pass）"
  },
  "aliases": ["Singapore Student Pass", "STP Singapore"],
  "status": "active",
  "status_note_md": {
    "en": "ICA states that a foreigner accepted for full-time studies in Singapore generally needs a Student's Pass unless holding another qualifying pass. Procedures differ by institution type. Singapore has no dedicated digital-nomad visa in this record.",
    "zh-Hans": "ICA 说明获新加坡全日制课程录取的外国人一般需要学生准证，除非持有其他合资格准证。程序因院校类型而异。本记录不将新加坡描述为提供专门数字游民签证。"
  },
  "summary_md": {
    "en": "Singapore's main study immigration pass for foreigners accepted into an approved full-time course. Part-time, evening, or weekend courses are not eligible. Holders of some other long-term passes may study without a Student's Pass for non-religious full-time courses while that pass remains valid.",
    "zh-Hans": "面向获批准全日制课程录取外国人的新加坡主要学习准证。兼职、晚间或周末课程不符合资格。部分其他长期准证持有人在准证有效期内可无需学生准证就读非宗教全日制课程。"
  },
  "good_for_md": {
    "en": "Students accepted into an approved full-time Singapore course (IHL, private PEI, government school, etc. as listed by ICA) who need a dedicated study pass.",
    "zh-Hans": "适合获 ICA 所列批准全日制课程（高等院校、私立教育机构、政府学校等）录取并需要专门学习准证的学生。"
  },
  "not_good_for_md": {
    "en": "Part-time or weekend-only students, people seeking unrestricted work or a digital-nomad stay, or applicants without acceptance into an approved full-time course.",
    "zh-Hans": "不适合仅兼职或周末学习、寻求不受限制工作或数字游民停留，或未被批准全日制课程录取的申请人。"
  },

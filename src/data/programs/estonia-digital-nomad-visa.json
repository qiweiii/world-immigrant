    "income_location": "outside_destination",
    "proof_history_months": 6,
    "stability_requirement_md": {
      "en": "The FAQ states that applicants must evidence income during the six months before application and meet the monthly gross threshold."
    }
  },
  "timeline": {
    "application_processing_time_md": {
      "en": "The e-Residency programme page says DNV processing can take up to 30 days. The FAQ distinguishes a C visa of up to 90 days from a D visa of up to 365 days."
    },

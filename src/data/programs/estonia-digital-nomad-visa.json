    "education": {
      "required_level": "none",
      "credential_assessment_required": "not_applicable",
      "note_md": {
        "en": "Applicants must work location-independently and fit a foreign-employer, foreign-company, or mostly-foreign-client freelancer category. Standard visa rules also apply."
      }
    },

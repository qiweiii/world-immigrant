  "category_ids": ["digital_nomad"],
  "official_names": {
    "en": "Digital Nomad Visa"
  },
  "aliases": ["Estonia Digital Nomad Visa", "Estonia DNV"],
  "status": "active",
  "status_note_md": {
    "en": "The Digital Nomad Visa is a temporary stay visa, separate from e-Residency, and does not create a permanent-residence or citizenship route."
  },
  "summary_md": {
    "en": "A temporary Estonian visa for location-independent workers working for a foreign employer, a foreign company, or mostly foreign clients, with a maximum D-visa stay of up to one year."
  },
  "good_for_md": {
    "en": "Remote employees, foreign-company owners, and freelancers with mostly foreign clients who can prove location-independent work and the required income history."
  },
  "not_good_for_md": {
    "en": "Applicants seeking Estonian residence, permanent residence, citizenship, local employment, or an e-Residency substitute."
  },
  "pathway_mechanism": "remote_income",
  "eligibility": {

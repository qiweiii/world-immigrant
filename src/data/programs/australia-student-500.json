  "status_note_md": {
    "en": "The Australian Department of Home Affairs lists subclass 500 as the Student visa. The official page was last updated 1 July 2026.",
    "zh-Hans": "澳大利亚内政部将 500 子类列为学生签证。官方页面最后更新于 2026 年 7 月 1 日。"
  },
  "summary_md": {
    "en": "Australia's principal student visa for international students enrolled in an eligible Australian course. The public Home Affairs page is dynamic, so detailed requirements are kept conservative until each requirement page is captured.",
    "zh-Hans": "澳大利亚面向就读合资格课程的国际学生的主要学生签证。由于内政部公开页面为动态页面，在逐项获取要求页面之前，详细要求保持保守。"
  },
  "good_for_md": {
    "en": "International students with an eligible course enrolment and the evidence required by Home Affairs for the Student visa.",
    "zh-Hans": "拥有合资格课程入学资格，并能够提供内政部要求的学生签证证据的国际学生。"
  },
  "not_good_for_md": {
    "en": "Applicants seeking unrestricted employment, independent skilled migration, or a digital-nomad route. Australia does not have a dedicated digital-nomad visa in this record.",
    "zh-Hans": "不适合寻求不受限制就业、独立技术移民或数字游民途径的申请人。本记录不将澳大利亚签证误称为专门的数字游民签证。"
  },

  "official_names": {
    "en": "Golden Residence — real estate investor"
  },
  "aliases": ["UAE Golden Visa Property Investor", "UAE Golden Residency Real Estate Investor"],
  "status": "active",
  "status_note_md": {
    "en": "This fixture uses the Dubai GDRFA Golden Investor service for its real-estate stream; the federal ICP overview remains supplementary because its deterministic snapshot is incomplete."
  },
  "summary_md": {
    "en": "A ten-year Golden Residence route for a UAE real-estate investor who owns property or properties with a total value of at least AED 2 million and maintains the investment conditions."
  },
  "good_for_md": {
    "en": "Applicants with a documented UAE property investment of at least AED 2 million who can provide Dubai Land Department valuation/ownership evidence and accept the ten-year investment hold conditions."
  },
  "not_good_for_md": {
    "en": "Applicants seeking a low-capital property route, a guaranteed permanent-residence outcome, or a general residence status without maintaining the qualifying property investment."
  },

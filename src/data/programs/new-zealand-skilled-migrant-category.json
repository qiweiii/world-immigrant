{
  "id": "new-zealand-skilled-migrant-category",
  "country_id": "new-zealand",
  "category_ids": ["skilled_worker"],
  "official_names": {
    "en": "Skilled Migrant Category Resident Visa"
  },
  "aliases": ["New Zealand SMC Resident Visa"],
  "status": "active",
  "status_note_md": {
    "en": "This is New Zealand residence rather than a temporary work visa. It requires an expression of interest and invitation to apply under the Skilled Migrant Category rules."
  },
  "summary_md": {
    "en": "A New Zealand resident visa for applicants aged 55 or younger with an accredited-employer skilled job or offer, six skilled-resident points, English, and the other residence requirements."
  },
  "good_for_md": {
    "en": "Skilled workers already in, or holding an offer of, qualifying accredited-employer work who can claim six points through occupation registration, qualification or income, and New Zealand skilled work experience."
  },
  "not_good_for_md": {
    "en": "Applicants without a qualifying skilled job or offer, six points, English, or the health and character requirements for residence."
  },
  "pathway_mechanism": "points_invitation",
  "eligibility": {
    "age": {
      "max": 55
    },
    "education": {
      "required_level": "unknown",
      "credential_assessment_required": "unknown"
    },
    "work_experience": {
      "note_md": {
        "en": "Up to three additional points can be claimed from skilled work experience in New Zealand; the exact points combination depends on the applicant profile."
      }
    },
    "language": [
      {
        "language": "English",
        "note_md": {
          "en": "The applicant must speak and understand English."
        }
      }
    ],
    "health_check_required": true,
    "police_certificate_required": true,
    "points_based": true,
    "points_threshold": 6,
    "job_offer_required": true,
    "sponsor_required": true
  },
  "funds": {
    "proof_of_funds": [],
    "application_fees": [
      {
        "label": {
          "en": "Resident visa application fee from"
        },
        "amount": 6450,
        "currency": "NZD",
        "applies_to": "primary"
      }
    ]
  },
  "income": {
    "required": true,
    "accepted_sources": ["employment"],
    "income_location": "inside_destination",
    "proof_history_months": "unknown",
    "stability_requirement_md": {
      "en": "The job or offer must meet the skilled-job rules, including hours, duration, occupation level, and applicable wage conditions. The retained page does not reduce this to one universal income amount."
    }
  },
  "timeline": {
    "application_processing_time_md": {
      "en": "The visa lets the holder stay indefinitely. The application requires an expression of interest and invitation to apply."
    },
    "initial_validity_months": "unknown",
    "renewable": false,
    "max_stay_months": "unknown"
  },
  "rights": {
    "work_allowed": true,

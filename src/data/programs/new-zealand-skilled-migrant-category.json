    "children_allowed": true,
    "max_child_age": 24,
    "spouse_work_allowed": true,
    "dependent_parents_allowed": false,
    "note_md": {
      "en": "The SMC page allows inclusion of a partner and dependent children aged 24 or younger in the application."
    }
  },
  "pr_pathway": {
    "available": true,
    "min_residence_years": 2,
    "summary_md": {
      "en": "After holding the resident visa for two years in a row, the holder can apply for a Permanent Resident Visa that permits indefinite travel in and out of New Zealand."
    }
  },
  "citizenship_pathway": {

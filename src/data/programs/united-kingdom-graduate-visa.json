{
  "id": "united-kingdom-graduate-visa",
  "country_id": "united-kingdom",
  "category_ids": ["study_to_pr"],
  "official_names": {
    "en": "Graduate visa",
    "zh-Hans": "毕业签证（Graduate visa）"
  },
  "aliases": ["UK Graduate visa", "Graduate route"],
  "status": "active",
  "status_note_md": {
    "en": "GOV.UK describes the Graduate visa as an active post-study route. Duration depends on when you apply: 2 years if you apply on or before 31 December 2026, or 18 months if you apply on or after 1 January 2027, with 3 years for PhD or other doctoral qualifications.",
    "zh-Hans": "GOV.UK 将毕业签证描述为现行的毕业后停留途径。时长取决于申请时间：2026 年 12 月 31 日或之前申请为 2 年；2027 年 1 月 1 日或之后申请为 18 个月；博士或其他博士级资格为 3 年。"
  },
  "summary_md": {
    "en": "A temporary UK post-study work route for people already in the UK on a Student or Tier 4 (General) visa who successfully complete an eligible UK course. It is not extendable, but GOV.UK says you may later switch to another visa such as Skilled Worker.",
    "zh-Hans": "面向已在英国持学生或 Tier 4（普通）签证、并成功完成合资格英国课程者的临时毕业后工作途径。不可延期，但 GOV.UK 说明之后可能转换至技术工人等其他签证。"
  },
  "good_for_md": {
    "en": "Students in the UK whose education provider has told the Home Office they successfully completed an eligible bachelor’s, postgraduate, or other qualifying course, and who apply before their Student or Tier 4 visa expires.",
    "zh-Hans": "适合仍在英国、教育机构已告知内政部其成功完成合资格学士、研究生或其他合格课程，并在学生或 Tier 4 签证到期前申请的申请人。"
  },
  "not_good_for_md": {
    "en": "Applicants outside the UK, people without a qualifying Student or Tier 4 history, those seeking to extend a Graduate visa, or people looking for a digital-nomad visa unrelated to UK study.",
    "zh-Hans": "不适合身在英国境外、没有合资格学生或 Tier 4 经历、希望延期毕业签证，或寻求与英国学习无关的数字游民签证的申请人。"
  },
  "pathway_mechanism": "other",

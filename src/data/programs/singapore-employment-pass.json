      "points_sensitive": true
    },
    "education": {
      "required_level": "unknown",
      "credential_assessment_required": "unknown",
      "note_md": {
        "en": "Degree-equivalent qualifications can contribute COMPASS points, but MOM states candidates without them may still pass through other criteria.",
        "zh-Hans": "同等学位的资格可以贡献 COMPASS 分数，但人力部表示，没有这些资格的候选人仍然可以通过其他标准。"
      }
    },

  "status": "active",
  "status_note_md": {
    "en": "Singapore MOM describes a two-stage Employment Pass eligibility framework. Salary thresholds and COMPASS rules are time-sensitive and remain flagged for human review."
  },
  "summary_md": {
    "en": "An employer-sponsored Singapore work pass for foreign professionals, managers, and executives with a job offer in Singapore who meet the qualifying-salary and, unless exempted, COMPASS requirements."
  },
  "good_for_md": {
    "en": "Candidates with a Singapore job offer, an employer or appointed employment agent able to apply, and a fixed monthly salary meeting the age- and sector-sensitive qualifying threshold."
  },
  "not_good_for_md": {
    "en": "Applicants without a Singapore job offer or employer application route. The retained sources do not establish a universal degree, family, remote-work, or permanent-residence outcome."
  },
  "pathway_mechanism": "employer_sponsored",

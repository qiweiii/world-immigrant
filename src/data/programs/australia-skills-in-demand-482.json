  "category_ids": ["skilled_worker"],
  "official_names": {
    "en": "Skills in Demand visa (subclass 482) — Core Skills stream",
    "zh-Hans": "技能需求签证（482 子类）- 核心技能类别"
  },
  "aliases": ["SID 482", "Skills in Demand visa", "subclass 482 Core Skills stream"],
  "status": "active",
  "status_note_md": {
    "en": "The Core Skills stream is an active temporary skilled-employment route administered by the Australian Department of Home Affairs. Thresholds and stream rules can change.",
    "zh-Hans": "核心技能类别是由澳大利亚内政部管理的现行临时技术就业途径。门槛和类别规则可能变化。"
  },
  "summary_md": {
    "en": "An employer-sponsored temporary skilled visa for nominated workers in the Core Skills stream, where the employer is addressing a labour shortage and the nominated role meets the stream rules.",
    "zh-Hans": "面向核心技能类别获提名工人的雇主担保临时技术签证，适用于雇主应对劳动力短缺且提名职位符合类别规则的情况。"
  },
  "good_for_md": {
    "en": "Skilled workers with an Australian employer nomination, an eligible occupation and employment arrangement, sufficient English unless exempt, and a salary meeting the applicable threshold and market-salary rules.",
    "zh-Hans": "适合拥有澳大利亚雇主提名、合资格职业和雇佣安排，并且除非获豁免否则具备足够英语能力，且薪资满足适用门槛和市场薪资规则的技术工人。"
  },
  "not_good_for_md": {
    "en": "People seeking independent permanent residence, self-sponsored remote work, or work unrelated to a nominating employer and the approved occupation.",
    "zh-Hans": "不适合寻求独立永久居留、自我担保远程工作，或寻求与提名雇主及获批职业无关工作的人员。"
  },
  "pathway_mechanism": "employer_sponsored",

{
  "id": "australia-temporary-graduate-485",
  "country_id": "australia",
  "category_ids": ["study_to_pr"],
  "official_names": {
    "en": "Temporary Graduate visa (subclass 485)",
    "zh-Hans": "临时毕业生签证（485 子类）"
  },
  "aliases": ["Temporary Graduate visa", "subclass 485", "Temporary Graduate 485"],
  "status": "active",
  "status_note_md": {
    "en": "The Temporary Graduate visa is an active temporary post-study route with post-vocational and post-higher-education work streams.",
    "zh-Hans": "临时毕业生签证是现行的毕业后临时途径，包括职业教育毕业后工作类别和高等教育毕业后工作类别。"
  },
  "summary_md": {
    "en": "A temporary visa allowing eligible international graduates to live, study and work in Australia after completing qualifying Australian study. The official page describes separate post-vocational and post-higher-education streams.",
    "zh-Hans": "允许合资格国际毕业生在完成符合条件的澳大利亚学习后在澳大利亚居住、学习和工作的临时签证。官方页面描述了职业教育毕业后和高等教育毕业后两个类别。"
  },
  "good_for_md": {
    "en": "Recent international graduates who held a Student visa, completed a recent qualification in a CRICOS-registered course, and fit one of the available streams.",
    "zh-Hans": "持有学生签证、在 CRICOS 注册课程中近期完成学历，并符合可用类别之一的国际毕业生。"
  },
  "not_good_for_md": {
    "en": "Applicants without recent eligible Australian study, people seeking direct permanent residence, or applicants who need to change streams after lodging.",
    "zh-Hans": "没有近期合资格澳大利亚学习经历、寻求直接永久居留，或需要在递交后更换类别的申请人。"
  },
  "pathway_mechanism": "other",
  "eligibility": {
    "age": {
      "max": 35,
      "note_md": {
        "en": "Applicants generally must be aged 35 or under when applying; exceptions apply.",
        "zh-Hans": "申请时通常必须年满 35 岁或以下；存在例外。"
      }
    },
    "education": {
      "required_level": "unknown",
      "credential_assessment_required": false,
      "note_md": {
        "en": "The stream depends on the type of recent qualification: an associate degree, diploma or trade qualification for the post-vocational stream, or a degree-level qualification or higher for the post-higher-education stream.",
        "zh-Hans": "类别取决于近期学历类型：职业教育毕业后类别要求副学士、文凭或行业资格；高等教育毕业后类别要求学位或更高学历。"
      }
    },

  "status": "active",
  "status_note_md": {
    "en": "e-Residency is a digital identity and business-access status, not a residence permit, visa, citizenship status, or travel right."
  },
  "summary_md": {
    "en": "A Republic of Estonia digital identity that lets global entrepreneurs authenticate online, sign documents, and establish or manage an Estonian company remotely; it does not grant residence or travel rights."
  },
  "good_for_md": {
    "en": "Location-independent founders and operators who need secure digital access to Estonian e-services and want to establish or run a company online without relocating to Estonia."
  },
  "not_good_for_md": {
    "en": "Anyone seeking a visa, physical residence, work authorization, citizenship, or travel rights in Estonia or the European Union."
  },

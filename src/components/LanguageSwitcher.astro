---
import CustomDropdown from "./CustomDropdown.astro";
import {
  localeLabels,
  locales,
  type Locale,
  withLocale,
  stripLocalePrefix,
  LOCALE_STORAGE_KEY,
  t,
} from "../i18n";

interface Props {
  locale: Locale;
  pathname: string;
}

const { locale, pathname } = Astro.props;
const barePath = stripLocalePrefix(pathname);
const routes = Object.fromEntries(
  locales.map((item) => [item, withLocale(barePath, item)]),
) as Record<Locale, string>;
const localeOptions = locales.map((item) => ({
  value: item,
  label: localeLabels[item].short,
  selected: item === locale,
}));
---

<div class="locale-switcher" data-locale-switcher data-locale-routes={JSON.stringify(routes)}>
  <CustomDropdown
    id="locale-select"
    name="locale"
    label={t("nav.language", locale)}
    options={localeOptions}
  />
</div>

<script define:vars={{ storageKey: LOCALE_STORAGE_KEY }}>
  document.querySelectorAll("[data-locale-switcher]").forEach((root) => {
    if (root.dataset.bound === "1") return;
    root.dataset.bound = "1";

    const nativeSelect = root.querySelector("select.dropdown-native");
    if (!nativeSelect) return;

    nativeSelect.addEventListener("change", () => {
      const next = nativeSelect.value;
      if (!next) return;
      try {
        localStorage.setItem(storageKey, next);
      } catch {
        /* ignore private-mode storage errors */
      }

      let routes = {};
      try {
        routes = JSON.parse(root.dataset.localeRoutes || "{}");
      } catch {
        routes = {};
      }
      const href = routes[next];
      if (typeof href === "string" && href.length > 0) {
        window.location.assign(href);
      }
    });
  });
</script>
---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "World Immigrant",
  description = "Source-cited global immigration pathway comparison.",
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title}</title>
    <script is:inline>
      const saved = localStorage.getItem("theme");
      if (saved) document.documentElement.dataset.theme = saved;
      else if (window.matchMedia("(prefers-color-scheme: dark)").matches)
        document.documentElement.dataset.theme = "dark";
    </script>
  </head>
  <body>
    <header class="appbar">
      <div class="appbar-inner">
        <a class="brand" href="/">
          <span class="brand-dot" aria-hidden="true"></span>
          <span>World Immigrant</span>
        </a>
        <nav class="nav-links" aria-label="Primary">
          <a href="/countries">Countries</a>
          <a href="/compare">Compare</a>
          <a href="/filter">Filter</a>
          <a href="/sources">Sources</a>
        </nav>
        <div style="display:flex;align-items:center;gap:6px;">
          <a class="nav-icon" href="https://github.com/qiweiii/world-immigrant" target="_blank" rel="noopener" aria-label="GitHub">
            <img class="icon" src="https://cdn.simpleicons.org/github/71717a" alt="GitHub" width="18" height="18" style="width:18px;height:18px;" />
          </a>
          <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
            <svg id="icon-sun" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" style="display:none;"><circle cx="12" cy="12" r="5"/><line x1="12" y1="1" x2="12" y2="3"/><line x1="12" y1="21" x2="12" y2="23"/><line x1="4.22" y1="4.22" x2="5.64" y2="5.64"/><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"/><line x1="1" y1="12" x2="3" y2="12"/><line x1="21" y1="12" x2="23" y2="12"/><line x1="4.22" y1="19.78" x2="5.64" y2="18.36"/><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"/></svg>
            <svg id="icon-moon" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/></svg>
          </button>
        </div>
      </div>
    </header>

    <div style="height:56px;"></div>
    <slot />

    <footer class="footer">
      <div class="footer-inner">
        <div class="footer-grid">
          <div class="footer-col">
            <div class="brand" style="margin-bottom:10px;">
              <span class="brand-dot" aria-hidden="true"></span>
              <span>World Immigrant</span>
            </div>
            <p>Source-cited, multilingual, AI-readable immigration pathway database. A public good for multi-destination mobility in a changing world.</p>
          </div>
          <div class="footer-col">
            <h4>Navigate</h4>
            <ul>
              <li><a href="/countries">Countries</a></li>
              <li><a href="/compare">Compare</a></li>
              <li><a href="/filter">Filter</a></li>
              <li><a href="/sources">Sources</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>Project</h4>
            <ul>
              <li><a href="https://github.com/qiweiii/world-immigrant">GitHub</a></li>
              <li><a href="https://github.com/qiweiii/world-immigrant/issues">Report a mismatch / issue</a></li>
              <li><a href="/sources">Source registry</a></li>
              <li><a href="https://world-immigrant.com">world-immigrant.com</a></li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <span>MIT License. Not legal advice. Verify official sources before acting.</span>
          <span style="font-family:var(--font-mono);font-size:12px;">v0.1.0</span>
        </div>
      </div>
    </footer>

    <script>
      // Theme toggle
      const toggle = document.getElementById("theme-toggle");
      const sun = document.getElementById("icon-sun");
      const moon = document.getElementById("icon-moon");
      function updateIcons() {
        const dark = document.documentElement.dataset.theme === "dark";
        if (sun) sun.style.display = dark ? "" : "none";
        if (moon) moon.style.display = dark ? "none" : "";
      }
      updateIcons();
      toggle?.addEventListener("click", () => {
        const cur = document.documentElement.dataset.theme || "light";
        const next = cur === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = next;
        localStorage.setItem("theme", next);
        updateIcons();
      });

      // Scroll entry
      const obs = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add("enter");
              obs.unobserve(e.target);
            }
          }
        },
        { threshold: 0.06, rootMargin: "0px 0px -40px 0px" }
      );
      document.querySelectorAll("section, .card, .panel").forEach((el) => obs.observe(el));
      document.querySelectorAll(".grid").forEach((grid) => {
        [...grid.children].forEach((c, i) => c.style.setProperty("--si", i));
      });
    </script>
  </body>
</html>
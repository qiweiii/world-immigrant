---
import "../styles/global.css";
import LanguageSwitcher from "./LanguageSwitcher.astro";
import {
  defaultLocale,
  localeHtmlLang,
  type Locale,
  t,
  withLocale,
  alternateLocalePaths,
  LOCALE_STORAGE_KEY,
} from "../i18n";

interface Props {
  title?: string;
  description?: string;
  locale?: Locale;
}

const {
  title = "World Immigrant",
  description = "Source-cited global immigration pathway comparison.",
  locale = defaultLocale,
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://world-immigrant.com");
const pathname = Astro.url.pathname;
const canonicalUrl = new URL(pathname, siteUrl).href;
const socialImageUrl = new URL("/og.png", siteUrl).href;
const alternates = alternateLocalePaths(pathname);
const homeHref = withLocale("/", locale);
const countriesHref = withLocale("/countries", locale);
const categoriesHref = withLocale("/categories", locale);
const compareHref = withLocale("/compare", locale);
const filterHref = withLocale("/filter", locale);
const sourcesHref = withLocale("/sources", locale);
const htmlLang = localeHtmlLang[locale];

// Determine which nav section is active based on the current path
const isActive = (href: string) => {
  const cleanPath = pathname.replace(/\/$/, "") || "/";
  const cleanHref = href.replace(/\/$/, "") || "/";
  if (cleanHref === cleanPath) return true;
  return cleanPath.startsWith(cleanHref + "/");
};
const navItems = [
  { href: categoriesHref, key: "nav.categories" },
  { href: countriesHref, key: "nav.countries" },
  { href: compareHref, key: "nav.compare" },
  { href: filterHref, key: "nav.filter" },
  { href: sourcesHref, key: "nav.sources" },
];
---

<!doctype html>
<html lang={htmlLang} data-theme="light" data-locale={locale}>
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0e0f14" />
    <link rel="icon" href="/favicon.png?v=2" type="image/png" sizes="192x192" />
    <link rel="apple-touch-icon" href="/favicon.png?v=2" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="canonical" href={canonicalUrl} />
    {
      Object.entries(alternates).map(([hreflang, href]) => (
        <link rel="alternate" hreflang={hreflang} href={new URL(href, siteUrl).href} />
      ))
    }
    <link rel="alternate" hreflang="x-default" href={new URL(alternates.en, siteUrl).href} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="World Immigrant" />
    <meta property="og:locale" content={htmlLang.replace("-", "_")} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="World Immigrant — source-cited immigration pathways" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <title>{title}</title>
    <script is:inline define:vars={{ storageKey: LOCALE_STORAGE_KEY, pageLocale: locale, alternates }}>
      const savedTheme = localStorage.getItem("theme");
      if (savedTheme) document.documentElement.dataset.theme = savedTheme;
      else if (window.matchMedia("(prefers-color-scheme: dark)").matches)
        document.documentElement.dataset.theme = "dark";

      // Respect an explicit user language choice across visits.
      try {
        const savedLocale = localStorage.getItem(storageKey);
        const path = window.location.pathname;
        const search = window.location.search;
        if (savedLocale && savedLocale !== pageLocale && alternates[savedLocale]) {
          window.location.replace(alternates[savedLocale] + search);
        } else if (!savedLocale && path === "/") {
          const browser = navigator.language || (navigator.languages && navigator.languages[0]) || "";
          const lower = String(browser).toLowerCase();
          let matched = null;
          if (lower === "zh-hans" || lower === "zh-cn" || lower === "zh-sg" || lower === "zh" || lower.startsWith("zh-")) {
            // Prefer Hans for generic zh; Hant regions stay on English until explicit switch.
            if (!(lower === "zh-hant" || lower === "zh-tw" || lower === "zh-hk" || lower === "zh-mo")) {
              matched = "zh-Hans";
            }
          }
          if (matched && alternates[matched] && matched !== pageLocale) {
            localStorage.setItem(storageKey, matched);
            window.location.replace(alternates[matched] + search);
          }
        }
      } catch {
        /* ignore private-mode storage errors */
      }
    </script>
  </head>
  <body>
    <header class="appbar">
      <div class="appbar-inner">
        <a class="wordmark" href={homeHref} aria-label={t("nav.home", locale)}>
          <span class="wordmark-mark" aria-hidden="true"></span>
        </a>
        <nav class="nav-links" aria-label={t("nav.primary", locale)}>
          {
            navItems.map((item) => (
              <a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>
                {t(item.key as any, locale)}
              </a>
            ))
          }
        </nav>
        <div class="appbar-actions" role="group" aria-label={t("nav.controls", locale)}>
          <LanguageSwitcher locale={locale} pathname={pathname} />
          <button class="theme-toggle" id="theme-toggle" aria-label={t("nav.theme", locale)}>
            <svg
              id="icon-sun"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              style="display:none;"
              ><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"
              ></line><line x1="12" y1="21" x2="12" y2="23"></line><line
                x1="4.22"
                y1="4.22"
                x2="5.64"
                y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line
                x1="1"
                y1="12"
                x2="3"
                y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line
                x1="4.22"
                y1="19.78"
                x2="5.64"
                y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg
            >
            <svg
              id="icon-moon"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg
            >
          </button>
          <a
            class="nav-icon"
            href="https://github.com/qiweiii/world-immigrant"
            target="_blank"
            rel="noopener"
            aria-label={t("nav.github", locale)}
          >
            <img
              class="icon"
              src="https://cdn.simpleicons.org/github/71717a"
              alt=""
              width="18"
              height="18"
              style="width:18px;height:18px;"
            />
          </a>
        </div>
        <details class="mobile-nav">
          <summary aria-label={t("nav.open", locale)}>
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16" /></svg>
          </summary>
          <nav aria-label={t("nav.mobile", locale)}>
            {
              navItems.map((item) => (
                <a href={item.href} aria-current={isActive(item.href) ? "page" : undefined}>
                  {t(item.key as any, locale)}
                </a>
              ))
            }
            <div class="mobile-nav-divider"></div>
            <div class="mobile-locale">
              <LanguageSwitcher locale={locale} pathname={pathname} />
            </div>
            <a href="https://github.com/qiweiii/world-immigrant" target="_blank" rel="noopener"
              >{t("nav.github", locale)}</a
            >
            <button class="mobile-nav-theme" id="mobile-theme-toggle" aria-label={t("nav.theme", locale)}>
              <span id="mobile-theme-label">{t("nav.theme.dark", locale)}</span>
            </button>
          </nav>
        </details>
      </div>
    </header>

    <div class="appbar-spacer"></div>
    <slot />

    <footer class="footer">
      <div class="footer-inner">
        <div class="footer-grid">
          <div class="footer-col">
            <a class="wordmark wordmark-footer" href={homeHref} aria-label={t("nav.home", locale)}>
              <span class="wordmark-mark" aria-hidden="true"></span>
            </a>
            <p>{t("footer.tagline", locale)}</p>
          </div>
          <div class="footer-col">
            <h4>{t("footer.browse", locale)}</h4>
            <ul>
              <li><a href={countriesHref}>{t("nav.countries", locale)}</a></li>
              <li><a href={categoriesHref}>{t("nav.categories", locale)}</a></li>
              <li><a href={compareHref}>{t("footer.compare", locale)}</a></li>
              <li><a href={filterHref}>{t("footer.filter", locale)}</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>{t("footer.trust", locale)}</h4>
            <ul>
              <li><a href={sourcesHref}>{t("footer.sources", locale)}</a></li>
              <li>
                <a href="https://github.com/qiweiii/world-immigrant">{t("nav.github", locale)}</a>
              </li>
              <li>
                <a href="https://github.com/qiweiii/world-immigrant/issues">{t("footer.report", locale)}</a>
              </li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <span>{t("footer.legal", locale)}</span>
          <span style="font-family:var(--font-mono);font-size:12px;">v0.1.0</span>
        </div>
      </div>
    </footer>

    <script define:vars={{ darkLabel: t("nav.theme.dark", locale), lightLabel: t("nav.theme.light", locale) }}>
      const toggle = document.getElementById("theme-toggle");
      const sun = document.getElementById("icon-sun");
      const moon = document.getElementById("icon-moon");
      const mobileToggle = document.getElementById("mobile-theme-toggle");
      const mobileLabel = document.getElementById("mobile-theme-label");

      function isDark() {
        return document.documentElement.dataset.theme === "dark";
      }

      function updateIcons() {
        const dark = isDark();
        if (sun) sun.style.display = dark ? "" : "none";
        if (moon) moon.style.display = dark ? "none" : "";
        if (mobileLabel) mobileLabel.textContent = dark ? lightLabel : darkLabel;
      }

      function switchTheme() {
        const next = isDark() ? "light" : "dark";
        document.documentElement.dataset.theme = next;
        localStorage.setItem("theme", next);
        updateIcons();
      }

      updateIcons();
      toggle?.addEventListener("click", switchTheme);
      mobileToggle?.addEventListener("click", switchTheme);

      const obs = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add("enter");
              obs.unobserve(e.target);
            }
          }
        },
        { threshold: 0.06, rootMargin: "0px 0px -40px 0px" },
      );
      document.querySelectorAll("section, .card, .panel").forEach((el) => obs.observe(el));
      document.querySelectorAll(".grid, .card-grid").forEach((grid) => {
        [...grid.children].forEach((c, i) => c.style.setProperty("--si", String(i)));
      });

      document.querySelectorAll(".mobile-nav nav a").forEach((a) => {
        a.addEventListener("click", () => {
          document.querySelector(".mobile-nav")?.removeAttribute("open");
        });
      });
    </script>
  </body>
</html>

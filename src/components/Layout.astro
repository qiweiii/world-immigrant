---
import "../styles/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "World Immigrant",
  description = "Source-cited global immigration pathway comparison.",
} = Astro.props;

const siteUrl = Astro.site ?? new URL("https://world-immigrant.com");
const canonicalUrl = new URL(Astro.url.pathname, siteUrl).href;
const socialImageUrl = new URL("/og.png", siteUrl).href;
---

<!doctype html>
<html lang="en" data-theme="light">
  <head>
    <meta charset="UTF-8" />
    <meta name="description" content={description} />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="theme-color" content="#0e0f14" />
    <link rel="icon" href="/favicon.png?v=2" type="image/png" sizes="192x192" />
    <link rel="apple-touch-icon" href="/favicon.png?v=2" />
    <link rel="manifest" href="/site.webmanifest" />
    <link rel="canonical" href={canonicalUrl} />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="World Immigrant" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:image:alt" content="World Immigrant — source-cited immigration pathways" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <title>{title}</title>
    <script is:inline>
      const saved = localStorage.getItem("theme");
      if (saved) document.documentElement.dataset.theme = saved;
      else if (window.matchMedia("(prefers-color-scheme: dark)").matches)
        document.documentElement.dataset.theme = "dark";
    </script>
  </head>
  <body>
    <header class="appbar">
      <div class="appbar-inner">
        <a class="wordmark" href="/" aria-label="World Immigrant home">
          <span class="wordmark-mark" aria-hidden="true"></span>
        </a>
        <nav class="nav-links" aria-label="Primary">
          <a href="/countries">Countries</a>
          <a href="/categories">Categories</a>
          <a href="/compare">Compare</a>
          <a href="/filter">Filter</a>
          <a href="/sources">Sources</a>
        </nav>
        <details class="mobile-nav">
          <summary aria-label="Open navigation">
            <svg viewBox="0 0 24 24" aria-hidden="true"><path d="M4 7h16M4 12h16M4 17h16" /></svg>
          </summary>
          <nav aria-label="Mobile primary navigation">
            <a href="/countries">Countries</a>
            <a href="/categories">Categories</a>
            <a href="/compare">Compare pathways</a>
            <a href="/filter">Check fit</a>
            <a href="/sources">Source registry</a>
          </nav>
        </details>
        <div class="appbar-actions">
          <a
            class="nav-icon"
            href="https://github.com/qiweiii/world-immigrant"
            target="_blank"
            rel="noopener"
            aria-label="GitHub"
          >
            <img
              class="icon"
              src="https://cdn.simpleicons.org/github/71717a"
              alt=""
              width="18"
              height="18"
              style="width:18px;height:18px;"
            />
          </a>
          <button class="theme-toggle" id="theme-toggle" aria-label="Toggle theme">
            <svg
              id="icon-sun"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              style="display:none;"
              ><circle cx="12" cy="12" r="5"></circle><line x1="12" y1="1" x2="12" y2="3"
              ></line><line x1="12" y1="21" x2="12" y2="23"></line><line
                x1="4.22"
                y1="4.22"
                x2="5.64"
                y2="5.64"></line><line x1="18.36" y1="18.36" x2="19.78" y2="19.78"></line><line
                x1="1"
                y1="12"
                x2="3"
                y2="12"></line><line x1="21" y1="12" x2="23" y2="12"></line><line
                x1="4.22"
                y1="19.78"
                x2="5.64"
                y2="18.36"></line><line x1="18.36" y1="5.64" x2="19.78" y2="4.22"></line></svg
            >
            <svg
              id="icon-moon"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              ><path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"></path></svg
            >
          </button>
        </div>
      </div>
    </header>

    <div class="appbar-spacer"></div>
    <slot />

    <footer class="footer">
      <div class="footer-inner">
        <div class="footer-grid">
          <div class="footer-col">
            <a class="wordmark wordmark-footer" href="/" aria-label="World Immigrant home">
              <span class="wordmark-mark" aria-hidden="true"></span>
            </a>
            <p>
              Source-cited immigration pathway information. Local-first filtering. Not legal advice.
            </p>
          </div>
          <div class="footer-col">
            <h4>Browse</h4>
            <ul>
              <li><a href="/countries">Countries</a></li>
              <li><a href="/categories">Categories</a></li>
              <li><a href="/compare">Compare</a></li>
              <li><a href="/filter">Filter</a></li>
            </ul>
          </div>
          <div class="footer-col">
            <h4>Trust</h4>
            <ul>
              <li><a href="/sources">Source registry</a></li>
              <li><a href="https://github.com/qiweiii/world-immigrant">GitHub</a></li>
              <li>
                <a href="https://github.com/qiweiii/world-immigrant/issues">Report a mismatch</a>
              </li>
            </ul>
          </div>
        </div>
        <div class="footer-bottom">
          <span>MIT License. Verify official sources before acting.</span>
          <span style="font-family:var(--font-mono);font-size:12px;">v0.1.0</span>
        </div>
      </div>
    </footer>

    <script>
      const toggle = document.getElementById("theme-toggle");
      const sun = document.getElementById("icon-sun");
      const moon = document.getElementById("icon-moon");
      function updateIcons() {
        const dark = document.documentElement.dataset.theme === "dark";
        if (sun) sun.style.display = dark ? "" : "none";
        if (moon) moon.style.display = dark ? "none" : "";
      }
      updateIcons();
      toggle?.addEventListener("click", () => {
        const cur = document.documentElement.dataset.theme || "light";
        const next = cur === "dark" ? "light" : "dark";
        document.documentElement.dataset.theme = next;
        localStorage.setItem("theme", next);
        updateIcons();
      });

      const obs = new IntersectionObserver(
        (entries) => {
          for (const e of entries) {
            if (e.isIntersecting) {
              e.target.classList.add("enter");
              obs.unobserve(e.target);
            }
          }
        },
        { threshold: 0.06, rootMargin: "0px 0px -40px 0px" },
      );
      document.querySelectorAll("section, .card, .panel").forEach((el) => obs.observe(el));
      document.querySelectorAll(".grid, .card-grid").forEach((grid) => {
        [...grid.children].forEach((c, i) => c.style.setProperty("--si", String(i)));
      });
    </script>
  </body>
</html>

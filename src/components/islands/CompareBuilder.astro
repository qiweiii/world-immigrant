<section class="compare-shell" aria-labelledby="compare-heading" data-compare-builder>
  <div class="compare-intro">
    <p class="eyebrow">Compare</p>
    <h2 id="compare-heading">Choose pathways, then scan the table.</h2>
    <p class="compare-lede">Select up to three programs. Facts stay side by side with source IDs under each cell.</p>
  </div>

  <div class="compare-select-wrap">
    <table class="compare-select-table" aria-label="Programs">
      <thead>
        <tr>
          <th scope="col" class="compare-col-check">Select</th>
          <th scope="col">Program</th>
          <th scope="col">Country</th>
          <th scope="col">Status</th>
        </tr>
      </thead>
      <tbody data-program-options></tbody>
    </table>
  </div>

  <p class="compare-status" data-compare-status>Loading programs…</p>
  <div class="compare-result-wrap" data-compare-table></div>
</section>

<script>
  import { buildComparison } from "../../lib/compareEngine";

  type CompareIndex = Parameters<typeof buildComparison>[0];

  const root = document.querySelector<HTMLElement>("[data-compare-builder]");
  const options = root?.querySelector<HTMLElement>("[data-program-options]");
  const status = root?.querySelector<HTMLElement>("[data-compare-status]");
  const tableRoot = root?.querySelector<HTMLElement>("[data-compare-table]");
  let programs: CompareIndex = [];

  function selectedIds() {
    if (!options) return [];
    return [...options.querySelectorAll<HTMLInputElement>("input[type=checkbox]:checked")].map(
      ({ value }) => value,
    );
  }

  function setQuery(ids: string[]) {
    const url = new URL(window.location.href);
    if (ids.length) url.searchParams.set("programs", ids.join(","));
    else url.searchParams.delete("programs");
    history.replaceState(null, "", url);
  }

  function renderTable() {
    if (!tableRoot || !status) return;
    tableRoot.replaceChildren();
    const ids = selectedIds();
    if (!ids.length) {
      status.textContent = "Select at least one program.";
      setQuery([]);
      return;
    }

    const view = buildComparison(programs, ids);
    status.textContent = `${ids.length} of 3 slots used.`;
    setQuery(ids);

    const table = document.createElement("table");
    table.className = "compare-matrix";
    const head = document.createElement("thead");
    const headRow = document.createElement("tr");
    const fieldHead = document.createElement("th");
    fieldHead.scope = "col";
    fieldHead.textContent = "Field";
    fieldHead.className = "compare-sticky";
    headRow.append(fieldHead);
    for (const column of view.columns) {
      const cell = document.createElement("th");
      cell.scope = "col";
      const link = document.createElement("a");
      link.href = `/programs/${column.id}`;
      link.textContent = column.title;
      cell.append(link);
      headRow.append(cell);
    }
    head.append(headRow);

    const body = document.createElement("tbody");
    for (const row of view.rows) {
      const rowElement = document.createElement("tr");
      const label = document.createElement("th");
      label.scope = "row";
      label.className = "compare-sticky";
      label.textContent = row.label;
      rowElement.append(label);
      for (const cell of row.cells) {
        const value = document.createElement("td");
        const text = document.createElement("div");
        text.className = "compare-cell-value";
        text.textContent = cell.display;
        value.append(text);
        if (cell.citations.length) {
          const evidence = document.createElement("div");
          evidence.className = "compare-cell-sources";
          evidence.textContent = cell.citations.join(" · ");
          value.append(evidence);
        }
        rowElement.append(value);
      }
      body.append(rowElement);
    }
    table.append(head, body);
    tableRoot.append(table);
  }

  async function init() {
    if (!root || !options || !status) return;
    try {
      const response = await fetch("/data/indexes/compare-index.v1.json");
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      const payload = (await response.json()) as { programs: CompareIndex };
      programs = payload.programs;
      const requested = [
        ...new Set(
          new URL(window.location.href).searchParams
            .get("programs")
            ?.split(",")
            .map((id) => id.trim())
            .filter(Boolean) ?? [],
        ),
      ].filter((id) => programs.some(({ program_id }) => program_id === id));
      const initial = requested.length
        ? requested.slice(0, 3)
        : programs.slice(0, 1).map(({ program_id }) => program_id);

      for (const program of programs) {
        const row = document.createElement("tr");
        const checkCell = document.createElement("td");
        checkCell.className = "compare-col-check";
        const label = document.createElement("label");
        label.className = "compare-check";
        const checkbox = document.createElement("input");
        checkbox.type = "checkbox";
        checkbox.value = program.program_id;
        checkbox.checked = initial.includes(program.program_id);
        checkbox.setAttribute("aria-label", `Select ${program.official_names.en}`);
        checkbox.addEventListener("change", () => {
          const selected = selectedIds();
          if (selected.length > 3) checkbox.checked = false;
          renderTable();
        });
        label.append(checkbox);
        checkCell.append(label);

        const nameCell = document.createElement("td");
        const name = document.createElement("div");
        name.className = "compare-program-name";
        name.textContent = program.official_names.en;
        nameCell.append(name);

        const countryCell = document.createElement("td");
        countryCell.textContent = program.country_id;

        const statusCell = document.createElement("td");
        statusCell.textContent = program.status;

        row.append(checkCell, nameCell, countryCell, statusCell);
        options.append(row);
      }
      renderTable();
    } catch (error) {
      status.textContent = `Compare data could not be loaded: ${error instanceof Error ? error.message : "unknown error"}`;
    }
  }

  void init();
</script>

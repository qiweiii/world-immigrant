---
import { defaultLocale, t, type Locale } from "../../i18n";
import CustomDropdown from "../CustomDropdown.astro";

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props as Props;
---
<section class="filter-shell" aria-labelledby="filter-heading" data-eligibility-filter data-locale={locale}>
  <div class="filter-intro">
    <p class="eyebrow">{t("filter.toolEyebrow", locale)}</p>
    <h2 id="filter-heading">{t("filter.toolHeading", locale)}</h2>
    <p class="filter-lede">{t("filter.toolLede", locale)}</p>
  </div>

  <form class="filter-form" data-profile-form>
    <div class="field-grid">
      <div class="field">
        <CustomDropdown
          id="goal"
          name="goal"
          label={t("filter.goal", locale)}
          options={[
            { value: "temporary_stay", label: t("filter.goal.temporary", locale) },
            { value: "permanent_residence", label: t("filter.goal.pr", locale), selected: true },
            { value: "citizenship", label: t("filter.goal.citizenship", locale) },
          ]}
        />
      </div>
      <div class="field">
        <label class="field-label" for="work-years">{t("filter.workYears", locale)}</label>
        <input class="input" id="work-years" name="skilled_work_years" value="3" inputmode="decimal" />
      </div>
      <div class="field">
        <CustomDropdown
          id="education"
          name="education_level"
          label={t("filter.education", locale)}
          options={[
            { value: "secondary", label: t("filter.education.secondary", locale) },
            { value: "vocational", label: t("filter.education.vocational", locale) },
            { value: "associate", label: t("filter.education.associate", locale) },
            { value: "bachelor", label: t("filter.education.bachelor", locale), selected: true },
            { value: "master", label: t("filter.education.master", locale) },
            { value: "doctorate", label: t("filter.education.doctorate", locale) },
          ]}
        />
      </div>
      <div class="field">
        <label class="field-label" for="program-points">{t("filter.programPoints", locale)}</label>
        <input class="input" id="program-points" name="program_selection_points" value="" inputmode="numeric" />
      </div>
      <div class="field">
        <label class="field-label" for="family-size">{t("filter.familySize", locale)}</label>
        <input class="input" id="family-size" name="family_size" value="1" inputmode="numeric" />
      </div>
    </div>

    <fieldset class="filter-flags">
      <legend class="field-label">{t("filter.additionalFacts", locale)}</legend>
      <div class="filter-flag-list">
        <label class="filter-flag">
          <input type="checkbox" name="has_approved_language_test" />
          <span>{t("filter.approvedLanguage", locale)}</span>
        </label>
        <label class="filter-flag">
          <input type="checkbox" name="foreign_education" />
          <span>{t("filter.foreignEducation", locale)}</span>
        </label>
        <label class="filter-flag">
          <input type="checkbox" name="authorized_to_work_in_country" />
          <span>{t("filter.authorizedWork", locale)}</span>
        </label>
        <label class="filter-flag">
          <input type="checkbox" name="valid_job_offer" />
          <span>{t("filter.validJobOffer", locale)}</span>
        </label>
      </div>
    </fieldset>
  </form>

  <p class="filter-status" data-filter-status>{t("filter.loading", locale)}</p>
  <div class="filter-results" data-filter-results></div>
</section>

<script>
  import { evaluatePrograms, type FilterResultStatus, type UserProfile } from "../../lib/filterEngine";
  import { defaultLocale, isLocale, pickLocalized, t, tf, withLocale } from "../../i18n";

  type FilterPrograms = Parameters<typeof evaluatePrograms>[0];

  const root = document.querySelector<HTMLElement>("[data-eligibility-filter]");
  const localeValue = root?.dataset.locale;
  const locale = isLocale(localeValue) ? localeValue : defaultLocale;
  const form = root?.querySelector<HTMLFormElement>("[data-profile-form]");
  const status = root?.querySelector<HTMLElement>("[data-filter-status]");
  const resultsRoot = root?.querySelector<HTMLElement>("[data-filter-results]");
  let programs: FilterPrograms = [];

  const statusLabels: Record<FilterResultStatus, string> = {
    likely_match: t("filter.status.likely", locale),
    possible_match: t("filter.status.possible", locale),
    not_match: t("filter.status.notMatch", locale),
    needs_review: t("filter.status.review", locale),
    unknown: t("filter.status.unknown", locale),
  };

  function optionalNumber(formData: FormData, key: string) {
    const raw = String(formData.get(key) ?? "").trim();
    if (!raw) return undefined;
    const value = Number(raw);
    return Number.isFinite(value) ? value : undefined;
  }

  function profileFromForm(): UserProfile | undefined {
    if (!form) return undefined;
    const data = new FormData(form);
    return {
      goal: String(data.get("goal")) as UserProfile["goal"],
      skilled_work_years: optionalNumber(data, "skilled_work_years"),
      has_approved_language_test: data.has("has_approved_language_test"),
      education_level: String(data.get("education_level")) as UserProfile["education_level"],
      foreign_education: data.has("foreign_education"),
      program_selection_points: optionalNumber(data, "program_selection_points"),
      family_size: optionalNumber(data, "family_size"),
      authorized_to_work_in_country: data.has("authorized_to_work_in_country"),
      valid_job_offer: data.has("valid_job_offer"),
    };
  }

  function render() {
    if (!status || !resultsRoot) return;
    const profile = profileFromForm();
    if (!profile) return;
    const results = evaluatePrograms(programs, profile, locale);
    status.textContent =
      results.length === 1
        ? t("filter.rankedOne", locale)
        : tf("filter.ranked", locale, { count: results.length });
    resultsRoot.replaceChildren();

    const groups = new Map<string, { countryName: string; results: typeof results }>();
    for (const result of results) {
      const program = programs.find(({ program_id }) => program_id === result.program_id);
      if (!program) continue;
      const countryName = pickLocalized(program.country_names, locale);
      const group = groups.get(program.country_id) ?? { countryName, results: [] };
      group.results.push(result);
      groups.set(program.country_id, group);
    }

    for (const group of groups.values()) {
      const countrySection = document.createElement("section");
      countrySection.className = "filter-country-group";
      const countryHeading = document.createElement("h3");
      countryHeading.className = "filter-country-heading";
      countryHeading.textContent = group.countryName;
      countrySection.append(countryHeading);

      for (const result of group.results) {
        const program = programs.find(({ program_id }) => program_id === result.program_id);
        if (!program) continue;

        const article = document.createElement("article");
        article.className = `filter-result filter-result--${result.status}`;

        const header = document.createElement("div");
        header.className = "filter-result-header";

        const badge = document.createElement("span");
        badge.className = `filter-result-badge filter-result-badge--${result.status}`;
        badge.textContent = statusLabels[result.status];

        const heading = document.createElement("h3");
        const link = document.createElement("a");
        link.href = withLocale(`/programs/${result.program_id}`, locale);
        link.textContent = `${pickLocalized(program.official_names, locale)} · ${group.countryName}`;
        heading.append(link);

        header.append(badge, heading);

        const positives = result.reasons.filter((reason) => reason.severity === "positive");
        const others = result.reasons.filter((reason) => reason.severity !== "positive");

        const body = document.createElement("div");
        body.className = "filter-result-body";

        if (positives.length) {
          const posBlock = document.createElement("div");
          posBlock.className = "filter-reason-group filter-reason-group--positive";
          const posTitle = document.createElement("p");
          posTitle.className = "filter-reason-heading";
          posTitle.textContent = t("filter.supporting", locale);
          posBlock.append(posTitle);
          const posList = document.createElement("ul");
          for (const reason of positives) {
            const item = document.createElement("li");
            item.className = "filter-reason filter-reason--positive";
            const msg = document.createElement("span");
            msg.textContent = reason.message;
            item.append(msg);
            if (reason.citations.length) {
              const src = document.createElement("span");
              src.className = "filter-reason-sources";
              const links = reason.citations.map((citation) => {
                const a = document.createElement("a");
                a.href = citation.url;
                a.target = "_blank";
                a.rel = "noopener";
                const label = citation.section || new URL(citation.url).hostname;
                a.textContent = label;
                return a;
              });
              for (let i = 0; i < links.length; i++) {
                if (i > 0) src.append(" · ");
                src.append(links[i]);
              }
              item.append(src);
            }
            posList.append(item);
          }
          posBlock.append(posList);
          body.append(posBlock);
        }

        if (others.length) {
          const otherBlock = document.createElement("div");
          otherBlock.className = "filter-reason-group";
          const otherTitle = document.createElement("p");
          otherTitle.className = "filter-reason-heading";
          otherTitle.textContent = t("filter.caveats", locale);
          otherBlock.append(otherTitle);
          const otherList = document.createElement("ul");
          for (const reason of others) {
            const item = document.createElement("li");
            item.className = `filter-reason filter-reason--${reason.severity}`;
            const msg = document.createElement("span");
            msg.textContent = reason.message;
            item.append(msg);
            if (reason.citations.length) {
              const src = document.createElement("span");
              src.className = "filter-reason-sources";
              const links = reason.citations.map((citation) => {
                const a = document.createElement("a");
                a.href = citation.url;
                a.target = "_blank";
                a.rel = "noopener";
                const label = citation.section || new URL(citation.url).hostname;
                a.textContent = label;
                return a;
              });
              for (let i = 0; i < links.length; i++) {
                if (i > 0) src.append(" · ");
                src.append(links[i]);
              }
              item.append(src);
            }
            otherList.append(item);
          }
          otherBlock.append(otherList);
          body.append(otherBlock);
        }

        article.append(header, body);
        countrySection.append(article);
      }
      resultsRoot.append(countrySection);
    }
  }

  async function init() {
    if (!status) return;
    try {
      const response = await fetch("/data/indexes/filter-index.v1.json");
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      const payload = (await response.json()) as { programs: FilterPrograms };
      programs = payload.programs;
      form?.addEventListener("input", render);
      render();
    } catch (error) {
      status.textContent = tf("filter.loadError", locale, {
        error: error instanceof Error ? error.message : t("filter.status.unknown", locale),
      });
    }
  }

  void init();
</script>

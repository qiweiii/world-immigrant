---
import { defaultLocale, t, type Locale } from "../../i18n";
import CustomDropdown from "../CustomDropdown.astro";

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props as Props;

const categories = [
  { id: "skilled_worker", label: t("filter.category.skilled", locale) },
  { id: "study_to_pr", label: t("filter.category.study", locale) },
  { id: "digital_nomad", label: t("filter.category.nomad", locale) },
  { id: "startup_entrepreneur", label: t("filter.category.startup", locale) },
  { id: "investor", label: t("filter.category.investor", locale) },
] as const;
---
<section class="filter-shell" aria-labelledby="filter-heading" data-eligibility-filter data-locale={locale}>
  <div class="filter-intro">
    <p class="eyebrow">{t("filter.toolEyebrow", locale)}</p>
    <h2 id="filter-heading">{t("filter.toolHeading", locale)}</h2>
    <p class="filter-lede">{t("filter.toolLede", locale)}</p>
  </div>

  <form class="filter-form" data-profile-form>
    <fieldset class="filter-section">
      <legend class="filter-section-title">{t("filter.section.goal", locale)}</legend>
      <div class="filter-chip-row" role="radiogroup" aria-label={t("filter.goal", locale)}>
        <label class="filter-chip">
          <input type="radio" name="goal" value="temporary_stay" />
          <span>{t("filter.goal.temporary", locale)}</span>
        </label>
        <label class="filter-chip">
          <input type="radio" name="goal" value="permanent_residence" checked />
          <span>{t("filter.goal.pr", locale)}</span>
        </label>
        <label class="filter-chip">
          <input type="radio" name="goal" value="citizenship" />
          <span>{t("filter.goal.citizenship", locale)}</span>
        </label>
      </div>
    </fieldset>

    <fieldset class="filter-section">
      <legend class="filter-section-title">{t("filter.section.paths", locale)}</legend>
      <p class="filter-section-hint">{t("filter.section.pathsHint", locale)}</p>
      <div class="filter-chip-row">
        {categories.map((category) => (
          <label class="filter-chip">
            <input type="checkbox" name="category_ids" value={category.id} />
            <span>{category.label}</span>
          </label>
        ))}
      </div>
    </fieldset>

    <fieldset class="filter-section">
      <legend class="filter-section-title">{t("filter.section.you", locale)}</legend>
      <div class="field-grid filter-field-grid">
        <CustomDropdown
          id="education"
          name="education_level"
          label={t("filter.education", locale)}
          options={[
            { value: "secondary", label: t("filter.education.secondary", locale) },
            { value: "vocational", label: t("filter.education.vocational", locale) },
            { value: "associate", label: t("filter.education.associate", locale) },
            { value: "bachelor", label: t("filter.education.bachelor", locale), selected: true },
            { value: "master", label: t("filter.education.master", locale) },
            { value: "doctorate", label: t("filter.education.doctorate", locale) },
          ]}
        />
        <div class="field">
          <label class="field-label" for="work-years">{t("filter.workYears", locale)}</label>
          <input class="input" id="work-years" name="skilled_work_years" value="" inputmode="decimal" placeholder="0" />
          <p class="field-hint">{t("filter.workYearsHint", locale)}</p>
        </div>
        <CustomDropdown
          id="job-offer"
          name="job_offer"
          label={t("filter.jobOffer", locale)}
          options={[
            { value: "unknown", label: t("filter.jobOffer.unknown", locale), selected: true },
            { value: "yes", label: t("filter.jobOffer.yes", locale) },
            { value: "no", label: t("filter.jobOffer.no", locale) },
          ]}
        />
      </div>
    </fieldset>

    <fieldset class="filter-section">
      <legend class="filter-section-title">{t("filter.section.money", locale)}</legend>
      <div class="field-grid filter-field-grid">
        <div class="field">
          <label class="field-label" for="family-size">{t("filter.familySize", locale)}</label>
          <input class="input" id="family-size" name="family_size" value="1" inputmode="numeric" min="1" />
        </div>
        <div class="field">
          <label class="field-label" for="savings">{t("filter.savings", locale)}</label>
          <input class="input" id="savings" name="liquid_funds_amount" value="" inputmode="decimal" placeholder="" />
          <p class="field-hint">{t("filter.savingsHint", locale)}</p>
        </div>
        <CustomDropdown
          id="currency"
          name="liquid_funds_currency"
          label={t("filter.currency", locale)}
          options={[
            { value: "USD", label: "USD", selected: true },
            { value: "CAD", label: "CAD" },
            { value: "EUR", label: "EUR" },
            { value: "GBP", label: "GBP" },
            { value: "AUD", label: "AUD" },
            { value: "SGD", label: "SGD" },
            { value: "MYR", label: "MYR" },
            { value: "AED", label: "AED" },
            { value: "JPY", label: "JPY" },
            { value: "NZD", label: "NZD" },
          ]}
        />
      </div>
    </fieldset>

    <details class="filter-advanced">
      <summary>{t("filter.additionalFacts", locale)}</summary>
      <div class="filter-flag-list">
        <label class="filter-flag">
          <input type="checkbox" name="has_approved_language_test" />
          <span>{t("filter.approvedLanguage", locale)}</span>
        </label>
        <label class="filter-flag">
          <input type="checkbox" name="foreign_education" />
          <span>{t("filter.foreignEducation", locale)}</span>
        </label>
        <label class="filter-flag">
          <input type="checkbox" name="authorized_to_work_in_country" />
          <span>{t("filter.authorizedWork", locale)}</span>
        </label>
      </div>
    </details>
  </form>

  <div class="filter-summary-bar" data-filter-summary hidden></div>
  <p class="filter-status" data-filter-status>{t("filter.loading", locale)}</p>
  <div class="filter-results" data-filter-results></div>
</section>

<script>
  import { evaluatePrograms, type FilterResult, type FilterResultStatus, type UserProfile } from "../../lib/filterEngine";
  import { defaultLocale, isLocale, pickLocalized, t, tf, withLocale } from "../../i18n";

  type FilterPrograms = Parameters<typeof evaluatePrograms>[0];

  const root = document.querySelector<HTMLElement>("[data-eligibility-filter]");
  const localeValue = root?.dataset.locale;
  const locale = isLocale(localeValue) ? localeValue : defaultLocale;
  const form = root?.querySelector<HTMLFormElement>("[data-profile-form]");
  const status = root?.querySelector<HTMLElement>("[data-filter-status]");
  const summaryBar = root?.querySelector<HTMLElement>("[data-filter-summary]");
  const resultsRoot = root?.querySelector<HTMLElement>("[data-filter-results]");
  let programs: FilterPrograms = [];
  let showBlocked = false;
  /** Country ids the user collapsed; others stay open by default. */
  const collapsedCountries = new Set<string>();

  const statusLabels: Record<FilterResultStatus, string> = {
    likely_match: t("filter.status.likely", locale),
    possible_match: t("filter.status.possible", locale),
    not_match: t("filter.status.notMatch", locale),
    needs_review: t("filter.status.review", locale),
    unknown: t("filter.status.unknown", locale),
  };

  const EXPLORE_STATUSES = new Set<FilterResultStatus>([
    "likely_match",
    "possible_match",
    "needs_review",
    "unknown",
  ]);

  function optionalNumber(formData: FormData, key: string) {
    const raw = String(formData.get(key) ?? "").trim();
    if (!raw) return undefined;
    const value = Number(raw);
    return Number.isFinite(value) ? value : undefined;
  }

  function triStateBool(formData: FormData, key: string): boolean | undefined {
    // Checkbox present = true; absent = unknown (not false). Users who never
    // opened advanced options should not be treated as "no".
    return formData.has(key) ? true : undefined;
  }

  function profileFromForm(): UserProfile | undefined {
    if (!form) return undefined;
    const data = new FormData(form);
    const categoryIds = data
      .getAll("category_ids")
      .map((value) => String(value))
      .filter(Boolean);
    const jobOffer = String(data.get("job_offer") ?? "unknown");
    const savings = optionalNumber(data, "liquid_funds_amount");
    const currency = String(data.get("liquid_funds_currency") ?? "USD");

    return {
      goal: String(data.get("goal") || "permanent_residence") as UserProfile["goal"],
      category_ids: categoryIds.length ? categoryIds : undefined,
      skilled_work_years: optionalNumber(data, "skilled_work_years"),
      education_level: String(data.get("education_level") || "bachelor") as UserProfile["education_level"],
      family_size: optionalNumber(data, "family_size") ?? 1,
      liquid_funds:
        savings === undefined
          ? undefined
          : {
              amount: savings,
              currency,
            },
      valid_job_offer: jobOffer === "yes" ? true : jobOffer === "no" ? false : undefined,
      has_approved_language_test: triStateBool(data, "has_approved_language_test"),
      foreign_education: triStateBool(data, "foreign_education"),
      authorized_to_work_in_country: triStateBool(data, "authorized_to_work_in_country"),
    };
  }

  function primaryReasons(result: FilterResult) {
    const blocking = result.reasons.filter((reason) => reason.severity === "blocking");
    if (blocking.length) return blocking.slice(0, 2);
    const warnings = result.reasons.filter((reason) => reason.severity === "warning");
    const positives = result.reasons.filter((reason) => reason.severity === "positive");
    return [...warnings.slice(0, 1), ...positives.slice(0, 1), ...warnings.slice(1, 2)].slice(0, 2);
  }

  function appendReasonList(parent: HTMLElement, reasons: FilterResult["reasons"], compact: boolean) {
    const list = document.createElement("ul");
    list.className = "filter-reason-list";
    for (const reason of reasons) {
      const item = document.createElement("li");
      item.className = `filter-reason filter-reason--${reason.severity}`;
      const msg = document.createElement("span");
      msg.textContent = reason.message;
      item.append(msg);
      if (!compact && reason.citations.length) {
        const src = document.createElement("span");
        src.className = "filter-reason-sources";
        const citation = reason.citations[0];
        const a = document.createElement("a");
        a.href = citation.url;
        a.target = "_blank";
        a.rel = "noopener";
        a.textContent = t("filter.officialSource", locale);
        src.append(a);
        item.append(src);
      }
      list.append(item);
    }
    parent.append(list);
  }

  function renderCard(
    result: FilterResult,
    program: FilterPrograms[number],
  ): HTMLElement {
    const article = document.createElement("article");
    article.className = `filter-result filter-result--${result.status}`;

    const header = document.createElement("div");
    header.className = "filter-result-header";

    const badge = document.createElement("span");
    badge.className = `filter-result-badge filter-result-badge--${result.status}`;
    badge.textContent = statusLabels[result.status];

    const heading = document.createElement("h3");
    const link = document.createElement("a");
    link.href = withLocale(`/programs/${result.program_id}`, locale);
    link.textContent = pickLocalized(program.official_names, locale);
    heading.append(link);

    header.append(badge, heading);
    article.append(header);

    const body = document.createElement("div");
    body.className = "filter-result-body";
    const preview = primaryReasons(result);
    appendReasonList(body, preview, true);

    if (result.reasons.length > preview.length) {
      const details = document.createElement("details");
      details.className = "filter-result-more";
      const summary = document.createElement("summary");
      summary.textContent = t("filter.showMore", locale);
      details.append(summary);
      const moreBody = document.createElement("div");
      moreBody.className = "filter-result-body";
      const rest = result.reasons.filter((reason) => !preview.includes(reason));
      const positives = rest.filter((reason) => reason.severity === "positive");
      const others = rest.filter((reason) => reason.severity !== "positive");
      if (positives.length) {
        const title = document.createElement("p");
        title.className = "filter-reason-heading";
        title.textContent = t("filter.supporting", locale);
        moreBody.append(title);
        appendReasonList(moreBody, positives, false);
      }
      if (others.length) {
        const title = document.createElement("p");
        title.className = "filter-reason-heading";
        title.textContent = t("filter.caveats", locale);
        moreBody.append(title);
        appendReasonList(moreBody, others, false);
      }
      details.append(moreBody);
      article.append(body, details);
    } else {
      article.append(body);
    }

    return article;
  }

  function groupByCountry(results: FilterResult[]) {
    const groups = new Map<
      string,
      { countryId: string; countryName: string; results: FilterResult[] }
    >();
    for (const result of results) {
      const program = programs.find(({ program_id }) => program_id === result.program_id);
      if (!program) continue;
      const countryId = program.country_id;
      const countryName = pickLocalized(program.country_names, locale);
      const group = groups.get(countryId) ?? { countryId, countryName, results: [] };
      group.results.push(result);
      groups.set(countryId, group);
    }
    return [...groups.values()].sort((left, right) =>
      left.countryName.localeCompare(right.countryName, locale),
    );
  }

  function renderCountryGroups(parent: HTMLElement, results: FilterResult[]) {
    for (const group of groupByCountry(results)) {
      const details = document.createElement("details");
      details.className = "filter-country-group";
      details.open = !collapsedCountries.has(group.countryId);
      details.addEventListener("toggle", () => {
        if (details.open) collapsedCountries.delete(group.countryId);
        else collapsedCountries.add(group.countryId);
      });

      const summary = document.createElement("summary");
      const name = document.createElement("span");
      name.textContent = group.countryName;
      const count = document.createElement("span");
      count.className = "filter-country-count";
      count.textContent = tf(
        group.results.length === 1 ? "filter.countryCount" : "filter.countryCountPlural",
        locale,
        { count: group.results.length },
      );
      summary.append(name, count);
      details.append(summary);

      const grid = document.createElement("div");
      grid.className = "filter-result-grid";
      for (const result of group.results) {
        const program = programs.find(({ program_id }) => program_id === result.program_id);
        if (!program) continue;
        grid.append(renderCard(result, program));
      }
      details.append(grid);
      parent.append(details);
    }
  }

  function render() {
    if (!status || !resultsRoot || !summaryBar) return;
    const profile = profileFromForm();
    if (!profile) return;
    const results = evaluatePrograms(programs, profile, locale);
    const explore = results.filter((result) => EXPLORE_STATUSES.has(result.status));
    const blocked = results.filter((result) => result.status === "not_match");

    status.textContent =
      results.length === 1
        ? t("filter.rankedOne", locale)
        : tf("filter.ranked", locale, { count: results.length });

    summaryBar.hidden = false;
    summaryBar.textContent = tf("filter.summary", locale, {
      explore: explore.length,
      blocked: blocked.length,
      total: results.length,
    });

    resultsRoot.replaceChildren();

    const exploreSection = document.createElement("section");
    exploreSection.className = "filter-result-section";
    const exploreHeading = document.createElement("h3");
    exploreHeading.className = "filter-section-heading";
    exploreHeading.textContent = t("filter.summaryExplore", locale);
    exploreSection.append(exploreHeading);

    if (!explore.length) {
      const empty = document.createElement("p");
      empty.className = "filter-empty";
      empty.textContent = t("filter.emptyExplore", locale);
      exploreSection.append(empty);
    } else {
      renderCountryGroups(exploreSection, explore);
    }
    resultsRoot.append(exploreSection);

    if (blocked.length) {
      const blockedSection = document.createElement("section");
      blockedSection.className = "filter-result-section filter-result-section--blocked";
      const toggle = document.createElement("button");
      toggle.type = "button";
      toggle.className = "filter-toggle-blocked btn btn-ghost";
      toggle.textContent = showBlocked
        ? t("filter.hideBlocked", locale)
        : tf("filter.showBlocked", locale, { count: blocked.length });
      toggle.addEventListener("click", () => {
        showBlocked = !showBlocked;
        render();
      });
      blockedSection.append(toggle);

      if (showBlocked) {
        renderCountryGroups(blockedSection, blocked);
      }
      resultsRoot.append(blockedSection);
    }
  }

  async function init() {
    if (!status) return;
    try {
      const response = await fetch("/data/indexes/filter-index.v1.json");
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      const payload = (await response.json()) as { programs: FilterPrograms };
      programs = payload.programs;
      form?.addEventListener("input", render);
      form?.addEventListener("change", render);
      render();
    } catch (error) {
      status.textContent = tf("filter.loadError", locale, {
        error: error instanceof Error ? error.message : t("filter.status.unknown", locale),
      });
    }
  }

  void init();
</script>

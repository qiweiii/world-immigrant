<section class="panel" aria-labelledby="filter-heading" data-eligibility-filter>
  <p class="eyebrow">Local-first profile</p>
  <h2 id="filter-heading">Check modeled minimums without sending profile data.</h2>
  <p>
    Results are preliminary information, not legal advice or a guarantee of eligibility or an
    invitation. Unknown and incomplete facts stay visible.
  </p>
  <form data-profile-form>
    <div class="field-grid">
      <div class="field">
        <label class="field-label" for="goal">Goal</label>
        <select class="input" id="goal" name="goal">
          <option value="permanent_residence" selected>Permanent residence</option>
          <option value="citizenship">Citizenship pathway</option>
        </select>
      </div>
      <div class="field">
        <label class="field-label" for="work-years">Qualifying skilled-work years</label>
        <input class="input" id="work-years" name="skilled_work_years" value="3" inputmode="decimal" />
      </div>
      <div class="field">
        <label class="field-label" for="language-benchmark">CLB or NCLC benchmark</label>
        <input class="input" id="language-benchmark" name="language_benchmark" value="8" inputmode="numeric" />
      </div>
      <div class="field">
        <label class="field-label" for="education">Highest completed education</label>
        <select class="input" id="education" name="education_level">
          <option value="secondary">Secondary</option>
          <option value="vocational">Vocational</option>
          <option value="associate">Associate</option>
          <option value="bachelor" selected>Bachelor</option>
          <option value="master">Master</option>
          <option value="doctorate">Doctorate</option>
        </select>
      </div>
      <div class="field">
        <label class="field-label" for="program-points">Program selection-factor points</label>
        <input class="input" id="program-points" name="program_selection_points" value="72" inputmode="numeric" />
      </div>
      <div class="field">
        <label class="field-label" for="family-size">Family size</label>
        <input class="input" id="family-size" name="family_size" value="1" inputmode="numeric" />
      </div>
      <div class="field">
        <label class="field-label" for="funds">Available settlement funds, CAD</label>
        <input class="input" id="funds" name="liquid_funds" value="20000" inputmode="decimal" />
      </div>
    </div>
    <div class="badge-row" style="margin-top:16px;">
      <label class="badge"><input type="checkbox" name="has_approved_language_test" checked /> Approved language test</label>
      <label class="badge"><input type="checkbox" name="foreign_education" checked /> Foreign education</label>
      <label class="badge"><input type="checkbox" name="has_eca" checked /> Valid ECA</label>
      <label class="badge"><input type="checkbox" name="authorized_to_work_in_country" /> Authorized to work in Canada</label>
      <label class="badge"><input type="checkbox" name="valid_job_offer" /> Valid Canadian job offer</label>
    </div>
  </form>
  <p class="card-description" data-filter-status>Loading verified filter data…</p>
  <div class="card-grid" data-filter-results></div>
</section>

<script>
  import { evaluatePrograms, type UserProfile } from "../../lib/filterEngine";

  type FilterPrograms = Parameters<typeof evaluatePrograms>[0];

  const root = document.querySelector<HTMLElement>("[data-eligibility-filter]");
  const form = root?.querySelector<HTMLFormElement>("[data-profile-form]");
  const status = root?.querySelector<HTMLElement>("[data-filter-status]");
  const resultsRoot = root?.querySelector<HTMLElement>("[data-filter-results]");
  let programs: FilterPrograms = [];

  function optionalNumber(formData: FormData, key: string) {
    const raw = String(formData.get(key) ?? "").trim();
    if (!raw) return undefined;
    const value = Number(raw);
    return Number.isFinite(value) ? value : undefined;
  }

  function profileFromForm(): UserProfile | undefined {
    if (!form) return undefined;
    const data = new FormData(form);
    const funds = optionalNumber(data, "liquid_funds");
    return {
      goal: String(data.get("goal")) as UserProfile["goal"],
      skilled_work_years: optionalNumber(data, "skilled_work_years"),
      has_approved_language_test: data.has("has_approved_language_test"),
      language_benchmark: optionalNumber(data, "language_benchmark"),
      education_level: String(data.get("education_level")) as UserProfile["education_level"],
      foreign_education: data.has("foreign_education"),
      has_eca: data.has("has_eca"),
      program_selection_points: optionalNumber(data, "program_selection_points"),
      family_size: optionalNumber(data, "family_size"),
      liquid_funds: funds === undefined ? undefined : { amount: funds, currency: "CAD" },
      authorized_to_work_in_country: data.has("authorized_to_work_in_country"),
      valid_job_offer: data.has("valid_job_offer"),
    };
  }

  function render() {
    if (!status || !resultsRoot) return;
    const profile = profileFromForm();
    if (!profile) return;
    const results = evaluatePrograms(programs, profile);
    status.textContent = `${results.length} program${results.length === 1 ? "" : "s"} checked locally. “Likely match” means no modeled blocker was found; it does not mean eligible or invited.`;
    resultsRoot.replaceChildren();

    for (const result of results) {
      const program = programs.find(({ program_id }) => program_id === result.program_id);
      if (!program) continue;
      const article = document.createElement("article");
      article.className = "card";
      const eyebrow = document.createElement("p");
      eyebrow.className = "eyebrow";
      eyebrow.textContent = `${result.status.replaceAll("_", " ")} · score ${result.score}`;
      const heading = document.createElement("h3");
      const link = document.createElement("a");
      link.href = `/programs/${result.program_id}`;
      link.textContent = program.official_names.en;
      heading.append(link);
      const list = document.createElement("ul");
      for (const reason of result.reasons) {
        const item = document.createElement("li");
        item.textContent = `${reason.severity}: ${reason.message} Sources: ${reason.citations.join(", ")}`;
        list.append(item);
      }
      article.append(eyebrow, heading, list);
      resultsRoot.append(article);
    }
  }

  async function init() {
    if (!status) return;
    try {
      const response = await fetch("/data/indexes/filter-index.v1.json");
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      const payload = (await response.json()) as { programs: FilterPrograms };
      programs = payload.programs;
      form?.addEventListener("input", render);
      render();
    } catch (error) {
      status.textContent = `Filter data could not be loaded: ${error instanceof Error ? error.message : "unknown error"}`;
    }
  }

  void init();
</script>

<section class="filter-shell" aria-labelledby="filter-heading" data-eligibility-filter>
  <div class="filter-intro">
    <p class="eyebrow">Fit tool</p>
    <h2 id="filter-heading">See how pathways line up with your situation.</h2>
    <p class="filter-lede">
      Answers stay on this page. Results are preliminary information, not a decision about eligibility
      or an invitation.
    </p>
  </div>

  <form class="filter-form" data-profile-form>
    <div class="field-grid">
      <div class="field">
        <label class="field-label" for="goal">Goal</label>
        <select class="input" id="goal" name="goal">
          <option value="permanent_residence" selected>Permanent residence</option>
          <option value="citizenship">Citizenship pathway</option>
        </select>
      </div>
      <div class="field">
        <label class="field-label" for="work-years">Qualifying skilled-work years</label>
        <input class="input" id="work-years" name="skilled_work_years" value="3" inputmode="decimal" />
      </div>
      <div class="field">
        <label class="field-label" for="language-benchmark">CLB or NCLC benchmark</label>
        <input class="input" id="language-benchmark" name="language_benchmark" value="8" inputmode="numeric" />
      </div>
      <div class="field">
        <label class="field-label" for="education">Highest completed education</label>
        <select class="input" id="education" name="education_level">
          <option value="secondary">Secondary</option>
          <option value="vocational">Vocational</option>
          <option value="associate">Associate</option>
          <option value="bachelor" selected>Bachelor</option>
          <option value="master">Master</option>
          <option value="doctorate">Doctorate</option>
        </select>
      </div>
      <div class="field">
        <label class="field-label" for="program-points">Program selection-factor points</label>
        <input class="input" id="program-points" name="program_selection_points" value="72" inputmode="numeric" />
      </div>
      <div class="field">
        <label class="field-label" for="family-size">Family size</label>
        <input class="input" id="family-size" name="family_size" value="1" inputmode="numeric" />
      </div>
      <div class="field">
        <label class="field-label" for="funds">Available settlement funds, CAD</label>
        <input class="input" id="funds" name="liquid_funds" value="20000" inputmode="decimal" />
      </div>
    </div>

    <fieldset class="filter-flags">
      <legend class="field-label">Additional facts</legend>
      <div class="filter-flag-list">
        <label class="filter-flag">
          <input type="checkbox" name="has_approved_language_test" checked />
          <span>Approved language test</span>
        </label>
        <label class="filter-flag">
          <input type="checkbox" name="foreign_education" checked />
          <span>Foreign education</span>
        </label>
        <label class="filter-flag">
          <input type="checkbox" name="has_eca" checked />
          <span>Valid ECA</span>
        </label>
        <label class="filter-flag">
          <input type="checkbox" name="authorized_to_work_in_country" />
          <span>Authorized to work in Canada</span>
        </label>
        <label class="filter-flag">
          <input type="checkbox" name="valid_job_offer" />
          <span>Valid Canadian job offer</span>
        </label>
      </div>
    </fieldset>
  </form>

  <p class="filter-status" data-filter-status>Loading filter data…</p>
  <div class="filter-results" data-filter-results></div>
</section>

<script>
  import { evaluatePrograms, type FilterResultStatus, type UserProfile } from "../../lib/filterEngine";

  type FilterPrograms = Parameters<typeof evaluatePrograms>[0];

  const root = document.querySelector<HTMLElement>("[data-eligibility-filter]");
  const form = root?.querySelector<HTMLFormElement>("[data-profile-form]");
  const status = root?.querySelector<HTMLElement>("[data-filter-status]");
  const resultsRoot = root?.querySelector<HTMLElement>("[data-filter-results]");
  let programs: FilterPrograms = [];

  const statusLabels: Record<FilterResultStatus, string> = {
    likely_match: "Looks open",
    possible_match: "Missing details",
    not_match: "Does not match",
    needs_review: "Complex rules",
    unknown: "Unclear",
  };

  function optionalNumber(formData: FormData, key: string) {
    const raw = String(formData.get(key) ?? "").trim();
    if (!raw) return undefined;
    const value = Number(raw);
    return Number.isFinite(value) ? value : undefined;
  }

  function profileFromForm(): UserProfile | undefined {
    if (!form) return undefined;
    const data = new FormData(form);
    const funds = optionalNumber(data, "liquid_funds");
    return {
      goal: String(data.get("goal")) as UserProfile["goal"],
      skilled_work_years: optionalNumber(data, "skilled_work_years"),
      has_approved_language_test: data.has("has_approved_language_test"),
      language_benchmark: optionalNumber(data, "language_benchmark"),
      education_level: String(data.get("education_level")) as UserProfile["education_level"],
      foreign_education: data.has("foreign_education"),
      has_eca: data.has("has_eca"),
      program_selection_points: optionalNumber(data, "program_selection_points"),
      family_size: optionalNumber(data, "family_size"),
      liquid_funds: funds === undefined ? undefined : { amount: funds, currency: "CAD" },
      authorized_to_work_in_country: data.has("authorized_to_work_in_country"),
      valid_job_offer: data.has("valid_job_offer"),
    };
  }

  function render() {
    if (!status || !resultsRoot) return;
    const profile = profileFromForm();
    if (!profile) return;
    const results = evaluatePrograms(programs, profile);
    status.textContent = `${results.length} pathway${results.length === 1 ? "" : "s"} ranked for this profile. “Looks open” only means no modeled blocker was found.`;
    resultsRoot.replaceChildren();

    for (const result of results) {
      const program = programs.find(({ program_id }) => program_id === result.program_id);
      if (!program) continue;

      const article = document.createElement("article");
      article.className = `filter-result filter-result--${result.status}`;

      const header = document.createElement("div");
      header.className = "filter-result-header";

      const badge = document.createElement("span");
      badge.className = `filter-result-badge filter-result-badge--${result.status}`;
      badge.textContent = statusLabels[result.status];

      const heading = document.createElement("h3");
      const link = document.createElement("a");
      link.href = `/programs/${result.program_id}`;
      link.textContent = program.official_names.en;
      heading.append(link);

      header.append(badge, heading);

      const positives = result.reasons.filter((reason) => reason.severity === "positive");
      const others = result.reasons.filter((reason) => reason.severity !== "positive");

      const body = document.createElement("div");
      body.className = "filter-result-body";

      if (positives.length) {
        const posBlock = document.createElement("div");
        posBlock.className = "filter-reason-group filter-reason-group--positive";
        const posTitle = document.createElement("p");
        posTitle.className = "filter-reason-heading";
        posTitle.textContent = "Supporting signals";
        posBlock.append(posTitle);
        const posList = document.createElement("ul");
        for (const reason of positives) {
          const item = document.createElement("li");
          item.className = "filter-reason filter-reason--positive";
          const msg = document.createElement("span");
          msg.textContent = reason.message;
          item.append(msg);
          if (reason.citations.length) {
            const src = document.createElement("span");
            src.className = "filter-reason-sources";
            src.textContent = reason.citations.join(" · ");
            item.append(src);
          }
          posList.append(item);
        }
        posBlock.append(posList);
        body.append(posBlock);
      }

      if (others.length) {
        const otherBlock = document.createElement("div");
        otherBlock.className = "filter-reason-group";
        const otherTitle = document.createElement("p");
        otherTitle.className = "filter-reason-heading";
        otherTitle.textContent = "Caveats and gaps";
        otherBlock.append(otherTitle);
        const otherList = document.createElement("ul");
        for (const reason of others) {
          const item = document.createElement("li");
          item.className = `filter-reason filter-reason--${reason.severity}`;
          const msg = document.createElement("span");
          msg.textContent = reason.message;
          item.append(msg);
          if (reason.citations.length) {
            const src = document.createElement("span");
            src.className = "filter-reason-sources";
            src.textContent = reason.citations.join(" · ");
            item.append(src);
          }
          otherList.append(item);
        }
        otherBlock.append(otherList);
        body.append(otherBlock);
      }

      article.append(header, body);
      resultsRoot.append(article);
    }
  }

  async function init() {
    if (!status) return;
    try {
      const response = await fetch("/data/indexes/filter-index.v1.json");
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      const payload = (await response.json()) as { programs: FilterPrograms };
      programs = payload.programs;
      form?.addEventListener("input", render);
      render();
    } catch (error) {
      status.textContent = `Filter data could not be loaded: ${error instanceof Error ? error.message : "unknown error"}`;
    }
  }

  void init();
</script>

---
interface Props {
  title: string;
  country: string;
  category: string;
  summary: string;
  href?: string;
  status?: string;
  checkedAt?: string;
}

const {
  title,
  country,
  category,
  summary,
  href = "#",
  status = "active",
  checkedAt,
} = Astro.props;
---

<a class="card card-clickable" href={href}>
  <p class="card-meta">{country} · {category.replaceAll("_", " ")}</p>
  <h3 class="card-title">{title}</h3>
  <p class="card-description">{summary}</p>
  <div class="card-footer">
    {checkedAt && <span class="card-tag">Checked {checkedAt.slice(0, 10)}</span>}
  </div>
</a>
---
import Layout from "../components/Layout.astro";
import CompareBuilder from "../components/islands/CompareBuilder.astro";
import { defaultLocale, t, type Locale } from "../i18n";

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props as Props;
---

<Layout locale={locale} title={t("compare.title", locale)}>
  <main>
    <section class="hero">
      <p class="eyebrow">{t("compare.eyebrow", locale)}</p>
      <h1>{t("compare.h1", locale)}</h1>
      <p>{t("compare.lede", locale)}</p>
    </section>
    <CompareBuilder locale={locale} />
  </main>
</Layout>

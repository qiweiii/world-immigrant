---
import Layout from "../components/Layout.astro";
import CompareBuilder from "../components/islands/CompareBuilder.astro";
---

<Layout title="Compare immigration pathways — World Immigrant">
  <main>
    <section class="hero">
      <p class="eyebrow">Side-by-side decisions</p>
      <h1>Compare the rules that change your decision.</h1>
      <p>
        Select up to three pathways to compare permanence, funds, family rules, work rights, and
        how current the underlying information is.
      </p>
    </section>
    <CompareBuilder />
  </main>
</Layout>
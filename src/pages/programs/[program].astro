---
import Layout from "../../components/Layout.astro";
import { loadCanonicalData } from "../../lib/data";
import { buildProgramPageModels, type ProgramPageModel } from "../../lib/site-model";
import { defaultLocale, pickLocalized, t, withLocale, type Locale } from "../../i18n";
import { breadcrumbJsonLd } from "../../lib/seo";

interface Props {
  model: ProgramPageModel;
  locale?: Locale;
}

export async function getStaticPaths() {
  const models = buildProgramPageModels(await loadCanonicalData());
  return models.map((model) => ({ params: { program: model.program.id }, props: { model } }));
}

const { model, locale = defaultLocale } = Astro.props as Props;
const { program, country, categories, sources, citations } = model;
const L = (path: string) => withLocale(path, locale);

function displayValue(value: unknown) {
  if (value === true) return t("program.yes", locale);
  if (value === false) return t("program.no", locale);
  if (value === "not_applicable") return t("program.notApplicable", locale);
  if (value === "unknown") return t("program.unknown", locale);
  if (value === "indirect") return t("program.indirect", locale);
  if (value === "limited") return t("program.limited", locale);
  if (value === undefined || value === null || value === "") return t("program.notStated", locale);
  return String(value);
}

const pathwayLabel =
  program.filter.pathway_type === "direct_pr"
    ? t("program.directPr", locale)
    : program.filter.pathway_type.replaceAll("_", " ");
const hasFundsTable = program.funds.proof_of_funds.length > 0;
const applicationFees = program.funds.application_fees ?? [];
const programName = pickLocalized(program.official_names, locale);
const countryName = pickLocalized(country.names, locale);
const summary = pickLocalized(program.summary_md, locale);
const structuredData = [
  breadcrumbJsonLd([
    { name: t("crumb.home", locale), path: L("/") },
    { name: t("nav.countries", locale), path: L("/countries") },
    { name: countryName, path: L(`/countries/${country.id}`) },
    { name: programName, path: L(`/programs/${program.id}`) },
  ]),
];
---

<Layout
  locale={locale}
  title={`${programName} — World Immigrant`}
  description={summary}
  dateModified={program.freshness.last_checked_at}
  structuredData={structuredData}
>
  <main>
    <nav class="breadcrumbs" aria-label={t("crumb.aria", locale)}>
      <a href={L("/")}>{t("crumb.home", locale)}</a>
      <span aria-hidden="true">/</span>
      <a href={L("/countries")}>{t("nav.countries", locale)}</a>
      <span aria-hidden="true">/</span>
      <a href={L(`/countries/${country.id}`)}>{countryName}</a>
      <span aria-hidden="true">/</span>
      <span>{programName}</span>
    </nav>

    <section class="hero">
      <p class="eyebrow">
        {countryName} · {categories.map((c) => pickLocalized(c.names, locale)).join(" · ")}
      </p>
      <h1>{programName}</h1>
      <p>{summary}</p>
      <div class="action-row">
        <a class="btn btn-primary" href={L(`/compare?programs=${program.id}`)}
          >{t("program.compareThis", locale)}</a
        >
        <a class="btn btn-ghost" href={L("/filter")}>{t("program.checkFit", locale)}</a>
      </div>
    </section>

    {
      pickLocalized(program.status_note_md, locale) && (
        <section class="panel panel-note" aria-label={t("program.statusNote", locale)}>
          <p>
            <strong>{t("program.statusNote", locale)}</strong>{" "}
            {pickLocalized(program.status_note_md, locale)}
          </p>
        </section>
      )
    }

    <section class="section" aria-labelledby="fit-heading">
      <div class="section-heading">
        <div>
          <p class="eyebrow">{t("program.decisionFit", locale)}</p>
          <h2 id="fit-heading">{t("program.whoServes", locale)}</h2>
        </div>
      </div>
      <div class="card-grid two">
        <article class="card">
          <h3 class="card-title">{t("program.goodFit", locale)}</h3>
          <p class="prose">{pickLocalized(program.good_for_md, locale)}</p>
        </article>
        <article class="card">
          <h3 class="card-title">{t("program.limits", locale)}</h3>
          <p class="prose">
            {pickLocalized(program.not_good_for_md, locale) || t("program.noLimits", locale)}
          </p>
        </article>
      </div>
    </section>

    <section class="section" aria-labelledby="eligibility-heading">
      <div class="section-heading">
        <div>
          <p class="eyebrow">{t("program.minimums", locale)}</p>
          <h2 id="eligibility-heading">{t("program.eligibility", locale)}</h2>
        </div>
      </div>
      <div class="card-grid">
        <article class="card">
          <h3 class="card-title">{t("program.age", locale)}</h3>
          <p>
            {
              program.eligibility.age.max !== undefined
                ? `${t("program.maxAge", locale)} ${program.eligibility.age.max + 1}`
                : t("program.noAge", locale)
            }
          </p>
          <p class="prose muted">{pickLocalized(program.eligibility.age.note_md, locale)}</p>
        </article>
        <article class="card">
          <h3 class="card-title">{t("program.work", locale)}</h3>
          <p>
            {t("program.minimum", locale)}:{" "}
            {displayValue(program.eligibility.work_experience.min_years)}{" "}
            {t("program.years", locale)}
          </p>
          <p class="prose muted">
            {pickLocalized(program.eligibility.work_experience.note_md, locale)}
          </p>
        </article>
        <article class="card">
          <h3 class="card-title">{t("program.language", locale)}</h3>
          <p>{program.eligibility.language[0]?.minimum_level ?? t("program.notStated", locale)}</p>
          <p class="prose muted">
            {pickLocalized(program.eligibility.language[0]?.note_md, locale)}
          </p>
        </article>
        <article class="card">
          <h3 class="card-title">{t("program.education", locale)}</h3>
          <p>
            {t("program.minimum", locale)}:{" "}
            {displayValue(program.eligibility.education.required_level)}
          </p>
          <p>
            {t("program.assessment", locale)}:{" "}
            {displayValue(program.eligibility.education.credential_assessment_required)}
          </p>
          <p class="prose muted">
            {pickLocalized(program.eligibility.education.note_md, locale)}
          </p>
        </article>
        <article class="card">
          <h3 class="card-title">{t("program.selection", locale)}</h3>
          <p>
            {t("program.points", locale)}: {displayValue(program.eligibility.points_threshold)}
          </p>
          <p>
            {t("program.competition", locale)}:{" "}
            {displayValue(program.eligibility.invitation_competition_level)}
          </p>
        </article>
        <article class="card">
          <h3 class="card-title">{t("program.health", locale)}</h3>
          <p>
            {t("program.healthCheck", locale)}:{" "}
            {displayValue(program.eligibility.health_check_required)}
          </p>
          <p>
            {t("program.police", locale)}:{" "}
            {displayValue(program.eligibility.police_certificate_required)}
          </p>
        </article>
      </div>
    </section>

    <section class="section" aria-labelledby="funds-heading">
      <div class="section-heading">
        <div>
          <p class="eyebrow">{t("program.costs", locale)}</p>
          <h2 id="funds-heading">{t("program.fundsFees", locale)}</h2>
        </div>
      </div>
      <div class="card-grid two">
        <article class="card">
          <h3 class="card-title">{t("program.settlement", locale)}</h3>
          {
            hasFundsTable ? (
              <div class="table-wrap">
                <table class="table">
                  <thead>
                    <tr>
                      <th>{t("program.familySize", locale)}</th>
                      <th>{t("program.minFunds", locale)}</th>
                    </tr>
                  </thead>
                  <tbody>
                    {program.funds.proof_of_funds.map((requirement) => (
                      <tr>
                        <td>
                          {requirement.calculation === "increment_per_additional_member"
                            ? `${t("program.eachMemberAfter", locale)} ${requirement.family_size_above}`
                            : requirement.family_size}
                        </td>
                        <td>
                          {displayValue(requirement.amount)} {requirement.currency}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            ) : (
              <p class="prose">{t("program.noFunds", locale)}</p>
            )
          }
          <p class="prose muted">{pickLocalized(program.funds.exemption_note_md, locale)}</p>
        </article>
        <article class="card">
          <h3 class="card-title">{t("program.fees", locale)}</h3>
          {
            applicationFees.length ? (
              <ul class="detail-list">
                {applicationFees.map((fee) => (
                  <li>
                    <strong>
                      {displayValue(fee.amount)} {fee.currency}
                    </strong>
                    <span>{pickLocalized(fee.label, locale) || fee.applies_to}</span>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="prose">{t("program.noFees", locale)}</p>
            )
          }
        </article>
      </div>
    </section>

    <section class="section" aria-labelledby="outcome-heading">
      <div class="section-heading">
        <div>
          <p class="eyebrow">{t("program.outcomes", locale)}</p>
          <h2 id="outcome-heading">{t("program.residenceWorkFamily", locale)}</h2>
        </div>
      </div>
      <div class="card-grid">
        <article class="card">
          <h3 class="card-title">{t("program.pr", locale)}</h3>
          <p class="prose">{pickLocalized(program.pr_pathway.summary_md, locale)}</p>
          <p>
            {t("program.workLabel", locale)}: {displayValue(program.rights.work_allowed)} ·{" "}
            {t("program.studyLabel", locale)}: {displayValue(program.rights.study_allowed)}
          </p>
        </article>
        <article class="card">
          <h3 class="card-title">{t("program.family", locale)}</h3>
          <p class="prose">{pickLocalized(program.family.note_md, locale)}</p>
          <p>
            {t("program.partner", locale)}:{" "}
            {displayValue(program.family.spouse_or_partner_allowed)} ·{" "}
            {t("program.children", locale)}: {displayValue(program.family.children_allowed)}
          </p>
        </article>
        <article class="card">
          <h3 class="card-title">{t("program.citizenship", locale)}</h3>
          <p class="prose">{pickLocalized(program.citizenship_pathway.summary_md, locale)}</p>
        </article>
        <article class="card">
          <h3 class="card-title">{t("program.processing", locale)}</h3>
          <p class="prose">
            {pickLocalized(program.timeline.application_processing_time_md, locale)}
          </p>
          <p>
            {t("program.modeled", locale)}:{" "}
            {displayValue(program.timeline.processing_time_months_min)}–
            {displayValue(program.timeline.processing_time_months_max)}{" "}
            {t("program.months", locale)}
          </p>
        </article>
      </div>
    </section>

    <section class="section" aria-labelledby="sources-heading">
      <div class="section-heading">
        <div>
          <p class="eyebrow">{t("program.sources", locale)}</p>
          <h2 id="sources-heading">{t("program.officialSources", locale)}</h2>
        </div>
      </div>
      <div class="card-grid">
        {
          sources.map((source) => (
            <a class="card card-clickable" href={source.url} target="_blank" rel="noopener noreferrer">
              <p class="card-meta">{source.publisher}</p>
              <h3 class="card-title">{source.title}</h3>
              <div class="card-footer">
                <span class="card-tag">
                  {t("program.checked", locale)} {source.last_checked_at?.slice(0, 10)}
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <section class="section" aria-labelledby="evidence-heading">
      <div class="section-heading">
        <div>
          <p class="eyebrow">{t("program.citations", locale)}</p>
          <h2 id="evidence-heading">{t("program.provenance", locale)}</h2>
        </div>
      </div>
      <div class="card-grid">
        {
          citations.map(({ path, citations: refs }) => (
            <article class="card">
              <p class="card-meta mono">{path}</p>
              {refs.map((ref) => (
                <div class="citation-block">
                  <h3 class="card-title">
                    <a href={ref.url} target="_blank" rel="noopener noreferrer">
                      {ref.section ?? ref.source_id}
                    </a>
                  </h3>
                  {ref.quote_md && <p class="quote">"{ref.quote_md}"</p>}
                </div>
              ))}
            </article>
          ))
        }
      </div>
    </section>

    <section class="panel" aria-label={t("program.disclaimerTitle", locale)}>
      <p>
        <strong>{t("program.disclaimerTitle", locale)}</strong>
        {" "}
        {t("program.disclaimerBody", locale)}
      </p>
    </section>
  </main>
</Layout>

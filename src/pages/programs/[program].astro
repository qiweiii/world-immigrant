---
import Layout from "../../components/Layout.astro";
import { loadCanonicalData } from "../../lib/data";
import { buildProgramPageModels, type ProgramPageModel } from "../../lib/site-model";

export async function getStaticPaths() {
  const models = buildProgramPageModels(await loadCanonicalData());
  return models.map((model) => ({ params: { program: model.program.id }, props: { model } }));
}

const { model } = Astro.props as { model: ProgramPageModel };
const { program, country, categories, sources, citations } = model;

function displayValue(value: unknown) {
  if (value === true) return "Yes";
  if (value === false) return "No";
  if (value === "not_applicable") return "Not applicable";
  if (value === "unknown") return "Unknown — verify with the official source";
  if (value === "indirect") return "Indirect pathway";
  if (value === "limited") return "Limited or conditional";
  if (value === undefined || value === null || value === "") return "Not stated";
  return String(value);
}

const pathwayLabel =
  program.filter.pathway_type === "direct_pr"
    ? "Direct permanent residence"
    : program.filter.pathway_type.replaceAll("_", " ");
const hasFundsTable = program.funds.proof_of_funds.length > 0;
const applicationFees = program.funds.application_fees ?? [];
---

<Layout
  title={`${program.official_names.en} — World Immigrant`}
  description={program.summary_md.en}
>
  <main>
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <a href="/countries">Countries</a>
      <span aria-hidden="true">/</span>
      <a href={`/countries/${country.id}`}>{country.names.en}</a>
      <span aria-hidden="true">/</span>
      <span>{program.official_names.en}</span>
    </nav>

    <section class="hero">
      <p class="eyebrow">
        {country.names.en} · {categories.map(({ names }) => names.en).join(" · ")}
      </p>
      <h1>{program.official_names.en}</h1>
      <p>{program.summary_md.en}</p>
      <div class="action-row">
        <a class="btn btn-primary" href={`/compare?programs=${program.id}`}>Compare this pathway</a>
        <a class="btn btn-ghost" href="/filter">Check your fit</a>
      </div>
    </section>

    {
      program.status_note_md?.en && (
        <section class="panel panel-note" aria-label="Status note">
          <p><strong>Status note.</strong> {program.status_note_md.en}</p>
        </section>
      )
    }

    <section class="section" aria-labelledby="fit-heading">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Decision fit</p>
          <h2 id="fit-heading">Who this pathway serves</h2>
        </div>
      </div>
      <div class="card-grid two">
        <article class="card">
          <h3 class="card-title">Good fit</h3>
          <p class="prose">{program.good_for_md.en}</p>
        </article>
        <article class="card">
          <h3 class="card-title">Important limits</h3>
          <p class="prose">{program.not_good_for_md?.en ?? "No separate limit summary is recorded."}</p>
        </article>
      </div>
    </section>

    <section class="section" aria-labelledby="eligibility-heading">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Minimums</p>
          <h2 id="eligibility-heading">Eligibility</h2>
        </div>
      </div>
      <div class="card-grid">
        <article class="card">
          <h3 class="card-title">Age</h3>
          <p>
            {
              program.eligibility.age.max !== undefined
                ? `Maximum modeled age: under ${program.eligibility.age.max + 1}`
                : "No hard age floor or ceiling is modeled."
            }
          </p>
          <p class="prose muted">{program.eligibility.age.note_md?.en}</p>
        </article>
        <article class="card">
          <h3 class="card-title">Work experience</h3>
          <p>Minimum: {displayValue(program.eligibility.work_experience.min_years)} years</p>
          <p class="prose muted">{program.eligibility.work_experience.note_md?.en}</p>
        </article>
        <article class="card">
          <h3 class="card-title">Language</h3>
          <p>{program.eligibility.language[0]?.minimum_level ?? "Not stated"}</p>
          <p class="prose muted">{program.eligibility.language[0]?.note_md?.en}</p>
        </article>
        <article class="card">
          <h3 class="card-title">Education</h3>
          <p>Minimum: {displayValue(program.eligibility.education.required_level)}</p>
          <p>Assessment: {displayValue(program.eligibility.education.credential_assessment_required)}</p>
          <p class="prose muted">{program.eligibility.education.note_md?.en}</p>
        </article>
        <article class="card">
          <h3 class="card-title">Selection threshold</h3>
          <p>Points: {displayValue(program.eligibility.points_threshold)}</p>
          <p>Competition: {displayValue(program.eligibility.invitation_competition_level)}</p>
        </article>
        <article class="card">
          <h3 class="card-title">Health and character</h3>
          <p>Health check: {displayValue(program.eligibility.health_check_required)}</p>
          <p>Police certificate: {displayValue(program.eligibility.police_certificate_required)}</p>
        </article>
      </div>
    </section>

    <section class="section" aria-labelledby="funds-heading">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Costs</p>
          <h2 id="funds-heading">Funds and fees</h2>
        </div>
      </div>
      <div class="card-grid two">
        <article class="card">
          <h3 class="card-title">Settlement funds</h3>
          {
            hasFundsTable ? (
              <div class="table-wrap">
                <table class="table">
                  <thead>
                    <tr>
                      <th>Family size</th>
                      <th>Minimum funds</th>
                    </tr>
                  </thead>
                  <tbody>
                    {program.funds.proof_of_funds.map((requirement) => (
                      <tr>
                        <td>
                          {requirement.calculation === "increment_per_additional_member"
                            ? `Each member after ${requirement.family_size_above}`
                            : requirement.family_size}
                        </td>
                        <td>
                          {displayValue(requirement.amount)} {requirement.currency}
                        </td>
                      </tr>
                    ))}
                  </tbody>
                </table>
              </div>
            ) : (
              <p class="prose">No settlement-fund table is published.</p>
            )
          }
          <p class="prose muted">{program.funds.exemption_note_md?.en}</p>
        </article>
        <article class="card">
          <h3 class="card-title">Application fees</h3>
          {
            applicationFees.length ? (
              <ul class="detail-list">
                {applicationFees.map((fee) => (
                  <li>
                    <strong>{displayValue(fee.amount)} {fee.currency}</strong>
                    <span>{fee.label?.en ?? fee.applies_to}</span>
                  </li>
                ))}
              </ul>
            ) : (
              <p class="prose">No fee table is published.</p>
            )
          }
        </article>
      </div>
    </section>

    <section class="section" aria-labelledby="outcome-heading">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Outcomes</p>
          <h2 id="outcome-heading">Residence, work, and family</h2>
        </div>
      </div>
      <div class="card-grid">
        <article class="card">
          <h3 class="card-title">Permanent residence</h3>
          <p class="prose">{program.pr_pathway.summary_md?.en}</p>
          <p>Work: {displayValue(program.rights.work_allowed)} · Study: {displayValue(program.rights.study_allowed)}</p>
        </article>
        <article class="card">
          <h3 class="card-title">Family</h3>
          <p class="prose">{program.family.note_md?.en}</p>
          <p>Partner: {displayValue(program.family.spouse_or_partner_allowed)} · Children: {displayValue(program.family.children_allowed)}</p>
        </article>
        <article class="card">
          <h3 class="card-title">Citizenship</h3>
          <p class="prose">{program.citizenship_pathway.summary_md?.en}</p>
        </article>
        <article class="card">
          <h3 class="card-title">Processing time</h3>
          <p class="prose">{program.timeline.application_processing_time_md?.en}</p>
          <p>Modeled: {displayValue(program.timeline.processing_time_months_min)}–{displayValue(program.timeline.processing_time_months_max)} months</p>
        </article>
      </div>
    </section>

    <section class="section" aria-labelledby="sources-heading">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Sources</p>
          <h2 id="sources-heading">Official sources</h2>
        </div>
      </div>
      <div class="card-grid">
        {
          sources.map((source) => (
            <a class="card card-clickable" href={source.url} target="_blank" rel="noopener noreferrer">
              <p class="card-meta">{source.publisher}</p>
              <h3 class="card-title">{source.title}</h3>
              <div class="card-footer">
                <span class="card-tag">Checked {source.last_checked_at?.slice(0, 10)}</span>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <section class="section" aria-labelledby="evidence-heading">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Citations</p>
          <h2 id="evidence-heading">Field provenance</h2>
        </div>
      </div>
      <div class="card-grid">
        {
          citations.map(({ path, citations: refs }) => (
            <article class="card">
              <p class="card-meta mono">{path}</p>
              {refs.map((ref) => (
                <div class="citation-block">
                  <h3 class="card-title">
                    <a href={ref.url} target="_blank" rel="noopener noreferrer">
                      {ref.section ?? ref.source_id}
                    </a>
                  </h3>
                  {ref.quote_md && <p class="quote">"{ref.quote_md}"</p>}
                </div>
              ))}
            </article>
          ))
        }
      </div>
    </section>

    <section class="panel" aria-label="Informational disclaimer">
      <p>
        <strong>Information only, not legal advice.</strong> Rules, fees, and processing times change.
        Verify the linked official pages before acting.
      </p>
    </section>
  </main>
</Layout>
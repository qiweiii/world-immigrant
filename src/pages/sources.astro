---
import Layout from "../components/Layout.astro";
import { loadCanonicalData } from "../lib/data";

const { sources } = await loadCanonicalData();
---

<Layout title="Sources — World Immigrant">
  <main>
    <section class="hero">
      <p class="eyebrow">Trust surface</p>
      <h1>Freshness and citations<br />are part of the product.</h1>
      <p>
        The source registry exposes official URLs, check cadence, extraction method, status, and
        the programs each source supports.
      </p>
    </section>

    <section class="section" aria-labelledby="registry-heading">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Registry</p>
          <h2 id="registry-heading">{sources.length} official sources</h2>
        </div>
      </div>
      <div class="card-grid">
        {
          sources.map((source) => (
            <article class="card">
              <p class="eyebrow">Priority {source.priority} · {source.status}</p>
              <h3><a href={source.url} rel="external">{source.title}</a></h3>
              <p>{source.publisher}</p>
              <div class="badge-row">
                <span class="badge">checked {source.last_checked_at?.slice(0, 10)}</span>
                <span class="badge">every {source.update_frequency_days} days</span>
                <span class="badge">{source.extraction_method}</span>
              </div>
            </article>
          ))
        }
      </div>
    </section>

    <section class="card-grid" aria-label="Source policy">
      <article class="card">
        <p class="eyebrow">Hierarchy</p>
        <h3>Official evidence first</h3>
        <p>Law and regulation text, immigration-department pages, official portals and calculators, then clearly labeled supporting sources.</p>
      </article>
      <article class="card">
        <p class="eyebrow">Validation</p>
        <h3>No uncited material claims</h3>
        <p>Active program records fail integrity validation when a material fact cannot be traced to a registered source.</p>
      </article>
    </section>
  </main>
</Layout>

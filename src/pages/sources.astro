---
import Layout from "../components/Layout.astro";
import { loadCanonicalData } from "../lib/data";

const { sources } = await loadCanonicalData();
---

<Layout title="Sources — World Immigrant">
  <main>
    <section class="hero">
      <p class="eyebrow">Sources</p>
      <h1>Where every summary starts.</h1>
      <p>The government pages behind each pathway record.</p>
    </section>

    <section class="section" aria-labelledby="registry-heading">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Registry</p>
          <h2 id="registry-heading">{sources.length} official sources</h2>
        </div>
      </div>
      <div class="card-grid">
        {
          sources.map((source) => (
            <a class="card card-clickable" href={source.url} target="_blank" rel="noopener noreferrer">
              <p class="card-meta">{source.publisher}</p>
              <h3 class="card-title">{source.title}</h3>
              <div class="card-footer">
                <span class="card-tag">Checked {source.last_checked_at?.slice(0, 10)}</span>
                <span class="card-tag">Every {source.update_frequency_days} days</span>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <section class="card-grid" aria-label="Source policy">
      <article class="card">
        <h3 class="card-title">Official evidence first</h3>
        <p class="card-description">Law and regulation text, immigration-department pages, official portals and calculators, then clearly labeled supporting sources.</p>
      </article>
      <article class="card">
        <h3 class="card-title">No uncited material claims</h3>
        <p class="card-description">Active program records fail integrity validation when a material fact cannot be traced to a registered source.</p>
      </article>
    </section>
  </main>
</Layout>
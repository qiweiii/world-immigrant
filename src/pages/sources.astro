---
import Layout from "../components/Layout.astro";
---

<Layout title="Sources — World Immigrant">
  <main>
    <section class="hero">
      <p class="eyebrow">Trust surface</p>
      <h1>Freshness and citations<br />are part of the product.</h1>
      <p>
        Source registry pages will show official URLs, last checked dates, extraction methods,
        source confidence, and change history.
      </p>
    </section>
    <section class="grid stagger">
      <article class="card">
        <div class="card-header">
          <img src="https://cdn.simpleicons.org/verified/2563eb" alt="" width="20" height="20" style="width:20px;height:20px;margin-bottom:8px;" />
          <h3 class="card-title">Source hierarchy</h3>
        </div>
        <ul style="color:var(--muted-foreground);font-size:14px;line-height:1.8;padding-left:18px;margin:8px 0 0;">
          <li>Law/regulation text</li>
          <li>Official immigration department pages</li>
          <li>Official application portals and calculators</li>
          <li>Embassy/consulate pages</li>
          <li>Labeled reputable secondary sources</li>
        </ul>
      </article>
      <article class="card">
        <div class="card-header">
          <img src="https://cdn.simpleicons.org/shieldcheck/2563eb" alt="" width="20" height="20" style="width:20px;height:20px;margin-bottom:8px;" />
          <h3 class="card-title">Validation rule</h3>
        </div>
        <p class="card-description">
          Active programs should fail validation when material fields lack source citations
          or freshness metadata.
        </p>
      </article>
    </section>
  </main>
</Layout>
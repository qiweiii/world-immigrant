---
import Layout from "../components/Layout.astro";
import { loadCanonicalData } from "../lib/data";
import { defaultLocale, pickLocalized, regionLabel, t, tf, withLocale, type Locale } from "../i18n";

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props as Props;
const dataset = await loadCanonicalData();
const { sources, countries, programs, categories } = dataset;
const L = (path: string) => withLocale(path, locale);

const categoryById = new Map(categories.map((category) => [category.id, category]));
const programById = new Map(programs.map((program) => [program.id, program]));

const countryGroups = countries.map((country) => {
  const countryPrograms = programs
    .filter((program) => program.country_id === country.id)
    .map((program) => {
      const programSources = sources.filter((source) => source.program_ids.includes(program.id));
      const programCategories = program.category_ids
        .map((id) => categoryById.get(id))
        .filter((item): item is (typeof categories)[number] => Boolean(item));
      return { program, programSources, programCategories };
    })
    .filter(({ programSources }) => programSources.length > 0);

  const unassigned = sources.filter(
    (source) =>
      source.country_id === country.id &&
      (source.program_ids.length === 0 ||
        source.program_ids.every((id) => !programById.has(id))),
  );

  return { country, countryPrograms, unassigned };
});
---

<Layout
  locale={locale}
  title={t("sources.title", locale)}
  description={t("sources.lede", locale)}
  pageType="CollectionPage"
>
  <main>
    <section class="hero">
      <p class="eyebrow">{t("sources.eyebrow", locale)}</p>
      <h1>{t("sources.h1", locale)}</h1>
      <p>{t("sources.lede", locale)}</p>
    </section>

    <section class="section" aria-labelledby="registry-heading">
      <div class="section-heading">
        <div>
          <p class="eyebrow">{t("sources.registry", locale)}</p>
          <h2 id="registry-heading">
            {sources.length} {t("sources.officialSources", locale)}
          </h2>
        </div>
      </div>

      <div class="source-tree">
        {
          countryGroups.map(({ country, countryPrograms, unassigned }) => (
            <section class="source-country" style={`--country-color: ${country.brand.color}`}>
              <header class="source-country-header">
                <span class="country-swatch" aria-hidden="true"></span>
                <div>
                  <h3>{pickLocalized(country.names, locale)}</h3>
                  <p class="card-meta">
                    {country.iso2} · {regionLabel(country.region, locale)}
                  </p>
                </div>
              </header>

              {
                countryPrograms.map(({ program, programSources, programCategories }) => (
                  <div class="source-program">
                    <div class="source-program-header">
                      <div>
                        <p class="source-program-cats">
                          {programCategories
                            .map((category) => pickLocalized(category.names, locale))
                            .join(" · ") || t("sources.general", locale)}
                        </p>
                        <h4>
                          <a href={L(`/programs/${program.id}`)}>
                            {pickLocalized(program.official_names, locale)}
                          </a>
                        </h4>
                      </div>
                      <span class="card-tag">
                        {tf(
                          programSources.length === 1
                            ? "sources.sourceCount"
                            : "sources.sourcesCount",
                          locale,
                          { count: programSources.length },
                        )}
                      </span>
                    </div>
                    <ul class="source-link-list">
                      {programSources.map((source) => (
                        <li>
                          <a
                            class="source-link-row"
                            href={source.url}
                            target="_blank"
                            rel="noopener noreferrer"
                          >
                            <span class="source-link-main">
                              <strong>{source.title}</strong>
                              <small>{source.publisher}</small>
                            </span>
                            <span class="source-link-meta">
                              <span>
                                {t("sources.checked", locale)}{" "}
                                {source.last_checked_at?.slice(0, 10) ?? "—"}
                              </span>
                              <span>
                                {t("sources.every", locale)} {source.update_frequency_days}{" "}
                                {t("sources.days", locale)}
                              </span>
                            </span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                ))
              }

              {
                unassigned.length > 0 && (
                  <div class="source-program">
                    <div class="source-program-header">
                      <div>
                        <p class="source-program-cats">{t("sources.countryLevel", locale)}</p>
                        <h4>{t("sources.otherRegistered", locale)}</h4>
                      </div>
                    </div>
                    <ul class="source-link-list">
                      {unassigned.map((source) => (
                        <li>
                          <a
                            class="source-link-row"
                            href={source.url}
                            target="_blank"
                            rel="noopener noreferrer"
                          >
                            <span class="source-link-main">
                              <strong>{source.title}</strong>
                              <small>{source.publisher}</small>
                            </span>
                            <span class="source-link-meta">
                              <span>
                                {t("sources.checked", locale)}{" "}
                                {source.last_checked_at?.slice(0, 10) ?? "—"}
                              </span>
                            </span>
                          </a>
                        </li>
                      ))}
                    </ul>
                  </div>
                )
              }
            </section>
          ))
        }
      </div>
    </section>

    <section class="card-grid two" aria-label={t("sources.registry", locale)}>
      <article class="card">
        <h3 class="card-title">{t("sources.officialFirst", locale)}</h3>
        <p class="card-description">{t("sources.officialFirstBody", locale)}</p>
      </article>
      <article class="card">
        <h3 class="card-title">{t("sources.noUncited", locale)}</h3>
        <p class="card-description">{t("sources.noUncitedBody", locale)}</p>
      </article>
    </section>
  </main>
</Layout>

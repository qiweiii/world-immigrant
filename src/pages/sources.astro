---
import Layout from "../components/Layout.astro";
import { loadCanonicalData } from "../lib/data";
import { defaultLocale, t, type Locale } from "../i18n";

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props as Props;
const { sources } = await loadCanonicalData();
---

<Layout locale={locale} title={t("sources.title", locale)}>
  <main>
    <section class="hero">
      <p class="eyebrow">{t("sources.eyebrow", locale)}</p>
      <h1>{t("sources.h1", locale)}</h1>
      <p>{t("sources.lede", locale)}</p>
    </section>

    <section class="section" aria-labelledby="registry-heading">
      <div class="section-heading">
        <div>
          <p class="eyebrow">{t("sources.registry", locale)}</p>
          <h2 id="registry-heading">
            {sources.length} {t("sources.officialSources", locale)}
          </h2>
        </div>
      </div>
      <div class="card-grid">
        {
          sources.map((source) => (
            <a class="card card-clickable" href={source.url} target="_blank" rel="noopener noreferrer">
              <p class="card-meta">{source.publisher}</p>
              <h3 class="card-title">{source.title}</h3>
              <div class="card-footer">
                <span class="card-tag">
                  {t("sources.checked", locale)} {source.last_checked_at?.slice(0, 10)}
                </span>
                <span class="card-tag">
                  {t("sources.every", locale)} {source.update_frequency_days}{" "}
                  {t("sources.days", locale)}
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <section class="card-grid" aria-label={t("sources.registry", locale)}>
      <article class="card">
        <h3 class="card-title">{t("sources.officialFirst", locale)}</h3>
        <p class="card-description">{t("sources.officialFirstBody", locale)}</p>
      </article>
      <article class="card">
        <h3 class="card-title">{t("sources.noUncited", locale)}</h3>
        <p class="card-description">{t("sources.noUncitedBody", locale)}</p>
      </article>
    </section>
  </main>
</Layout>

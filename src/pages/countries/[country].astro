---
import Layout from "../../components/Layout.astro";
import VisaCard from "../../components/VisaCard.astro";
import { loadCanonicalData } from "../../lib/data";
import { buildCountryPageModels, type CountryPageModel } from "../../lib/site-model";
import { breadcrumbJsonLd } from "../../lib/seo";
import { defaultLocale, pickLocalized, regionLabel, t, withLocale, type Locale } from "../../i18n";

interface Props {
  model: CountryPageModel;
  locale?: Locale;
}

export async function getStaticPaths() {
  const models = buildCountryPageModels(await loadCanonicalData());
  return models.map((model) => ({ params: { country: model.country.id }, props: { model } }));
}

const { model, locale = defaultLocale } = Astro.props as Props;
const { country, programs, categories } = model;
const L = (path: string) => withLocale(path, locale);
const countryName = pickLocalized(country.names, locale);
const countrySummary = pickLocalized(country.summary_md, locale);
const structuredData = [
  breadcrumbJsonLd([
    { name: t("crumb.home", locale), path: L("/") },
    { name: t("nav.countries", locale), path: L("/countries") },
    { name: countryName, path: L(`/countries/${country.id}`) },
  ]),
];
---

<Layout
  locale={locale}
  title={`${countryName} ${t("country.pathwaysTitle", locale)}`}
  description={countrySummary}
  dateModified={country.freshness.last_checked_at}
  structuredData={structuredData}
>
  <main>
    <nav class="breadcrumbs" aria-label={t("crumb.aria", locale)}>
      <a href={L("/")}>{t("crumb.home", locale)}</a>
      <span aria-hidden="true">/</span>
      <a href={L("/countries")}>{t("nav.countries", locale)}</a>
      <span aria-hidden="true">/</span>
      <span>{countryName}</span>
    </nav>

    <section class="hero country-hero" style={`--country-color: ${country.brand.color}`}>
      <p class="eyebrow">
        <span class="country-swatch" aria-hidden="true"></span>
        {country.iso2} · {regionLabel(country.region, locale)}
      </p>
      <h1>{countryName}</h1>
      <p>{pickLocalized(country.summary_md, locale)}</p>
      <div class="action-row">
        <a class="btn" href={L("/compare")}>{t("country.compare", locale)}</a>
        <a class="btn btn-ghost" href={L("/filter")}>{t("country.checkFit", locale)}</a>
      </div>
    </section>

    <section class="section" aria-labelledby="pathways-heading">
      <div class="section-heading">
        <div>
          <p class="eyebrow">{t("country.pathways", locale)}</p>
          <h2 id="pathways-heading">{t("country.programs", locale)}</h2>
        </div>
      </div>
      <div class="card-grid">
        {
          programs.map((program) => (
            <VisaCard
              locale={locale}
              title={pickLocalized(program.official_names, locale)}
              country={countryName}
              category={program.category_ids
                .map((id) => categories.find((category) => category.id === id))
                .filter((category) => category !== undefined)
                .map((category) => pickLocalized(category.names, locale))
                .join(", ")}
              summary={pickLocalized(program.summary_md, locale)}
              href={L(`/programs/${program.id}`)}
              status={program.status}
              checkedAt={program.freshness.last_checked_at}
            />
          ))
        }
      </div>
    </section>

    <section class="section" aria-labelledby="categories-heading">
      <div class="section-heading">
        <div>
          <p class="eyebrow">{t("country.categories", locale)}</p>
          <h2 id="categories-heading">{t("country.related", locale)}</h2>
        </div>
      </div>
      <div class="card-grid">
        {
          categories.map((category) => (
            <a class="card card-clickable" href={L(`/categories/${category.id}`)}>
              <h3 class="card-title">{pickLocalized(category.names, locale)}</h3>
              <p class="card-description">{pickLocalized(category.description_md, locale)}</p>
            </a>
          ))
        }
      </div>
    </section>
  </main>
</Layout>

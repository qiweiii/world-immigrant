---
import Layout from "../../components/Layout.astro";
import VisaCard from "../../components/VisaCard.astro";
import { loadCanonicalData } from "../../lib/data";
import { buildCountryPageModels } from "../../lib/site-model";
import { defaultLocale, pickLocalized, t, withLocale, type Locale } from "../../i18n";

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props as Props;
const countries = buildCountryPageModels(await loadCanonicalData());
const L = (path: string) => withLocale(path, locale);
---

<Layout locale={locale} title={t("countries.title", locale)}>
  <main>
    <nav class="breadcrumbs" aria-label={t("crumb.aria", locale)}>
      <a href={L("/")}>{t("crumb.home", locale)}</a>
      <span aria-hidden="true">/</span>
      <span>{t("countries.eyebrow", locale)}</span>
    </nav>

    <section class="hero">
      <p class="eyebrow">{t("countries.eyebrow", locale)}</p>
      <h1>{t("countries.h1", locale)}</h1>
      <p>{t("countries.lede", locale)}</p>
      <div class="action-row">
        <a class="btn btn-primary" href={L("/filter")}>{t("countries.findMatching", locale)}</a>
        <a class="btn" href={L("/compare")}>{t("countries.compare", locale)}</a>
      </div>
    </section>

    <section class="section" aria-labelledby="countries-heading">
      <div class="section-heading">
        <div>
          <p class="eyebrow">{t("countries.coverage", locale)}</p>
          <h2 id="countries-heading">{t("countries.h2", locale)}</h2>
        </div>
      </div>
      <div class="card-grid">
        {
          countries.map(({ country, programs }) => (
            <a
              class="card card-clickable country-card"
              href={L(`/countries/${country.id}`)}
              style={`--country-color: ${country.brand.color}`}
            >
              <p class="card-meta">
                <span class="country-swatch" aria-hidden="true"></span>
                {country.iso2} · {country.region}
              </p>
              <h3 class="card-title">{pickLocalized(country.names, locale)}</h3>
              <p class="card-description">{pickLocalized(country.summary_md, locale)}</p>
              <div class="card-footer">
                <span class="card-tag">
                  {programs.length}{" "}
                  {programs.length === 1
                    ? t("home.pathwayCount", locale)
                    : t("home.pathwaysCount", locale)}
                </span>
                <span class="card-tag">
                  {t("countries.checked", locale)} {country.freshness.last_checked_at.slice(0, 10)}
                </span>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <section class="section" aria-labelledby="programs-heading">
      <div class="section-heading">
        <div>
          <p class="eyebrow">{t("countries.pathways", locale)}</p>
          <h2 id="programs-heading">{t("countries.allPrograms", locale)}</h2>
        </div>
      </div>
      <div class="card-grid">
        {
          countries.flatMap(({ country, programs }) =>
            programs.map((program) => (
              <VisaCard
                title={pickLocalized(program.official_names, locale)}
                country={pickLocalized(country.names, locale)}
                category={program.category_ids.join(", ")}
                summary={pickLocalized(program.summary_md, locale)}
                href={L(`/programs/${program.id}`)}
                status={program.status}
                checkedAt={program.freshness.last_checked_at}
              />
            )),
          )
        }
      </div>
    </section>
  </main>
</Layout>

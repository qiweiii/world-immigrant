---
import Layout from "../../components/Layout.astro";
import VisaCard from "../../components/VisaCard.astro";
import { loadCanonicalData } from "../../lib/data";
import { buildCountryPageModels } from "../../lib/site-model";

const countries = buildCountryPageModels(await loadCanonicalData());
---

<Layout title="Countries — World Immigrant">
  <main>
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span>Countries</span>
    </nav>

    <section class="hero">
      <p class="eyebrow">Country coverage</p>
      <h1>Start with the destination, then inspect the route.</h1>
      <p>
        Each country page gathers the pathways currently mapped there, the decision details that
        differ between them, and the official pages behind the summary.
      </p>
      <div class="action-row">
        <a class="btn btn-primary" href="/filter">Filter locally</a>
        <a class="btn" href="/compare">Compare programs</a>
      </div>
    </section>

    <section class="section" aria-labelledby="countries-heading">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Current coverage</p>
          <h2 id="countries-heading">Countries with mapped pathways</h2>
        </div>
      </div>
      <div class="card-grid">
        {
          countries.map(({ country, programs }) => (
            <article class="card">
              <p class="eyebrow">
                {country.iso2} · {country.region}
              </p>
              <h3 class="card-title">
                <a href={`/countries/${country.id}`}>{country.names.en}</a>
              </h3>
              <p class="card-description">{country.summary_md.en}</p>
              <div class="badge-row">
                <span class="badge">
                  {programs.length} pathway record{programs.length === 1 ? "" : "s"}
                </span>
                <span class="badge">checked {country.freshness.last_checked_at.slice(0, 10)}</span>
              </div>
              <p class="card-cta">
                <a href={`/countries/${country.id}`}>Open country →</a>
              </p>
            </article>
          ))
        }
      </div>
    </section>

    <section class="section" aria-labelledby="programs-heading">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Current pathways</p>
          <h2 id="programs-heading">What you can explore now</h2>
        </div>
      </div>
      <div class="card-grid">
        {
          countries.flatMap(({ country, programs }) =>
            programs.map((program) => (
              <VisaCard
                title={program.official_names.en}
                country={country.names.en}
                category={program.category_ids.join(", ")}
                summary={program.summary_md.en}
                href={`/programs/${program.id}`}
                status={program.status}
                needsReview={program.freshness.needs_human_review}
                checkedAt={program.freshness.last_checked_at}
              />
            )),
          )
        }
      </div>
    </section>
  </main>
</Layout>

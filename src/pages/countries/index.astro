---
import Layout from "../../components/Layout.astro";
import VisaCard from "../../components/VisaCard.astro";
import { loadCanonicalData } from "../../lib/data";
import { buildCountryPageModels } from "../../lib/site-model";

const countries = buildCountryPageModels(await loadCanonicalData());
---

<Layout title="Countries — World Immigrant">
  <main>
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span>Countries</span>
    </nav>

    <section class="hero">
      <p class="eyebrow">Countries</p>
      <h1>Explore by destination.</h1>
      <p>See which countries have mapped pathways and open the one you're interested in.</p>
      <div class="action-row">
        <a class="btn btn-primary" href="/filter">Find matching pathways</a>
        <a class="btn" href="/compare">Compare</a>
      </div>
    </section>

    <section class="section" aria-labelledby="countries-heading">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Coverage</p>
          <h2 id="countries-heading">Countries</h2>
        </div>
      </div>
      <div class="card-grid">
        {
          countries.map(({ country, programs }) => (
            <a class="card card-clickable" href={`/countries/${country.id}`}>
              <p class="card-meta">{country.iso2} · {country.region}</p>
              <h3 class="card-title">{country.names.en}</h3>
              <p class="card-description">{country.summary_md.en}</p>
              <div class="card-footer">
                <span class="card-tag">{programs.length} pathway{programs.length === 1 ? "" : "s"}</span>
                <span class="card-tag">Checked {country.freshness.last_checked_at.slice(0, 10)}</span>
              </div>
            </a>
          ))
        }
      </div>
    </section>

    <section class="section" aria-labelledby="programs-heading">
      <div class="section-heading">
        <div>
          <p class="eyebrow">Pathways</p>
          <h2 id="programs-heading">All programs</h2>
        </div>
      </div>
      <div class="card-grid">
        {
          countries.flatMap(({ country, programs }) =>
            programs.map((program) => (
              <VisaCard
                title={program.official_names.en}
                country={country.names.en}
                category={program.category_ids.join(", ")}
                summary={program.summary_md.en}
                href={`/programs/${program.id}`}
                status={program.status}
                checkedAt={program.freshness.last_checked_at}
              />
            )),
          )
        }
      </div>
    </section>
  </main>
</Layout>
---
import { isLocale, nonDefaultLocales } from "../../../i18n";
import CountriesPage from "../../countries/index.astro";

export function getStaticPaths() {
  return nonDefaultLocales.map((locale) => ({ params: { locale } }));
}

const { locale } = Astro.params;
if (!isLocale(locale)) throw new Error(`Unsupported locale: ${locale}`);
---

<CountriesPage locale={locale} />

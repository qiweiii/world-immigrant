---
import Layout from "../components/Layout.astro";
import EligibilityFilter from "../components/islands/EligibilityFilter.astro";
---

<Layout title="Filter immigration options — World Immigrant">
  <main>
    <section class="hero">
      <p class="eyebrow">Privacy-preserving matching</p>
      <h1>Filter options locally,<br />then verify every claim.</h1>
      <p>
        The filter engine classifies programs as likely match, possible match, not match,
        needs review, or unknown — with reasons and citations.
      </p>
    </section>
    <EligibilityFilter />
  </main>
</Layout>
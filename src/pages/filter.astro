---
import Layout from "../components/Layout.astro";
import EligibilityFilter from "../components/islands/EligibilityFilter.astro";
import { defaultLocale, t, type Locale } from "../i18n";

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props as Props;
---

<Layout locale={locale} title={t("filter.title", locale)}>
  <main>
    <section class="hero">
      <p class="eyebrow">{t("filter.eyebrow", locale)}</p>
      <h1>{t("filter.h1", locale)}</h1>
      <p>{t("filter.lede", locale)}</p>
    </section>
    <EligibilityFilter />
  </main>
</Layout>

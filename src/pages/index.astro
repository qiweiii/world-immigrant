---
import Layout from "../components/Layout.astro";
import { loadCanonicalData } from "../lib/data";
import { buildCountryPageModels } from "../lib/site-model";

const dataset = await loadCanonicalData();
const { programs, countries, sources } = dataset;
const countryModels = buildCountryPageModels(dataset);
const programCards = programs.map((program) => {
  const country = countries.find((item) => item.id === program.country_id);
  return { program, country };
});
const compareHref =
  programs.length > 1 ? `/compare?programs=${programs.map(({ id }) => id).join(",")}` : "/compare";
const shorten = (value: string, maxLength: number) => {
  if (value.length <= maxLength) return value;
  return `${value.slice(0, maxLength).replace(/\s+\S*$/, "")}…`;
};
---

<Layout
  title="World Immigrant — source-cited immigration pathways"
  description="Compare immigration pathways with official sources, current coverage, and a private local fit check."
>
  <main>
    <section class="landing-hero" aria-labelledby="home-title">
      <div class="landing-hero-copy">
        <p class="eyebrow">World Immigrant</p>
        <h1 id="home-title">Find a route you can verify.</h1>
        <p class="landing-lede">
          Structured immigration pathways, linked to official sources.
        </p>
        <div class="action-row">
          <a class="btn btn-primary" href="#pathways">View pathways</a>
          <a class="text-action" href={compareHref}>Compare →</a>
        </div>
      </div>

      <aside class="coverage-panel" aria-label="Current coverage">
        <p class="eyebrow">Coverage</p>
        <p class="coverage-total"><strong>{programs.length}</strong> pathways</p>
        <div class="coverage-country-list">
          {
            countryModels.map(({ country, programs: countryPrograms }) => (
              <a class="coverage-country" href={`/countries/${country.id}`}>
                <span>
                  <strong>{country.names.en}</strong>
                  <small>{countryPrograms.length} pathway{countryPrograms.length === 1 ? "" : "s"}</small>
                </span>
                <span aria-hidden="true">→</span>
              </a>
            ))
          }
        </div>
        <div class="coverage-footnote">
          <span>{sources.length} sources</span>
          <a href="/sources">Source registry</a>
        </div>
      </aside>
    </section>

    <nav class="quick-actions" aria-label="Start here">
      <a class="quick-action" href="/countries"><span>01</span> Browse destinations</a>
      <a class="quick-action" href={compareHref}><span>02</span> Compare pathways</a>
      <a class="quick-action" href="/filter"><span>03</span> Check fit privately</a>
    </nav>

    <section class="section pathway-section" id="pathways" aria-labelledby="pathways-heading">
      <div class="section-heading section-heading-wide">
        <div>
          <p class="eyebrow">Available now</p>
          <h2 id="pathways-heading">Pathways</h2>
        </div>
        <a class="text-action" href="/countries">All destinations →</a>
      </div>
      <div class="pathway-list">
        {
          programCards.map(({ program, country }) => (
            <article class="pathway-row">
              <div class="pathway-row-main">
                <p class="card-meta">
                  {country?.names.en ?? program.country_id} · {program.category_ids.join(" ").replaceAll("_", " ")}
                </p>
                <h3><a href={`/programs/${program.id}`}>{program.official_names.en}</a></h3>
                <p>{shorten(program.summary_md.en, 155)}</p>
              </div>
              <dl class="pathway-facts">
                <div>
                  <dt>Residence</dt>
                  <dd>{program.pr_pathway.available === true ? "Direct PR" : "See pathway"}</dd>
                </div>
                <div>
                  <dt>Family</dt>
                  <dd>{program.family.spouse_or_partner_allowed === true ? "Yes" : "See rules"}</dd>
                </div>
                <div>
                  <dt>Checked</dt>
                  <dd>{program.freshness.last_checked_at.slice(0, 10)}</dd>
                </div>
              </dl>
              <a class="pathway-row-link" href={`/programs/${program.id}`}>Read →</a>
            </article>
          ))
        }
      </div>
      <div class="section-actions">
        <a class="btn" href={compareHref}>Compare both</a>
        <a class="text-action" href="/filter">Check fit →</a>
      </div>
    </section>

    <section class="coverage-section" aria-labelledby="countries-heading">
      <div class="section-heading section-heading-wide">
        <div>
          <p class="eyebrow">Destinations</p>
          <h2 id="countries-heading">By country</h2>
        </div>
      </div>
      <div class="country-list">
        {
          countryModels.map(({ country, programs: countryPrograms }) => (
            <article class="country-row">
              <div>
                <p class="card-meta">{country.iso2} · {country.region}</p>
                <h3><a href={`/countries/${country.id}`}>{country.names.en}</a></h3>
              </div>
              <p>{shorten(country.summary_md.en, 140)}</p>
              <div class="country-row-meta">
                <span>{countryPrograms.length} pathway{countryPrograms.length === 1 ? "" : "s"}</span>
                <span>checked {country.freshness.last_checked_at.slice(0, 10)}</span>
              </div>
              <a class="text-action" href={`/countries/${country.id}`}>Open →</a>
            </article>
          ))
        }
      </div>
    </section>

    <section class="source-note" aria-label="Source guidance">
      <p><strong>Policy changes.</strong> Every record carries a check date and source trail.</p>
      <a class="text-action" href="/sources">Inspect sources →</a>
    </section>
  </main>
</Layout>
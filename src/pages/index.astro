---
import Layout from "../components/Layout.astro";
import TrustBadge from "../components/TrustBadge.astro";
import { loadCanonicalData } from "../lib/data";

const { categories } = await loadCanonicalData();
---

<Layout
  title="World Immigrant — source-cited global mobility options"
  description="Compare lawful immigration pathways across countries with citations, freshness, and local-first filtering."
>
  <main>
    <section class="hero">
      <p class="eyebrow">Public-good global mobility infrastructure</p>
      <h1>Build your Plan A,<br />Plan B, and Plan C.</h1>
      <p>
        Source-cited, multilingual, AI-readable immigration pathway database for people who need
        realistic multi-destination options in a changing world.
      </p>
      <div style="display:flex;flex-wrap:wrap;gap:10px;margin-top:24px;">
        <a class="btn btn-primary" href="/filter">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><path d="M4 21v-7"/><path d="M4 10V3"/><path d="M12 21v-9"/><path d="M12 8V3"/><path d="M20 21v-5"/><path d="M20 12V3"/><path d="M1 14h6"/><path d="M9 8h6"/><path d="M17 16h6"/></svg>
          Start filtering
        </a>
        <a class="btn" href="/compare">
          <svg aria-hidden="true" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="m16 3 4 4-4 4"/><path d="M20 7H4"/><path d="m8 21-4-4 4-4"/><path d="M4 17h16"/></svg>
          Compare pathways
        </a>
        <a class="btn btn-ghost" href="/sources">Source model</a>
      </div>
      <div class="badge-row">
        <TrustBadge label="official-source first" tone="success" />
        <TrustBadge label="local-first profile" />
        <TrustBadge label="not legal advice" tone="warning" />
      </div>
    </section>

    <section class="section-header">
      <p class="eyebrow">Browse by category</p>
      <h2>Every pathway, sourced and structured.</h2>
      <p>Each category links to country-specific programs with eligibility, costs, timelines, and official citations.</p>
    </section>

    <section class="grid stagger" aria-label="Core categories">
      {
        categories.map((cat) => (
          <article class="card">
            <div class="card-header">
              <p class="eyebrow" style="margin:0 0 4px;">Global pathways</p>
              <h3 class="card-title"><a href={`/categories/${cat.id}`}>{cat.names.en}</a></h3>
            </div>
            <p class="card-description">{cat.description_md.en}</p>
            <div class="badge-row">
              <span class="badge">source-first</span>
              <span class="badge">structured</span>
            </div>
          </article>
        ))
      }
    </section>
  </main>
</Layout>
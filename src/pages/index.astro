---
import Layout from "../components/Layout.astro";
import { loadCanonicalData } from "../lib/data";
import { buildCountryPageModels } from "../lib/site-model";
import { defaultLocale, pickLocalized, regionLabel, t, withLocale, type Locale } from "../i18n";

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props as Props;
const dataset = await loadCanonicalData();
const { programs, countries, sources, categories } = dataset;
const countryModels = buildCountryPageModels(dataset);
const programCards = programs.map((program) => {
  const country = countries.find((item) => item.id === program.country_id);
  return { program, country };
});
const bareCompare =
  programs.length > 1 ? `/compare?programs=${programs.map(({ id }) => id).join(",")}` : "/compare";
const compareHref = withLocale(bareCompare, locale);
const shorten = (value: string, maxLength: number) => {
  if (value.length <= maxLength) return value;
  return `${value.slice(0, maxLength).replace(/\s+\S*$/, "")}…`;
};
const L = (path: string) => withLocale(path, locale);
const visibleCount = 4;

const categoryColors: Record<string, string> = {
  digital_nomad: "#0ea5e9",
  skilled_worker: "#2563eb",
  study_to_pr: "#8b5cf6",
  startup_entrepreneur: "#f59e0b",
  investor: "#10b981",
  family: "#ec4899",
  retirement: "#14b8a6",
  e_residency: "#6366f1",
  humanitarian: "#ef4444",
  other: "#64748b",
};

// Popular countries first on the home page
const popularCountryIds = [
  "canada",
  "australia",
  "united-kingdom",
  "united-states",
  "germany",
  "japan",
  "singapore",
  "uae",
  "netherlands",
  "new-zealand",
  "portugal",
  "spain",
  "hong-kong",
  "croatia",
  "estonia",
];
const popularityOrder = (id: string) => {
  const idx = popularCountryIds.indexOf(id);
  return idx === -1 ? 999 : idx;
};
const sortedCountryModels = [...countryModels].sort(
  (a, b) => popularityOrder(a.country.id) - popularityOrder(b.country.id),
);
// Sort pathway cards to match country popularity
const pathwayPopularity = (card: { program: { country_id: string } }) =>
  popularityOrder(card.program.country_id);
const sortedProgramCards = [...programCards].sort(
  (a, b) => pathwayPopularity(a) - pathwayPopularity(b),
);
---

<Layout locale={locale} title={t("home.title", locale)} description={t("home.description", locale)}>
  <main>
    <section class="landing-hero" aria-labelledby="home-title">
      <div class="landing-hero-copy">
        <p class="eyebrow">World Immigrant</p>
        <h1 id="home-title">{t("home.heroHeadline", locale)} <span class="hero-globe" aria-hidden="true">🌍</span></h1>
        <p class="landing-lede">{t("home.h1", locale)}</p>
        <div class="action-row">
          <a class="btn btn-primary" href="#pathways">{t("home.viewPathways", locale)}</a>
          <a class="btn btn-ghost" href={compareHref}>{t("home.compareArrow", locale)}</a>
        </div>
      </div>

      <aside class="coverage-panel" aria-label={t("home.coverage", locale)}>
        <p class="eyebrow">{t("home.coverage", locale)}</p>
        <p class="coverage-total">
          <strong>{programs.length}</strong>
          {" "}
          {programs.length === 1 ? t("home.pathwayCount", locale) : t("home.pathwaysCount", locale)}
        </p>
        <div class="coverage-marquee" aria-hidden="true">
          <div class="coverage-marquee-track">
            {
              [...sortedCountryModels, ...sortedCountryModels].map(({ country, programs: countryPrograms }) => (
                <div
                  class="coverage-marquee-item"
                  style={`--country-color: ${country.brand.color}`}
                >
                  <span class="country-swatch" aria-hidden="true"></span>
                  <span>
                    <strong>{pickLocalized(country.names, locale)}</strong>
                    <small>
                      {countryPrograms.length}{" "}
                      {countryPrograms.length === 1
                        ? t("home.pathwayCount", locale)
                        : t("home.pathwaysCount", locale)}
                    </small>
                  </span>
                </div>
              ))
            }
          </div>
        </div>
        <div class="coverage-footnote">
          <span>{sources.length} {t("home.sourcesCount", locale)}</span>
          <a href={L("/sources")}>{t("home.sourceRegistry", locale)}</a>
        </div>
      </aside>
    </section>

    <nav class="quick-actions" aria-label={t("home.startHere", locale)}>
      <a class="quick-action" href={L("/countries")}
        ><span>01</span> {t("home.browseDestinations", locale)}</a>
      <a class="quick-action" href={compareHref}
        ><span>02</span> {t("home.comparePathways", locale)}</a>
      <a class="quick-action" href={L("/filter")}
        ><span>03</span> {t("home.checkFit", locale)}</a>
    </nav>

    <section class="section pathway-section" id="pathways" aria-labelledby="pathways-heading">
      <div class="section-heading section-heading-wide">
        <div>
          <p class="eyebrow">{t("home.availableNow", locale)}</p>
          <h2 id="pathways-heading">{t("home.pathways", locale)}</h2>
        </div>
      </div>
      <section class="category-list" aria-label={t("home.pathways", locale)}>
        {
          categories.map((category, index) => {
            const count = programs.filter(({ category_ids }) =>
              category_ids.includes(category.id),
            ).length;
            const color = categoryColors[category.id] ?? categoryColors.other;
            return (
              <a
                class="category-list-item"
                href={L(`/categories/${category.id}`)}
                style={`--item-color: ${color}; --item-delay: ${index * 30}ms`}
              >
                <span class="category-list-index" aria-hidden="true">
                  {String(index + 1).padStart(2, "0")}
                </span>
                <span class="category-list-body">
                  <span class="category-list-title">{pickLocalized(category.names, locale)}</span>
                  <span class="category-list-desc">
                    {pickLocalized(category.description_md, locale)}
                  </span>
                </span>
                <span class="category-list-meta">
                  {count}{" "}
                  {count === 1 ? t("home.pathwayCount", locale) : t("home.pathwaysCount", locale)}
                </span>
              </a>
            );
          })
        }
      </section>
      <div class="section-actions">
        <a class="btn btn-ghost" href={compareHref}>{t("home.compareBoth", locale)}</a>
        <a class="btn btn-ghost" href={L("/filter")}>{t("home.checkFitArrow", locale)}</a>
      </div>
    </section>

    <section class="coverage-section" aria-labelledby="countries-heading">
      <div class="section-heading section-heading-wide">
        <div>
          <p class="eyebrow">{t("home.destinations", locale)}</p>
          <h2 id="countries-heading">{t("home.byCountry", locale)}</h2>
        </div>
      </div>
      <div class="country-list">
        {
          sortedCountryModels.slice(0, visibleCount).map(({ country, programs: countryPrograms }) => (
            <article class="country-row" style={`--country-color: ${country.brand.color}`}>
              <div>
                <p class="card-meta">
                  <span class="country-swatch" aria-hidden="true"></span>
                  {country.iso2} · {regionLabel(country.region, locale)}
                </p>
                <h3>
                  <a href={L(`/countries/${country.id}`)}>
                    {pickLocalized(country.names, locale)}
                  </a>
                </h3>
              </div>
              <p>{shorten(pickLocalized(country.summary_md, locale), 140)}</p>
              <div class="country-row-meta">
                <span>
                  {countryPrograms.length}{" "}
                  {countryPrograms.length === 1
                    ? t("home.pathwayCount", locale)
                    : t("home.pathwaysCount", locale)}
                </span>
                <span>
                  {t("home.checkedLabel", locale)}{" "}
                  {country.freshness.last_checked_at.slice(0, 10)}
                </span>
              </div>
              <a class="btn btn-ghost" href={L(`/countries/${country.id}`)}>
                {t("home.open", locale)}
              </a>
            </article>
          ))
        }
        {
          sortedCountryModels.length > visibleCount && (
            <div class="country-list-rest" data-hidden="true">
              {sortedCountryModels.slice(visibleCount).map(({ country, programs: countryPrograms }) => (
                <article class="country-row" style={`--country-color: ${country.brand.color}`}>
                  <div>
                    <p class="card-meta">
                      <span class="country-swatch" aria-hidden="true"></span>
                      {country.iso2} · {regionLabel(country.region, locale)}
                    </p>
                    <h3>
                      <a href={L(`/countries/${country.id}`)}>
                        {pickLocalized(country.names, locale)}
                      </a>
                    </h3>
                  </div>
                  <p>{shorten(pickLocalized(country.summary_md, locale), 140)}</p>
                  <div class="country-row-meta">
                    <span>
                      {countryPrograms.length}{" "}
                      {countryPrograms.length === 1
                        ? t("home.pathwayCount", locale)
                        : t("home.pathwaysCount", locale)}
                    </span>
                    <span>
                      {t("home.checkedLabel", locale)}{" "}
                      {country.freshness.last_checked_at.slice(0, 10)}
                    </span>
                  </div>
                  <a class="btn btn-ghost" href={L(`/countries/${country.id}`)}>
                    {t("home.open", locale)}
                  </a>
                </article>
              ))}
            </div>
          )
        }
      </div>
      <div class="section-actions">
        {
          sortedCountryModels.length > visibleCount && (
            <button class="btn btn-primary" type="button" data-toggle="country-list-rest">
              {t("home.viewMore", locale)}
            </button>
          )
        }
        <a class="btn btn-ghost" href={L("/countries")}>{t("home.allDestinations", locale)}</a>
      </div>
    </section>

    <section class="source-note" aria-label={t("home.sourceRegistry", locale)}>
      <p>
        <strong>{t("home.policyChanges", locale)}</strong>
        {" "}
        {t("home.policyBody", locale)}
      </p>
      <a class="btn btn-ghost" href={L("/sources")}>{t("home.inspectSources", locale)}</a>
    </section>
  </main>

  <script>
    document.querySelectorAll("[data-toggle]").forEach((btn) => {
      btn.addEventListener("click", () => {
        const target = btn.getAttribute("data-toggle");
        if (!target) return;
        const rest = document.querySelector(`.${target}`);
        if (!rest) return;
        const hidden = rest.getAttribute("data-hidden") === "true";
        rest.setAttribute("data-hidden", hidden ? "false" : "true");
        btn.textContent = hidden
          ? btn.getAttribute("data-label-less") || btn.textContent
          : btn.getAttribute("data-label-more") || btn.textContent;
      });
    });
  </script>
</Layout>
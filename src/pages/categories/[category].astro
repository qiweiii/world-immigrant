---
import Layout from "../../components/Layout.astro";
import VisaCard from "../../components/VisaCard.astro";
import { loadCanonicalData, type CanonicalDataset } from "../../lib/data";
import type { Category, Country, Program } from "../../lib/schema";
import { defaultLocale, pickLocalized, t, withLocale, type Locale } from "../../i18n";

type CategoryModel = {
  category: Category;
  programs: Array<{ program: Program; country: Country }>;
};

interface Props {
  model: CategoryModel;
  locale?: Locale;
}

export async function getStaticPaths() {
  const dataset: CanonicalDataset = await loadCanonicalData();
  const countries = new Map(dataset.countries.map((country) => [country.id, country]));
  return dataset.categories.map((category) => ({
    params: { category: category.id },
    props: {
      model: {
        category,
        programs: dataset.programs
          .filter(({ category_ids }) => category_ids.includes(category.id))
          .flatMap((program) => {
            const country = countries.get(program.country_id);
            return country ? [{ program, country }] : [];
          }),
      } satisfies CategoryModel,
    },
  }));
}

const { model, locale = defaultLocale } = Astro.props as Props;
const L = (path: string) => withLocale(path, locale);
const categoryName = pickLocalized(model.category.names, locale);
---

<Layout
  locale={locale}
  title={`${categoryName} ${t("categories.pathwaysSuffix", locale)}`}
>
  <main>
    <nav class="breadcrumbs" aria-label={t("crumb.aria", locale)}>
      <a href={L("/")}>{t("crumb.home", locale)}</a>
      <span aria-hidden="true">/</span>
      <a href={L("/categories")}>{t("nav.categories", locale)}</a>
      <span aria-hidden="true">/</span>
      <span>{categoryName}</span>
    </nav>

    <section class="hero">
      <p class="eyebrow">{t("categories.category", locale)}</p>
      <h1>{categoryName}</h1>
      <p>{pickLocalized(model.category.description_md, locale)}</p>
    </section>
    <section class="section" aria-labelledby="programs-heading">
      <div class="section-heading">
        <div>
          <p class="eyebrow">{t("categories.pathways", locale)}</p>
          <h2 id="programs-heading">{t("categories.programsHeading", locale)}</h2>
        </div>
      </div>
      {
        model.programs.length ? (
          <div class="card-grid">
            {model.programs.map(({ program, country }) => (
              <VisaCard
                locale={locale}
                title={pickLocalized(program.official_names, locale)}
                country={pickLocalized(country.names, locale)}
                category={categoryName}
                summary={pickLocalized(program.summary_md, locale)}
                href={L(`/programs/${program.id}`)}
                status={program.status}
                checkedAt={program.freshness.last_checked_at}
              />
            ))}
          </div>
        ) : (
          <div class="panel">
            <p>{t("categories.empty", locale)}</p>
          </div>
        )
      }
    </section>
  </main>
</Layout>

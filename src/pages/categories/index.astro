---
import Layout from "../../components/Layout.astro";
import { loadCanonicalData } from "../../lib/data";
import { defaultLocale, pickLocalized, t, withLocale, type Locale } from "../../i18n";
import { absoluteUrl, breadcrumbJsonLd } from "../../lib/seo";

interface Props {
  locale?: Locale;
}

const { locale = defaultLocale } = Astro.props as Props;
const { categories, programs } = await loadCanonicalData();
const L = (path: string) => withLocale(path, locale);
const structuredData = [
  breadcrumbJsonLd([
    { name: t("crumb.home", locale), path: L("/") },
    { name: t("categories.eyebrow", locale), path: L("/categories") },
  ]),
  {
    "@type": "ItemList",
    numberOfItems: categories.length,
    itemListElement: categories.map((category, index) => ({
      "@type": "ListItem",
      position: index + 1,
      name: pickLocalized(category.names, locale),
      url: absoluteUrl(L(`/categories/${category.id}`)),
    })),
  },
];

/** Distinct accent per category for list hover washes */
const categoryColors: Record<string, string> = {
  digital_nomad: "#0ea5e9",
  skilled_worker: "#2563eb",
  study_to_pr: "#8b5cf6",
  startup_entrepreneur: "#f59e0b",
  investor: "#10b981",
  family: "#ec4899",
  retirement: "#14b8a6",
  e_residency: "#6366f1",
  humanitarian: "#ef4444",
  other: "#64748b",
};
---

<Layout
  locale={locale}
  title={t("categories.title", locale)}
  description={t("categories.lede", locale)}
  pageType="CollectionPage"
  structuredData={structuredData}
>
  <main>
    <nav class="breadcrumbs" aria-label={t("crumb.aria", locale)}>
      <a href={L("/")}>{t("crumb.home", locale)}</a>
      <span aria-hidden="true">/</span>
      <span>{t("categories.eyebrow", locale)}</span>
    </nav>

    <section class="hero">
      <p class="eyebrow">{t("categories.eyebrow", locale)}</p>
      <h1>{t("categories.h1", locale)}</h1>
      <p>{t("categories.lede", locale)}</p>
    </section>

    <section class="category-list" aria-label={t("categories.eyebrow", locale)}>
      {
        categories.map((category, index) => {
          const count = programs.filter(({ category_ids }) => category_ids.includes(category.id))
            .length;
          const color = categoryColors[category.id] ?? categoryColors.other;
          return (
            <a
              class="category-list-item"
              href={L(`/categories/${category.id}`)}
              style={`--item-color: ${color}; --item-delay: ${index * 30}ms`}
            >
              <span class="category-list-index" aria-hidden="true">
                {String(index + 1).padStart(2, "0")}
              </span>
              <span class="category-list-body">
                <span class="category-list-title">{pickLocalized(category.names, locale)}</span>
                <span class="category-list-desc">
                  {pickLocalized(category.description_md, locale)}
                </span>
              </span>
              <span class="category-list-meta">
                {count}{" "}
                {count === 1 ? t("categories.program", locale) : t("categories.programs", locale)}
              </span>
            </a>
          );
        })
      }
    </section>
  </main>
</Layout>

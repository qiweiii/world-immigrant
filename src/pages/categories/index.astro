---
import Layout from "../../components/Layout.astro";
import { loadCanonicalData } from "../../lib/data";

const { categories, programs } = await loadCanonicalData();
---

<Layout title="Immigration pathway categories — World Immigrant">
  <main>
    <nav class="breadcrumbs" aria-label="Breadcrumb">
      <a href="/">Home</a>
      <span aria-hidden="true">/</span>
      <span>Categories</span>
    </nav>

    <section class="hero">
      <p class="eyebrow">Categories</p>
      <h1>Browse by type of route.</h1>
      <p>Skilled worker, investor, digital nomad, and other immigration categories.</p>
    </section>
    <section class="card-grid" aria-label="Pathway categories">
      {
        categories.map((category) => {
          const count = programs.filter(({ category_ids }) => category_ids.includes(category.id)).length;
          return (
            <a class="card card-clickable" href={`/categories/${category.id}`}>
              <p class="card-meta">{count} program{count === 1 ? "" : "s"}</p>
              <h2 class="card-title">{category.names.en}</h2>
              <p class="card-description">{category.description_md.en}</p>
            </a>
          );
        })
      }
    </section>
  </main>
</Layout>
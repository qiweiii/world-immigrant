    "proof_history_months": "unknown",
    "stability_requirement_md": {
      "en": "The retained AEWV page ties eligibility to the offered job and employment agreement; it does not establish one universal personal-income threshold in this fixture."
    }
  },
  "timeline": {
    "application_processing_time_md": {
      "en": "Immigration New Zealand lists 80% processing within seven weeks. The visa can be up to five years based on the job; most jobs have a five-year maximum continuous stay and ANZSCO skill-level 4 or 5 jobs generally have three years."
    },
    "initial_validity_months": "unknown",
    "renewable": true,
    "max_stay_months": 60
  },
  "rights": {
    "work_allowed": true,

    "children_allowed": true,
    "spouse_work_allowed": "unknown",
    "dependent_parents_allowed": false,
    "note_md": {
      "en": "Partner and dependent-child visas may be supported, but the exact visa type depends on earnings, occupation skill level, NOL/ANZSCO status, Green List or approved transport/care-workforce status, and other conditions."
    }
  },
  "pr_pathway": {
    "available": "indirect",
    "summary_md": {
      "en": "The AEWV page says the visa can lead to a resident visa depending on the job and points applicants to New Zealand skilled-residence pathways."
    }
  },
  "citizenship_pathway": {

  "official_names": {
    "en": "Accredited Employer Work Visa (AEWV)"
  },
  "aliases": [
    "New Zealand AEWV"
  ],
  "status": "active",
  "status_note_md": {
    "en": "AEWV is an employer-linked temporary work visa. The Immigration New Zealand page states that it can lead to a resident visa depending on the job, but does not make residence automatic."
  },
  "summary_md": {
    "en": "A New Zealand work visa for a full-time job offer from an accredited employer, with job-specific conditions, up to five years for most jobs, and possible residence options depending on the occupation."
  },
  "good_for_md": {
    "en": "Skilled workers with a genuine full-time offer from an accredited New Zealand employer who can show at least two years of relevant experience or an accepted qualification."
  },
  "not_good_for_md": {
    "en": "Applicants without an accredited-employer job offer, applicants seeking open work rights unrelated to the offered job, or applicants treating AEWV alone as automatic residence."
  },
  "pathway_mechanism": "employer_sponsored",
  "eligibility": {
    "age": {},
    "education": {
      "required_level": "unknown",
      "credential_assessment_required": "unknown",
      "note_md": {
        "en": "The skill requirement can be met through at least two years of relevant job experience or a qualification at New Zealand Qualification Framework level 4 or higher."
      }
    },
    "work_experience": {
      "min_years": 2,
      "note_md": {
        "en": "Relevant experience or the alternative qualification route must be in the same field or industry as the offered job, subject to the visa rules."
      }
    },
    "language": [],
    "health_check_required": "unknown",
    "police_certificate_required": "unknown",

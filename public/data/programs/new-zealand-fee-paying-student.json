    "note_md": {
      "en": "You cannot include a partner or dependent children in the student visa application; they may apply for visas based on their relationship to you.",
      "zh-Hans": "不能将伴侣或受抚养子女纳入学生签证申请；他们可基于与你的关系另行申请签证。"
    }
  },
  "pr_pathway": {
    "available": "indirect",
    "summary_md": {
      "en": "A student visa is temporary. Later work or residence routes such as AEWV or Skilled Migrant Category may apply under their own rules after study.",
      "zh-Hans": "学生签证是临时的。学业后可能在各自规则下适用 AEWV 或技术移民等后续工作/居留途径。"
    }
  },

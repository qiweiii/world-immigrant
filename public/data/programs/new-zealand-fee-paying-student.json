  "official_names": {
    "en": "Fee Paying Student Visa",
    "zh-Hans": "自费学生签证（Fee Paying Student Visa）"
  },
  "aliases": [
    "New Zealand student visa",
    "NZ fee-paying student visa"
  ],
  "status": "active",
  "status_note_md": {
    "en": "Immigration New Zealand describes the Fee Paying Student Visa as the main full-time study route for international fee-paying students. Paper applications are no longer accepted; apply online. New Zealand has no dedicated digital-nomad visa in this record.",
    "zh-Hans": "新西兰移民局将自费学生签证描述为国际自费学生的主要全日制学习途径。不再接受纸质申请，须在线申请。本记录不将新西兰描述为提供专门数字游民签证。"
  },
  "summary_md": {
    "en": "A New Zealand student visa for people with an offer of place from an approved education provider who pay international tuition (or partial scholarship). INZ says stay can be up to 4 years, online applications cost from NZD $850, and 80% of decisions are within 9.5 weeks. Limited part-time work (up to 25 hours a week while studying, full-time in holidays) depends on visa conditions. Living funds are typically NZD $20,000 per year for tertiary study.",
    "zh-Hans": "面向获认可教育机构录取并支付国际学费（或部分奖学金）者的新西兰学生签证。移民局说明最长可停留 4 年，在线申请费用起价约 850 新西兰元，80% 在 9.5 周内出结果。有限兼职（学习期间每周最多 25 小时，假期可全职）取决于签证条件。高等教育生活费资金通常为每年 20,000 新西兰元。"
  },
  "good_for_md": {
    "en": "International students with an offer from an approved NZ provider, funds for tuition and living costs (or an acceptable sponsor), and genuine study intent.",
    "zh-Hans": "适合获新西兰认可教育机构录取、具备学费与生活费（或合格担保人），并有真实学习目的的国际学生。"
  },
  "not_good_for_md": {
    "en": "Applicants without an approved provider offer, people seeking unrestricted work or a digital-nomad stay, or those who cannot show funds, insurance, health, or character requirements.",
    "zh-Hans": "不适合没有认可机构录取、寻求不受限制工作或数字游民停留，或无法证明资金、保险、健康或品行要求的申请人。"
  },
  "pathway_mechanism": "other",
  "eligibility": {
    "age": {
      "note_md": {
        "en": "If aged under 10 and not in an NZQA-approved hostel, a parent or legal guardian must accompany you and you must live with them while studying.",
        "zh-Hans": "若未满 10 岁且不住在 NZQA 认可宿舍，须有父母或法定监护人陪同并在学习期间与其同住。"
      }
    },
    "education": {
      "required_level": "unknown",
      "credential_assessment_required": "unknown",
      "note_md": {
        "en": "Must be offered a place on a course by an approved education provider that is a signatory to the Education (Pastoral Care of Tertiary and International Learners) Code of Practice 2021.",
        "zh-Hans": "必须获得认可教育机构的课程录取，且该机构为 2021 年教育（高等教育与国际学习者牧养关怀）实践守则签署方。"
      }
    },
    "work_experience": {},
    "language": [],
    "health_check_required": true,
    "police_certificate_required": "unknown",
    "points_based": false,
    "job_offer_required": false,

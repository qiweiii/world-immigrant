  },
  "funds": {
    "proof_of_funds": [
      {
        "amount": 20000,
        "currency": "NZD",
        "period": "annual",
        "applies_to": "primary",
        "calculation": "minimum_total",
        "note_md": {
          "en": "Tertiary, English language or other non-compulsory study living costs: NZD $20,000 per year if studying 1 year or more, or NZD $1,667 per month if shorter. School years 1–13 use NZD $17,000 per year or NZD $1,417 per month. Plus tuition and outward travel funds.",
          "zh-Hans": "高等教育、英语或其他非义务教育生活费：学习满一年及以上每年 20,000 新西兰元，不足一年每月 1,667 新西兰元。小学至中学 1–13 年级为每年 17,000 或每月 1,417。另需学费与离境交通资金。"
        }
      }
    ],
    "application_fees": [
      {
        "label": {
          "en": "Fee Paying Student Visa application fee (from)",

  "timeline": {
    "application_processing_time_md": {
      "en": "INZ states cost from NZD $850, processing 80% within 9.5 weeks, and strongly encourages applying 3 months before travel. Maximum stay up to 4 years; visa length usually matches paid study or passport validity if sooner.",
      "zh-Hans": "移民局说明费用起价 850 新西兰元，80% 在 9.5 周内处理，强烈建议出行前 3 个月申请。最长停留 4 年；签证时长通常与已付学费学习期或护照有效期（以较短者为准）一致。"
    },
    "processing_time_months_min": 2,
    "processing_time_months_max": 3,

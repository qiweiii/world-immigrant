  "official_names": {
    "en": "Study permit",
    "zh-Hans": "学习许可"
  },
  "aliases": [
    "Canada study permit",
    "Canadian study visa",
    "Study permit Canada"
  ],
  "status": "active",
  "status_note_md": {
    "en": "Most foreign nationals need a study permit to study at a designated learning institution in Canada. Applicants should apply before travelling to Canada. Rules such as provincial attestation letters and financial support amounts can change.",
    "zh-Hans": "大多数外国人在加拿大指定学习机构学习需要学习许可。申请人应在前往加拿大前申请。省/地区证明信和资金要求等规则可能变化。"
  },
  "summary_md": {
    "en": "Canada's principal temporary study authorization for international students enrolled at designated learning institutions. It can form part of a longer study-to-work-to-PR path when the program and later PGWP or Express Entry rules are met, but the study permit itself is not permanent residence.",
    "zh-Hans": "加拿大面向在指定学习机构就读的国际学生的主要临时学习许可。在课程及后续毕业工签或快速通道规则满足时，可成为学习-工作-永居路径的一部分，但学习许可本身不是永久居留。"
  },
  "good_for_md": {
    "en": "Students accepted by a designated learning institution who can show a letter of acceptance, required provincial or territorial attestation in most cases, identity documents, first-year financial support, and intent to leave Canada when the permit expires.",
    "zh-Hans": "适合被指定学习机构录取，并能提供录取通知书、多数情况下所需的省/地区证明信、身份文件、首年经济能力证明，以及在许可到期时离开加拿大意向的学生。"
  },
  "not_good_for_md": {
    "en": "Applicants seeking unrestricted work, a digital-nomad route, or direct permanent residence. Canada does not offer a dedicated digital-nomad visa in this record. Work rights while studying are conditional and separate from the study permit decision itself.",
    "zh-Hans": "不适合寻求不受限制工作、数字游民途径或直接永久居留的申请人。本记录不将加拿大描述为提供专门数字游民签证。在学期间工作权利有条件限制，且与学习许可决定本身分开。"
  },
  "pathway_mechanism": "other",
  "eligibility": {
    "age": {},
    "education": {
      "required_level": "unknown",
      "credential_assessment_required": "unknown",
      "note_md": {
        "en": "Applicants must be enrolled at a designated learning institution. Post-secondary letters of acceptance are validated with the school. Program-level academic requirements are set by the institution rather than a single federal education floor in the retained IRCC pages. Core IRCC eligibility includes DLI enrolment, enough money for tuition, living expenses and return transport, lawfulness and possible police certificate, good health and possible medical exam, and proof the applicant will leave when the study permit expires. Most applicants also need a provincial or territorial attestation letter (or a CAQ for Quebec).",
        "zh-Hans": "申请人必须就读于指定学习机构。高等教育录取通知书需经学校验证。课程层面的学术要求由院校设定，保留的 IRCC 页面没有单一的联邦最低学历门槛。 IRCC 核心资格包括指定学习机构录取、足够支付学费/生活费/往返交通的资金、守法及可能的无犯罪证明、健康及可能的体检，以及证明学习许可到期后会离开。大多数申请人还需要省/地区证明信（魁北克为 CAQ）。"
      }
    },

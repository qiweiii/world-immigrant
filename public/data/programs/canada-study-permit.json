  "pr_pathway": {
    "available": "indirect",
    "summary_md": {
      "en": "A study permit is temporary. Eligible graduates may later apply for a post-graduation work permit and, with Canadian experience, for permanent residence routes such as the Canadian Experience Class. Those later steps have separate eligibility rules.",
      "zh-Hans": "学习许可是临时的。合资格毕业生之后可能申请毕业工签，并在取得加拿大经验后申请加拿大经验类等永居途径。后续步骤有单独资格规则。"
    }
  },

  "status_note_md": {
    "en": "Official UAE sources describe a remote-work residence route. The source record remains under human review because service details and fees can change."
  },
  "summary_md": {
    "en": "A UAE remote-work residence route for people working remotely for an organization outside the UAE. The Dubai authority describes a one-year permit subject to renewal, while federal and Dubai sources state a USD 3,500 monthly income condition."
  },
  "good_for_md": {
    "en": "Remote employees with an overseas organization, documented monthly income of at least USD 3,500, health insurance, and the documents required by the issuing authority."
  },
  "not_good_for_md": {
    "en": "Applicants who cannot document remote work for an organization outside the UAE or the stated monthly income condition. Family, local-employment, and settlement outcomes require separate official confirmation."
  },

  "status_note_md": {
    "en": "The retained UGE page establishes the international-teleworker route. Detailed financial, family, fee, and duration fields remain unknown until the official FAQ can be fetched and verified.",
    "zh-Hans": "保留的 UGE 页面建立国际远程工作人员途径。在获取并验证官方常见问题解答之前，详细的财务、家庭、费用和期限字段仍然未知。"
  },
  "summary_md": {
    "en": "Spain's UGE describes an international-teleworker route for third-country nationals working remotely for companies outside Spain through computer, telematic, and telecommunications systems.",
    "zh-Hans": "西班牙的 UGE 描述了一种国际远程工作途径，供第三国国民通过计算机、远程信息处理和电信系统为西班牙境外的公司远程工作。"
  },
  "good_for_md": {
    "en": "Third-country nationals whose employment or professional activity can be performed remotely for a company outside Spain using computer, telematic, and telecommunications systems.",
    "zh-Hans": "可以使用计算机、远程信息处理和电信系统为西班牙境外的公司远程执行就业或专业活动的第三国国民。"
  },
  "not_good_for_md": {
    "en": "People whose work requires on-site activity or whose employment relationship is not with an organization outside Spain. Current income, family, fee, duration, and settlement details need the official FAQ evidence.",
    "zh-Hans": "工作需要现场活动或与西班牙境外组织没有雇佣关系的人员。目前的收入、家庭、费用、期限和定居详细信息需要官方常见问题解答证据。"
  },

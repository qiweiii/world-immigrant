    "income_location": "outside_destination",
    "proof_history_months": 6,
    "stability_requirement_md": {
      "en": "The FAQ states that applicants must evidence income during the six months before application and meet the monthly gross threshold.",
      "zh-Hans": "常见问题解答指出，申请人必须证明申请前六个月内的收入并达到每月总额门槛。"
    }
  },
  "timeline": {
    "application_processing_time_md": {
      "en": "The e-Residency programme page says DNV processing can take up to 30 days. The FAQ distinguishes a C visa of up to 90 days from a D visa of up to 365 days.",
      "zh-Hans": "e-Residency 计划页面显示，DNV 处理最多可能需要 30 天。常见问题解答将最长 90 天的 C 签证与最长 365 天的 D 签证区分开来。"
    },
    "initial_validity_months": "variable",
    "renewable": false,
    "max_stay_months": "variable"
  },
  "rights": {
    "work_allowed": true,
    "local_employment_allowed": false,
    "remote_work_allowed": true,
    "study_allowed": "unknown",
    "business_allowed": "unknown",
    "tax_residency_note_md": {
      "en": "The DNV is a temporary stay visa and is not a residence permit.",
      "zh-Hans": "DNV 是临时居留签证，不是居留许可。"
    }
  },
  "family": {
    "spouse_or_partner_allowed": "unknown",

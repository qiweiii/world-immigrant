    "dependent_parents_allowed": "unknown",
    "note_md": {
      "en": "The retained DNV pages do not establish dependant eligibility or dependant work rights.",
      "zh-Hans": "保留的 DNV 页面不建立附属资格或附属工作权利。"
    }
  },
  "pr_pathway": {
    "available": false,
    "summary_md": {
      "en": "The FAQ states that DNV stays do not provide an advantage for obtaining an Estonian residence permit and do not give permanent residence.",
      "zh-Hans": "常见问题解答指出，DNV 居留并不能为获得爱沙尼亚居留许可提供优势，也不能提供永久居留权。"
    }
  },
  "citizenship_pathway": {
    "available": false,
    "summary_md": {
      "en": "The FAQ states that DNV stays do not give a right to Estonian citizenship.",
      "zh-Hans": "常见问题解答指出，DNV 停留并不赋予爱沙尼亚公民身份的权利。"
    }
  },

{
  "id": "estonia-digital-nomad-visa",
  "country_id": "estonia",
  "category_ids": [
    "digital_nomad"
  ],
  "official_names": {
    "en": "Digital Nomad Visa",
    "zh-Hans": "数字游牧签证"
  },
  "aliases": [
    "Estonia Digital Nomad Visa",
    "Estonia DNV"
  ],
  "status": "active",
  "status_note_md": {
    "en": "The Digital Nomad Visa is a temporary stay visa, separate from e-Residency, and does not create a permanent-residence or citizenship route.",
    "zh-Hans": "数字游牧签证是一种临时居留签证，与电子居留分开，不会创建永久居留或公民身份途径。"
  },
  "summary_md": {
    "en": "A temporary Estonian visa for location-independent workers working for a foreign employer, a foreign company, or mostly foreign clients, with a maximum D-visa stay of up to one year.",
    "zh-Hans": "爱沙尼亚临时签证，适用于为外国雇主、外国公司或大多数外国客户工作的不受地点限制的工人，D 签证最长停留期限为一年。"
  },
  "good_for_md": {
    "en": "Remote employees, foreign-company owners, and freelancers with mostly foreign clients who can prove location-independent work and the required income history.",
    "zh-Hans": "远程员工、外国公司所有者和主要是外国客户的自由职业者，他们可以证明与地点无关的工作和所需的收入历史。"
  },
  "not_good_for_md": {
    "en": "Applicants seeking Estonian residence, permanent residence, citizenship, local employment, or an e-Residency substitute.",
    "zh-Hans": "寻求爱沙尼亚居留权、永久居留权、公民身份、当地就业或电子居留权替代的申请人。"
  },
  "pathway_mechanism": "remote_income",
  "eligibility": {
    "age": {},
    "education": {
      "required_level": "none",
      "credential_assessment_required": "not_applicable",
      "note_md": {
        "en": "Applicants must work location-independently and fit a foreign-employer, foreign-company, or mostly-foreign-client freelancer category. Standard visa rules also apply.",
        "zh-Hans": "申请人必须独立工作地点，并且符合外国雇主、外国公司或主要是外国客户的自由职业者类别。标准签证规则也适用。"
      }
    },

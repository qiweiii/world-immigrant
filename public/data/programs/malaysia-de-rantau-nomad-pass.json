  "status_note_md": {
    "en": "MDEC maintains the DE Rantau Nomad Pass programme. Its 2026 update says the programme has expanded beyond IT and digital fields to additional professional roles.",
    "zh-Hans": "MDEC 继续提供 DE Rantau 数字游牧者准证。其 2026 年更新说明，该计划已从 IT 和数字领域扩展到其他专业岗位。"
  },
  "summary_md": {
    "en": "A Malaysian digital-nomad route for eligible foreign digital professionals and remote workers. MDEC describes the programme as a way for qualified professionals to stay and work longer in Malaysia, while the latest update broadens eligible professional fields.",
    "zh-Hans": "面向符合条件的外国数字专业人士和远程工作者的马来西亚数字游牧途径。MDEC 将该计划描述为让合格专业人士在马来西亚停留和工作更长时间的途径，最新更新还扩大了可申请的专业领域。"
  },
  "good_for_md": {
    "en": "Remote workers, digital professionals, and other professional roles covered by the current MDEC programme who can document the required work and supporting evidence.",
    "zh-Hans": "适合当前 MDEC 计划涵盖的远程工作者、数字专业人士及其他专业岗位人员，前提是能够提供所需工作和支持材料证明。"
  },
  "not_good_for_md": {
    "en": "Applicants seeking Malaysian local employment, permanent residence, or a route whose current income, duration, and family conditions have not been confirmed in the retained MDEC pages.",
    "zh-Hans": "不适合寻求马来西亚本地就业、永久居留，或需要当前保留的 MDEC 页面尚未确认的收入、期限和家庭条件的申请人。"
  },

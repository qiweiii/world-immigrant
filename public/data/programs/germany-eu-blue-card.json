  "status_note_md": {
    "en": "The official Make it in Germany page presents the EU Blue Card as an active residence route for qualified professionals with a job offer and the applicable salary requirement.",
    "zh-Hans": "德国官方 Make it in Germany 页面将欧盟蓝卡列为面向拥有工作机会并满足适用薪资要求的合格专业人士的有效居留途径。"
  },
  "summary_md": {
    "en": "A German residence route for qualified professionals with an employment contract or binding job offer, recognized or comparable higher education, and the applicable gross annual salary threshold. The official page also describes special rules for some IT professionals without a formal qualification.",
    "zh-Hans": "面向合格专业人士的德国居留途径，要求劳动合同或有约束力的工作机会、获认可或同等的高等教育学历，以及适用的年度税前年薪门槛。官方页面还说明了部分没有正式学历的 IT 专业人士可适用特殊规则。"
  },
  "good_for_md": {
    "en": "Qualified professionals with a German job offer, relevant higher education or an eligible IT profile, and salary meeting the current threshold for the occupation.",
    "zh-Hans": "适合拥有德国工作机会、相关高等教育学历或符合条件的 IT 背景，并达到当前职业薪资门槛的专业人士。"
  },
  "not_good_for_md": {
    "en": "Applicants without a qualifying job offer or without a route-specific qualification and salary profile. The exact threshold depends on the current rules and occupation category.",
    "zh-Hans": "不适合没有合格工作机会，或不具备该途径要求的资格和薪资条件的申请人。具体门槛取决于当前规定和职业类别。"
  },

  "official_names": {
    "en": "Long-stay study authorisation",
    "zh-Hans": "长期学习居留许可"
  },
  "aliases": [
    "Spain study visa",
    "Study stay authorisation",
    "Estancia por estudios"
  ],
  "status": "active",
  "status_note_md": {
    "en": "Spain distinguishes study stays exceeding 90 days from shorter study stays. The Ministry of Inclusion and the Ministry of Foreign Affairs publish the study-stay and visa requirements.",
    "zh-Hans": "西班牙区分超过 90 天的学习停留和较短的学习停留。包容部和外交部公布学习停留及签证要求。"
  },
  "summary_md": {
    "en": "A temporary study-stay route for higher education, post-compulsory secondary education, student mobility, volunteering, and specified training activities lasting more than 90 days.",
    "zh-Hans": "面向高等教育、义务后中等教育、学生流动、志愿服务和特定培训活动的临时学习停留途径，适用于超过 90 天的项目。"
  },
  "good_for_md": {
    "en": "Students accepted by an eligible Spanish programme who can show acceptance, financial means, health insurance, and the required identity, health, and criminal-record documents.",
    "zh-Hans": "适合被西班牙合资格课程录取，并能够证明录取、经济能力、医疗保险以及所需身份、健康和犯罪记录材料的学生。"
  },
  "not_good_for_md": {
    "en": "Applicants seeking unrestricted employment, a direct permanent-residence route, or a short stay that does not require this long-stay study authorisation.",
    "zh-Hans": "不适合寻求不受限制就业、直接永久居留途径，或不需要长期学习居留许可的短期停留申请人。"
  },

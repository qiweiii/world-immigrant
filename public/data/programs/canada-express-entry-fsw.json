{
  "id": "canada-express-entry-fsw",
  "country_id": "canada",
  "category_ids": [
    "skilled_worker"
  ],
  "official_names": {
    "en": "Federal Skilled Worker Program",
    "zh-Hans": "联邦技术工人计划"
  },
  "aliases": [
    "FSWP",
    "Federal Skilled Worker",
    "Express Entry FSW"
  ],
  "status": "active",
  "status_note_md": {
    "en": "The program accepts profiles through Express Entry. Meeting the program minimums permits entry to the pool but does not guarantee an invitation to apply.",
    "zh-Hans": "该计划通过“快速通道”接受个人资料。满足计划最低要求即可进入人才库，但不能保证获得申请邀请。"
  },
  "summary_md": {
    "en": "A federal permanent-residence pathway for skilled workers with foreign work experience. Candidates must satisfy the Federal Skilled Worker minimum requirements and score at least 67 out of 100 selection-factor points before competing for an invitation through Express Entry.",
    "zh-Hans": "为具有外国工作经验的技术工人提供联邦永久居留途径。候选人必须满足联邦技术工人的最低要求，并在通过“快速通道”竞争邀请之前获得至少 67 分（满分 100 分）。"
  },
  "good_for_md": {
    "en": "Skilled workers with qualifying experience, an approved language test, recognized education, and a competitive Express Entry profile who intend to settle outside Quebec.",
    "zh-Hans": "具有合格经验、经过批准的语言测试、受认可的教育以及具有竞争力的快速通道资料且打算在魁北克以外定居的技术工人。"
  },
  "not_good_for_md": {
    "en": "People who cannot meet the language, skilled-work, education, admissibility, or settlement-fund rules. Passing the 67-point Federal Skilled Worker threshold does not itself guarantee an invitation because Express Entry invitations are competitive.",
    "zh-Hans": "不符合语言、技术工作、教育、入境或定居基金规则的人。通过 67 分的联邦技术工人门槛本身并不能保证获得邀请，因为“快速通道”邀请具有竞争力。"
  },
  "pathway_mechanism": "points_invitation",
  "eligibility": {
    "age": {
      "points_sensitive": true,
      "note_md": {
        "en": "There is no stated hard maximum age, but selection-factor points decline after age 35 and reach zero at age 47.",
        "zh-Hans": "没有规定硬性的最高年龄，但选择因素点在 35 岁之后下降，并在 47 岁时达到零。"
      }
    },
    "education": {
      "required_level": "secondary",
      "credential_assessment_required": "not_applicable",
      "credential_assessment_condition": "foreign_education",
      "note_md": {
        "en": "A Canadian secondary or post-secondary credential qualifies. Foreign education requires an immigration-purpose Educational Credential Assessment showing equivalence to a completed Canadian credential.",
        "zh-Hans": "加拿大中学或高等教育证书符合资格。外国教育需要进行移民目的的教育证书评估，证明其与已完成的加拿大证书相当。"
      }
    },
    "work_experience": {
      "min_years": 1,
      "occupation_list_required": true,
      "note_md": {
        "en": "At least 1,560 hours of qualifying paid skilled work are required. The work must align with an eligible National Occupational Classification occupation and satisfy the program's continuity and timing rules. Self-employed and qualifying student work may count under the stated conditions.",
        "zh-Hans": "需要至少 1,560 小时的合格带薪技术工作。该工作必须符合合格的国家职业分类职业，并满足该计划的连续性和时间安排规则。自营职业和合格的学生工作可以在规定的条件下计算在内。"
      }
    },
    "language": [
      {
        "language": "en-or-fr",
        "test": "IRCC-approved English or French test",
        "minimum_level": "CLB 7 or NCLC 7 in all four abilities",
        "minimum_benchmark": 7,
        "note_md": {
          "en": "Approved results must be less than two years old when the Express Entry profile and permanent-residence application are submitted.",
          "zh-Hans": "提交快速通道资料和永久居留申请时，批准的结果必须少于两年。"
        }
      }
    ],
    "health_check_required": true,
    "police_certificate_required": true,
    "points_based": true,
    "points_threshold": 67,
    "invitation_competition_level": "high",
    "job_offer_required": false,
    "sponsor_required": false
  },

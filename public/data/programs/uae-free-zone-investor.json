  "status": "active",
  "status_note_md": {
    "en": "This fixture combines an official DMCC free-zone company setup path with the Dubai GDRFA partner/investor Green Residence service. The government portal's broader Green Visa pages remain supplementary and are not used for claims here."
  },
  "summary_md": {
    "en": "A company-owner route pairing DMCC free-zone company formation with Dubai's Green Residence permit for an investor or partner in a commercial project."
  },
  "good_for_md": {
    "en": "Founders or partners who need a UAE free-zone company, can provide ownership and business documents, and want a renewable five-year residence permit tied to their partner/investor status."
  },
  "not_good_for_md": {
    "en": "Applicants seeking a passive residence route without a company or commercial-project role, or those who need a published universal setup cost, family entitlement, or permanent-residence outcome."
  },

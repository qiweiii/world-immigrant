    "local_director_required": "unknown",
    "note_md": {
      "en": "DMCC describes a digital formation process, shareholder and ownership documents, business information, a registered office solution, and an electronic licence. GDRFA requires partnership/MOA or investment-contract evidence and a trade licence for the residence permit."
    }
  },
  "timeline": {
    "application_processing_time_md": {
      "en": "DMCC says company formation typically takes around 10 working days depending on documents and approvals. GDRFA lists 48 hours as the expected completion time for the residence service."

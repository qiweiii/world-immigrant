  "status": "active",
  "status_note_md": {
    "en": "USCIS maintains the H-1B specialty-occupation classification. The current USCIS page includes cap-selection and entry-related notices, so availability and filing conditions require human review at application time.",
    "zh-Hans": "USCIS 继续提供 H-1B 专业职业类别。当前 USCIS 页面包含配额抽选和入境相关通知，因此申请时必须人工核实可用性和递交条件。"
  },
  "summary_md": {
    "en": "A US employer-sponsored nonimmigrant classification for services in a specialty occupation requiring highly specialized knowledge and a directly related bachelor’s degree or equivalent. USCIS describes an employer petition, a certified Labor Condition Application, and an electronic registration process for cap-subject cases.",
    "zh-Hans": "美国雇主担保的非移民类别，面向需要高度专业知识以及相关学士学位或同等学历的专业职业。USCIS 说明，该途径涉及雇主递交申请、经认证的劳工情况申请，以及受配额限制案件的电子注册流程。"
  },
  "good_for_md": {
    "en": "Applicants with a US employer and a specialty-occupation role whose degree, equivalent education or experience, and licensing evidence match the offered position.",
    "zh-Hans": "适合拥有美国雇主和专业职业岗位，并且学历、同等教育或经验以及执照证明与职位要求相匹配的申请人。"
  },
  "not_good_for_md": {
    "en": "Applicants without a qualifying employer petition, a directly related specialty qualification, or a selected registration where the case is cap-subject. This is not a general permanent-residence route, and the United States does not have a dedicated digital-nomad visa in this record.",
    "zh-Hans": "不适合没有合格雇主申请、相关专业资格，或在受配额限制时没有入选注册的申请人。这不是一般性的永久居留途径，且本记录不将美国描述为提供专门数字游民签证。"
  },

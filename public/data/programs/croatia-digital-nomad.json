      "savings"
    ],
    "income_location": "outside_destination",
    "proof_history_months": 6,
    "stability_requirement_md": {
      "en": "The MUP page requires at least 2.5 average Croatian net salaries, currently €3,622.50 per month. It allows regular-income evidence or payslips for the previous six months; alternatives include €43,470 for a 12-month stay or €65,205 for an 18-month stay."
    }
  },
  "timeline": {
    "application_processing_time_md": {
      "en": "Temporary stay may be granted for up to 18 months. If granted for less than 18 months, an extension of up to six months may be requested no later than 60 days before expiry. A new digital-nomad application may be submitted six months after expiry."
    },
    "initial_validity_months": "variable",
    "renewable": true,
    "max_stay_months": 18
  },

            ],
            "note_md": {
              "en": "Proof of funds is not required when both conditions are met."
            }
          }
        ],
        "exemption_note_md": {
          "en": "Proof of funds is not required when the applicant is authorized to work in Canada and has a valid Canadian job offer. Family size includes the applicant, spouse or common-law partner, and dependent children, including family members who are not accompanying the applicant."
        },

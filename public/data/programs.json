        "study_allowed": true,
        "business_allowed": "unknown",
        "healthcare_access_md": {
          "en": "Permanent residents may qualify for public health coverage, but enrollment and waiting rules are provincial or territorial."
        },
        "tax_residency_note_md": {
          "en": "Tax residence depends on facts and Canadian tax rules; permanent-resident status alone is not a complete tax-residency determination."
        }
      },
      "family": {
        "spouse_or_partner_allowed": true,
        "unmarried_partner_allowed": true,
        "children_allowed": true,
        "max_child_age": "unknown",
        "spouse_work_allowed": true,
        "dependent_parents_allowed": "not_applicable",
        "note_md": {
          "en": "A spouse or common-law partner and dependent children must be declared and may accompany the principal applicant. Each family member must satisfy the applicable admissibility and document requirements."
        }
      },
      "pr_pathway": {
        "available": true,
        "summary_md": {
          "en": "A successful application grants Canadian permanent residence directly."
        }
      },
      "citizenship_pathway": {
        "available": "indirect",
        "min_residence_years": 3,
        "physical_presence_requirement_md": {
          "en": "Adult citizenship applicants generally need at least 1,095 days of physical presence during the five-year eligibility period, including at least 730 days as a permanent resident."
        },
        "language_requirement_md": {
          "en": "Applicants aged 18 to 54 generally need to demonstrate adequate English or French and take the citizenship test, subject to the official exemptions and waiver rules."
        },
        "summary_md": {
          "en": "Permanent residence can lead to citizenship after the separate citizenship requirements are met."
        }
      },
